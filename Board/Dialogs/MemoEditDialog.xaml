<Window
    x:Class="NewSchool.Board.Dialogs.MemoEditDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:controls="using:NewSchool.Controls"
    xmlns:boardcontrols="using:NewSchool.Board.Controls"
    mc:Ignorable="d"
    Title="메모 편집">

    <Grid Padding="24,20,24,16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 헤더: 체크박스, 카테고리, 제목 -->
        <Grid Grid.Row="0"
              Padding="0,0,0,12"
              BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
              BorderThickness="0,0,0,1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="32"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- 완료 체크박스 -->
            <CheckBox x:Name="ChkCompleted"
                      Grid.Column="0"
                      VerticalAlignment="Center"
                      ToolTipService.ToolTip="완료 표시"/>

            <!-- 카테고리 -->
            <ComboBox x:Name="CBoxCategory"
                      Grid.Column="1"
                      MinWidth="100"
                      VerticalAlignment="Center"
                      Margin="0,0,8,0">
                <ComboBoxItem Content="수업" Tag="수업"/>
                <ComboBoxItem Content="학급" Tag="학급"/>
                <ComboBoxItem Content="업무" Tag="업무"/>
                <ComboBoxItem Content="개인" Tag="개인"/>
            </ComboBox>

            <!-- 제목 -->
            <TextBox x:Name="TxtTitle"
                     Grid.Column="2"
                     PlaceholderText="메모 제목"
                     VerticalAlignment="Center"/>
        </Grid>

        <!-- 에디터 + 파일 영역 -->
        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto"
                      Padding="0,12,0,0">
            <StackPanel Spacing="12">

                <!-- 에디터 -->
                <Border BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="4"
                        MinHeight="300">
                    <controls:RichTextEditor x:Name="Editor"
                                         Mode="Full"
                                         MinHeight="280"/>
                </Border>

                <!-- 첨부파일 섹션 -->
                <StackPanel Spacing="8">
                    <TextBlock Text="📎 첨부파일"
                               Style="{StaticResource BodyStrongTextBlockStyle}"/>

                    <Border BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1"
                            CornerRadius="4"
                            Background="{ThemeResource LayerFillColorDefaultBrush}"
                            MinHeight="80"
                            Padding="8">
                        <boardcontrols:PostFileListBox x:Name="FileList"
                                                 AllowDrop="True"/>
                    </Border>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>

        <!-- 메타정보 (작성일시) -->
        <TextBlock x:Name="TxtMetadata"
                   Grid.Row="2"
                   Margin="0,12,0,0"
                   FontSize="11"
                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                   HorizontalAlignment="Right"/>

        <!-- 하단 버튼 -->
        <StackPanel Grid.Row="3"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Spacing="8"
                    Margin="0,12,0,0">
            <Button x:Name="BtnSave"
                    Content="저장"
                    Style="{StaticResource AccentButtonStyle}"
                    MinWidth="90"
                    Click="BtnSave_Click"/>
            <Button x:Name="BtnCancel"
                    Content="취소"
                    MinWidth="90"
                    Click="BtnCancel_Click"/>
        </StackPanel>
    </Grid>
</Window>

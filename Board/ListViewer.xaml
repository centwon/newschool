<!-- ListViewer.xaml (WinUI3 - MVVM 패턴 + 수동 UI 업데이트) -->
<Page
    x:Class="NewSchool.Board.ListViewer"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:NewSchool.Board"
    xmlns:newschool="using:NewSchool"
    Background="White">

    <Page.Resources>
        <newschool:DateToShortString x:Key="DateToShortString"/>

        <!-- 헤더 텍스트 스타일 -->
        <Style x:Key="HeaderTextBlockStyle" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Padding" Value="8,8"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <!-- 아이템 텍스트 스타일 -->
        <Style x:Key="ItemTextBlockStyle" TargetType="TextBlock">
            <Setter Property="Padding" Value="8,8"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
        </Style>
    </Page.Resources>

    <ScrollViewer x:Name="Scroller" VerticalScrollBarVisibility="Auto">
        <Grid x:Name="GridBoard">
            <Grid.RowDefinitions>
                <RowDefinition x:Name="RowTop" Height="40"/>
                <RowDefinition x:Name="RowContent" Height="Auto"/>
                <RowDefinition x:Name="RowList" Height="*"/>
                <RowDefinition x:Name="RowPaging" Height="40"/>
                <RowDefinition x:Name="RowSearch" Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- 상단 헤더 -->
            <Border Grid.Row="0" Background="#FFF8F8F8" BorderBrush="#FFE0E0E0" BorderThickness="0,0,0,1">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <ComboBox x:Name="CBoxCategory" 
                             Grid.Column="0" 
                             VerticalAlignment="Center" 
                             Margin="8,4,4,4"
                             MinWidth="100"
                             SelectionChanged="CBoxCategory_SelectionChanged"/>

                    <ComboBox x:Name="CBoxSubject" 
                             Grid.Column="1" 
                             VerticalAlignment="Center" 
                             Margin="4,4,4,4"
                             MinWidth="100"
                             SelectionChanged="CBoxSubject_SelectionChanged"/>

                    <TextBlock x:Name="TBHeader" 
                              Grid.Column="2" 
                              VerticalAlignment="Center" 
                              Margin="16,0,0,0" 
                              FontWeight="Bold" 
                              FontSize="14"/>

                    <TextBlock x:Name="TBCount" 
                              Grid.Column="4" 
                              VerticalAlignment="Center" 
                              HorizontalAlignment="Right" 
                              Margin="0,0,8,0"
                              FontSize="12"
                              Foreground="#FF666666"/>
                </Grid>
            </Border>

            <!-- Post 내용 영역 -->
            <Grid x:Name="GridPost" Grid.Row="1"/>

            <!-- ItemsRepeater 목록 -->
            <Border Grid.Row="2" 
                    BorderBrush="#FFE0E0E0" 
                    BorderThickness="1,0,1,0" 
                    Margin="0,0,0,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- 헤더 -->
                    <Grid Grid.Row="0" 
                          Background="#FFF0F0F0" 
                          BorderBrush="#FFE0E0E0" 
                          BorderThickness="0,0,0,1"
                          Height="40">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="80"/>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="*" MinWidth="200"/>
                            <ColumnDefinition Width="140"/>
                            <ColumnDefinition Width="80"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0" Text="번호" Style="{StaticResource HeaderTextBlockStyle}" HorizontalAlignment="Center"/>
                        <TextBlock Grid.Column="1" Text="분류" Style="{StaticResource HeaderTextBlockStyle}"/>
                        <TextBlock Grid.Column="2" Text="주제" Style="{StaticResource HeaderTextBlockStyle}"/>
                        <TextBlock Grid.Column="3" Text="제목" Style="{StaticResource HeaderTextBlockStyle}"/>
                        <TextBlock Grid.Column="4" Text="등록일자" Style="{StaticResource HeaderTextBlockStyle}" HorizontalAlignment="Center"/>
                        <TextBlock Grid.Column="5" Text="조회" Style="{StaticResource HeaderTextBlockStyle}" HorizontalAlignment="Center"/>
                    </Grid>

                    <!-- 로딩 + 빈 목록 + ItemsRepeater 레이어 -->
                    <Grid Grid.Row="1">
                        <!-- 로딩 표시 (수동 제어) -->
                        <ProgressRing x:Name="LoadingRing"
                                     Width="60"
                                     Height="60"
                                     HorizontalAlignment="Center"
                                     VerticalAlignment="Center"
                                     Visibility="Collapsed"/>

                        <!-- 빈 목록 메시지 (수동 제어) -->
                        <TextBlock x:Name="EmptyMessage"
                                  Text="표시할 게시물이 없습니다."
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Center"
                                  FontSize="14"
                                  Foreground="#FF999999"
                                  Visibility="Collapsed"/>

                        <!-- ItemsRepeater (수동 제어) -->
                        <ScrollViewer x:Name="ScrollViewerPosts" 
                                     VerticalScrollBarVisibility="Auto" 
                                     Padding="0"
                                     Visibility="Visible">
                            <ItemsRepeater x:Name="PostsRepeater">
                                <ItemsRepeater.ItemTemplate>
                                    <DataTemplate x:DataType="local:Post">
                                        <Button Click="PostItem_Click"
                                               HorizontalAlignment="Stretch"
                                               HorizontalContentAlignment="Stretch"
                                               Padding="0"
                                               Background="Transparent"
                                               BorderThickness="0,0,0,1"
                                               BorderBrush="#FFF0F0F0"
                                               CornerRadius="0"
                                               MinHeight="40"
                                               Tag="{x:Bind}">
                                            <Button.Resources>
                                                <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="#FFF3F9FF"/>
                                                <SolidColorBrush x:Key="ButtonBackgroundPressed" Color="#FFD9ECFF"/>
                                                <SolidColorBrush x:Key="ButtonBorderBrushPointerOver" Color="Transparent"/>
                                                <SolidColorBrush x:Key="ButtonBorderBrushPressed" Color="Transparent"/>
                                            </Button.Resources>

                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="80"/>
                                                    <ColumnDefinition Width="120"/>
                                                    <ColumnDefinition Width="120"/>
                                                    <ColumnDefinition Width="*" MinWidth="200"/>
                                                    <ColumnDefinition Width="140"/>
                                                    <ColumnDefinition Width="80"/>
                                                </Grid.ColumnDefinitions>

                                                <TextBlock Grid.Column="0" 
                                                          Text="{x:Bind No}" 
                                                          Style="{StaticResource ItemTextBlockStyle}"
                                                          HorizontalAlignment="Center"
                                                          FontSize="12"/>

                                                <TextBlock Grid.Column="1" 
                                                          Text="{x:Bind Category}" 
                                                          Style="{StaticResource ItemTextBlockStyle}"
                                                          FontSize="12"
                                                          MaxLines="1"/>

                                                <TextBlock Grid.Column="2" 
                                                          Text="{x:Bind Subject}" 
                                                          Style="{StaticResource ItemTextBlockStyle}"
                                                          FontSize="12"
                                                          MaxLines="1"/>

                                                <StackPanel Grid.Column="3" 
                                                           Orientation="Horizontal"
                                                           VerticalAlignment="Center"
                                                           Padding="8,8">
                                                    <TextBlock Text="{x:Bind Title}" 
                                                              TextTrimming="CharacterEllipsis"
                                                              FontSize="13"
                                                              MaxLines="1"/>
                                                    <FontIcon Glyph="&#xE723;" 
                                                             FontSize="10" 
                                                             Margin="4,0,0,0"
                                                             Visibility="{x:Bind FileIconVisibility}"/>
                                                    <FontIcon Glyph="&#xE8F2;" 
                                                             FontSize="10" 
                                                             Margin="4,0,0,0"
                                                             Visibility="{x:Bind CommentIconVisibility}"/>
                                                </StackPanel>

                                                <TextBlock Grid.Column="4" 
                                                          Text="{x:Bind DateTime, Converter={StaticResource DateToShortString}}" 
                                                          Style="{StaticResource ItemTextBlockStyle}"
                                                          HorizontalAlignment="Center"
                                                          FontSize="12"
                                                          Foreground="#FF666666"/>

                                                <TextBlock Grid.Column="5" 
                                                          Text="{x:Bind ReadCount}" 
                                                          Style="{StaticResource ItemTextBlockStyle}"
                                                          HorizontalAlignment="Center"
                                                          FontSize="12"
                                                          Foreground="#FF666666"/>
                                            </Grid>
                                        </Button>
                                    </DataTemplate>
                                </ItemsRepeater.ItemTemplate>

                                <ItemsRepeater.Layout>
                                    <StackLayout Orientation="Vertical" Spacing="0"/>
                                </ItemsRepeater.Layout>
                            </ItemsRepeater>
                        </ScrollViewer>
                    </Grid>
                </Grid>
            </Border>

            <!-- 페이징 -->
            <Border Grid.Row="3" Background="#FFF8F8F8" BorderBrush="#FFE0E0E0" BorderThickness="0,1,0,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Button x:Name="BtnPageStart" 
                           Grid.Column="1" 
                           VerticalAlignment="Center" 
                           Margin="4,0,4,0" 
                           Click="BtnPageStart_Click" 
                           Background="Transparent"
                           BorderBrush="Transparent"
                           Padding="8,4">
                        <StackPanel Orientation="Horizontal">
                            <FontIcon Glyph="&#xE892;" FontSize="12" Margin="0,0,4,0"/>
                            <TextBlock Text="처음"/>
                        </StackPanel>
                    </Button>

                    <Button x:Name="BtnPagePrevios" 
                           Grid.Column="2" 
                           VerticalAlignment="Center" 
                           Margin="4,0,4,0" 
                           Click="BtnPagePrevios_Click" 
                           Background="Transparent"
                           BorderBrush="Transparent"
                           Padding="8,4">
                        <StackPanel Orientation="Horizontal">
                            <FontIcon Glyph="&#xE76B;" FontSize="12" Margin="0,0,4,0"/>
                            <TextBlock Text="이전"/>
                        </StackPanel>
                    </Button>

                    <Button x:Name="BtnPageNext" 
                           Grid.Column="3" 
                           VerticalAlignment="Center" 
                           Margin="4,0,4,0" 
                           Click="BtnPageNext_Click" 
                           Background="Transparent"
                           BorderBrush="Transparent"
                           Padding="8,4">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="다음"/>
                            <FontIcon Glyph="&#xE76C;" FontSize="12" Margin="4,0,0,0"/>
                        </StackPanel>
                    </Button>

                    <Button x:Name="BtnPageEnd" 
                           Grid.Column="4" 
                           VerticalAlignment="Center" 
                           Margin="4,0,4,0" 
                           Click="BtnPageEnd_Click" 
                           Background="Transparent"
                           BorderBrush="Transparent"
                           Padding="8,4">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="마지막"/>
                            <FontIcon Glyph="&#xE893;" FontSize="12" Margin="4,0,0,0"/>
                        </StackPanel>
                    </Button>

                    <Button x:Name="BtnAddPost" 
                           Content="새글쓰기" 
                           Grid.Column="6" 
                           VerticalAlignment="Center" 
                           Click="BtnAddPost_Click" 
                           Margin="8,4,8,4"
                           Style="{StaticResource AccentButtonStyle}"/>
                </Grid>
            </Border>

            <!-- 검색 -->
            <Border Grid.Row="4" Background="#FFF8F8F8" Padding="0,8,0,8">
                <Grid HorizontalAlignment="Center">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <ComboBox x:Name="CBoxSearch" 
                             Grid.Column="0" 
                             VerticalAlignment="Center" 
                             Margin="4,0,4,0" 
                             SelectedIndex="0" 
                             MinWidth="120" 
                             SelectionChanged="CBoxSearch_SelectionChanged">
                        <ComboBoxItem Content="제목"/>
                        <ComboBoxItem Content="내용"/>
                        <ComboBoxItem Content="제목+내용"/>
                    </ComboBox>

                    <TextBox x:Name="TBoxSearch" 
                            Grid.Column="1" 
                            Width="240" 
                            VerticalAlignment="Center" 
                            Margin="4,0,4,0"
                            PlaceholderText="검색어를 입력하세요"/>

                    <Button x:Name="BtnSearch" 
                           Content="검색" 
                           Grid.Column="2" 
                           Margin="4,0,4,0"
                           Click="BtnSearch_Click"
                           MinWidth="80"/>
                </Grid>
            </Border>
        </Grid>
    </ScrollViewer>
</Page>

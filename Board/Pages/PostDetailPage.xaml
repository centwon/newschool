<Page
    x:Class="NewSchool.Board.Pages.PostDetailPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:NewSchool.Board.Pages"
    xmlns:controls="using:NewSchool.Board.Controls"
    xmlns:board="using:NewSchool.Board"
    xmlns:appcontrols="using:NewSchool.Controls"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Grid Padding="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <!-- 헤더 -->
        <Grid Grid.Row="0" Margin="0,0,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- 뒤로가기 버튼 추가 -->
            <!-- 아이콘 버튼 버전 -->
            <Button Grid.Column="0" Click="BackButton_Click" Margin="0,0,20,0" ToolTipService.ToolTip="목록으로 돌아가기">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <FontIcon Glyph="&#xE72B;" FontSize="16"/>
                    <TextBlock Text="목록으로" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>

            <TextBlock Grid.Column="1" Text="게시글 상세" Style="{StaticResource TitleTextBlockStyle}" VerticalAlignment="Center"/>

            <Button Grid.Column="2" Content="수정" Click="EditButton_Click" Margin="0,0,10,0"/>

            <Button Grid.Column="3" Content="삭제" Click="DeleteButton_Click" Style="{StaticResource AccentButtonStyle}"/>
        </Grid>
        <!-- 본문 -->
        <ScrollViewer Grid.Row="1" Grid.ColumnSpan="2">
            <StackPanel Spacing="20">
                <!-- Post 정보 -->
                <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="20">
                    <StackPanel Spacing="12">
                        <!-- 제목 -->
                        <TextBlock Text="{x:Bind ViewModel.Post.Title, Mode=OneWay}"
                                   Style="{StaticResource SubtitleTextBlockStyle}"
                                   FontWeight="Bold"
                                   TextWrapping="Wrap"/>

                        <!-- 메타 정보 -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0" Text="{x:Bind ViewModel.Post.User, Mode=OneWay}" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>

                            <TextBlock Grid.Column="1" Text=" | " Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>

                            <TextBlock Grid.Column="2" Text="{x:Bind ViewModel.Post.DateTime, Mode=OneWay}" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>

                            <StackPanel Grid.Column="3" Orientation="Horizontal" Spacing="8">
                                <TextBlock Text="조회" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                <TextBlock Text="{x:Bind ViewModel.Post.ReadCount, Mode=OneWay}" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            </StackPanel>
                        </Grid>

                        <Border Height="1"                                 Background="{ThemeResource DividerStrokeColorDefaultBrush}"/>

                        <!-- 내용 (Jodit HTML 뷰어) -->
                        <appcontrols:JoditEditor x:Name="ContentViewer"
                                                 Mode="ReadOnly"
                                                 MinHeight="200"/>

                        <!-- 첨부파일  -->
                        <StackPanel Spacing="12">
                            <controls:PostFileListBox x:Name="DetailFileListBox"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- 댓글 섹션 -->
                <StackPanel Spacing="12">
                    <TextBlock Text="댓글"
                               Style="{StaticResource SubtitleTextBlockStyle}"/>

                    <!-- 댓글 작성 -->
                    <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
        BorderThickness="1"
        CornerRadius="8"
        Padding="16">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <!-- 댓글 내용 -->
                            <TextBox Grid.Row="0"
                 x:Name="NewCommentTextBox"
                 PlaceholderText="댓글을 입력하세요"
                 AcceptsReturn="True"
                 TextWrapping="Wrap"
                 MinHeight="80"
                 Text="{x:Bind ViewModel.NewCommentContent, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

                            <!-- 파일 첨부 영역 -->
                            <StackPanel Grid.Row="1" 
                    Margin="0,8,0,0"
                    Spacing="8">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <Button x:Name="CommentAttachFileButton"
                        Click="CommentAttachFileButton_Click"
                        Padding="8,4">
                                        <Button.Content>
                                            <StackPanel Orientation="Horizontal" Spacing="4">
                                                <FontIcon Glyph="&#xE723;" FontSize="14"/>
                                                <TextBlock Text="파일 첨부"/>
                                            </StackPanel>
                                        </Button.Content>
                                    </Button>

                                    <Button x:Name="CommentRemoveFileButton"
                        Click="CommentRemoveFileButton_Click"
                        Padding="8,4"
                        Visibility="Collapsed">
                                        <Button.Content>
                                            <StackPanel Orientation="Horizontal" Spacing="4">
                                                <FontIcon Glyph="&#xE738;" FontSize="14"/>
                                                <TextBlock Text="파일 제거"/>
                                            </StackPanel>
                                        </Button.Content>
                                    </Button>
                                </StackPanel>

                                <!-- 선택된 파일 정보 -->
                                <Border x:Name="CommentFileInfoBorder"
                    Background="{ThemeResource SubtleFillColorSecondaryBrush}"
                    Padding="8"
                    CornerRadius="4"
                    Visibility="Collapsed">
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <FontIcon Glyph="&#xE8E5;" FontSize="14"/>
                                        <TextBlock x:Name="CommentFileNameTextBlock" 
                               VerticalAlignment="Center"/>
                                        <TextBlock x:Name="CommentFileSizeTextBlock" 
                               VerticalAlignment="Center"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                    </StackPanel>
                                </Border>
                            </StackPanel>

                            <!-- 버튼 -->
                            <Button Grid.Row="2"
                Content="댓글 작성"
                HorizontalAlignment="Right"
                Margin="0,8,0,0"
                Click="AddCommentButton_Click"
                Style="{StaticResource AccentButtonStyle}"/>
                        </Grid>
                    </Border>
                    <!-- 댓글 목록 -->
                    <!-- 댓글 목록 -->
                    <ItemsControl ItemsSource="{x:Bind ViewModel.Comments, Mode=OneWay}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="board:Comment">
                                <Border Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="16"
                    Margin="0,0,0,8">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>

                                        <!-- 댓글 헤더 -->
                                        <Grid Grid.Row="0" Margin="0,0,0,8">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <TextBlock Grid.Column="0"
                                   Text="{x:Bind User}"
                                   FontWeight="SemiBold"
                                   Margin="0,0,8,0"/>

                                            <TextBlock Grid.Column="1"
                                   Text="|"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                   Margin="0,0,8,0"/>

                                            <TextBlock Grid.Column="2"
                                   Text="{x:Bind DateTime}"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>

                                            <Button Grid.Column="3"
                                Content="삭제"
                                Click="DeleteCommentButton_Click"
                                Tag="{x:Bind}"
                                Padding="8,4"/>
                                        </Grid>

                                        <!-- 댓글 내용 -->
                                        <TextBlock Grid.Row="1"
                               Text="{x:Bind Content}"
                               TextWrapping="Wrap"/>

                                        <!-- 첨부파일 -->
                                        <Border Grid.Row="2"
                            Visibility="{x:Bind FileIconVisibility}"
                            Background="{ThemeResource SubtleFillColorSecondaryBrush}"
                            Padding="8"
                            Margin="0,8,0,0"
                            CornerRadius="4">
                                            <Button Background="Transparent"
                                BorderThickness="0"
                                Click="CommentFileButton_Click"
                                Tag="{x:Bind}"
                                Padding="4"
                                HorizontalAlignment="Left">
                                                <StackPanel Orientation="Horizontal" Spacing="8">
                                                    <FontIcon Glyph="&#xE8E5;" FontSize="14"/>
                                                    <TextBlock Text="{x:Bind FileName}"
                                           VerticalAlignment="Center"/>
                                                </StackPanel>
                                            </Button>
                                        </Border>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>

<Page
    x:Class="NewSchool.Board.Pages.PostDetailPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:NewSchool.Board.Pages"
    xmlns:controls="using:NewSchool.Board.Controls"
    xmlns:board="using:NewSchool.Board"
    xmlns:appcontrols="using:NewSchool.Controls"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Grid Padding="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <!-- 헤더 -->
        <Grid Grid.Row="0" Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- 뒤로가기 버튼 추가 -->
            <Button Grid.Column="0" Click="BackButton_Click" Margin="0,0,8,0" Padding="8,4" ToolTipService.ToolTip="목록으로 돌아가기">
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <FontIcon Glyph="&#xE72B;" FontSize="14"/>
                    <TextBlock Text="목록으로" VerticalAlignment="Center" FontSize="13"/>
                </StackPanel>
            </Button>

            <TextBlock Grid.Column="1" Text="게시글 보기" Style="{StaticResource BodyStrongTextBlockStyle}" VerticalAlignment="Center"/>

            <Button Grid.Column="2" Click="PrintButton_Click" Margin="0,0,8,0" Padding="8,4" ToolTipService.ToolTip="인쇄">
                <StackPanel Orientation="Horizontal" Spacing="4">
                    <FontIcon Glyph="&#xE749;" FontSize="13"/>
                    <TextBlock Text="인쇄" FontSize="13"/>
                </StackPanel>
            </Button>

            <Button Grid.Column="3" Content="수정" Click="EditButton_Click" Margin="0,0,8,0" Padding="8,4"/>

            <Button Grid.Column="4" Content="삭제" Click="DeleteButton_Click" Style="{StaticResource AccentButtonStyle}" Padding="8,4"/>
        </Grid>
        <!-- Post 정보 상단 -->
        <Border Grid.Row="1"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1,1,1,0"
                CornerRadius="8,8,0,0"
                Padding="12,10,12,8">
            <StackPanel Spacing="8">
                <!-- 카테고리/주제 + 제목 + 날짜/조회/확인 (한 줄) -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Background="{ThemeResource AccentFillColorDefaultBrush}" CornerRadius="4" Padding="6,2" Margin="0,0,6,0" VerticalAlignment="Center">
                        <TextBlock Text="{x:Bind ViewModel.Post.Category, Mode=OneWay}" Foreground="White" FontSize="11"/>
                    </Border>
                    <Border Grid.Column="1" Background="{ThemeResource SubtleFillColorSecondaryBrush}" CornerRadius="4" Padding="6,2" Margin="0,0,6,0" VerticalAlignment="Center"
                            Visibility="{x:Bind ViewModel.SubjectVisibility, Mode=OneWay}">
                        <TextBlock Text="{x:Bind ViewModel.Post.Subject, Mode=OneWay}" FontSize="11" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    </Border>
                    <TextBlock Grid.Column="2"
                               Text="{x:Bind ViewModel.Post.Title, Mode=OneWay}"
                               FontSize="15"
                               FontWeight="SemiBold"
                               TextTrimming="CharacterEllipsis"
                               VerticalAlignment="Center"/>

                    <StackPanel Grid.Column="3" Orientation="Horizontal" Spacing="12" VerticalAlignment="Center" Margin="12,0,0,0">
                        <CheckBox Content="확인"
                                  Padding="6,2"
                                  MinHeight="0"
                                  Visibility="{x:Bind ViewModel.IsMemoVisibility, Mode=OneWay}"
                                  IsChecked="{x:Bind ViewModel.IsCompleted, Mode=TwoWay}"/>
                        <TextBlock Text="{x:Bind ViewModel.Post.DateTime, Mode=OneWay}" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" VerticalAlignment="Center"/>
                        <StackPanel Orientation="Horizontal" Spacing="4">
                            <TextBlock Text="조회" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" VerticalAlignment="Center"/>
                            <TextBlock Text="{x:Bind ViewModel.Post.ReadCount, Mode=OneWay}" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" VerticalAlignment="Center"/>
                        </StackPanel>
                    </StackPanel>
                </Grid>

                <Border Height="1" Background="{ThemeResource DividerStrokeColorDefaultBrush}"/>
            </StackPanel>
        </Border>

        <!-- 내용 (Jodit HTML 뷰어) - 남은 공간을 채우며 내부 스크롤 -->
        <Border Grid.Row="2"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1,0,1,1"
                CornerRadius="0,0,8,8"
                Padding="12,0,12,8">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <appcontrols:RichTextEditor x:Name="ContentViewer"
                                         Grid.Row="0"
                                         Mode="ReadOnly"/>

                <!-- 첨부파일 (파일이 있을 때만 표시) -->
                <controls:PostFileListBox x:Name="DetailFileListBox"
                                          Grid.Row="1"
                                          Margin="0,8,0,0"
                                          Visibility="Collapsed"/>
            </Grid>
        </Border>

        <!-- 댓글 섹션 -->
        <ScrollViewer Grid.Row="3" MaxHeight="260" Margin="0,10,0,0"
                      VerticalScrollBarVisibility="Auto"
                      VerticalScrollMode="Enabled"
                      HorizontalScrollMode="Disabled">
            <StackPanel Spacing="8">
                <!-- 댓글 섹션 -->
                <StackPanel Spacing="8">
                    <TextBlock Text="댓글"
                               Style="{StaticResource BodyStrongTextBlockStyle}"/>

                    <!-- 댓글 작성 -->
                    <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
        BorderThickness="1"
        CornerRadius="8"
        Padding="12">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <!-- 답글 대상 안내 -->
                            <Border x:Name="ReplyingToBorder"
                                    Grid.Row="0"
                                    Background="{ThemeResource SubtleFillColorSecondaryBrush}"
                                    Padding="8"
                                    CornerRadius="4"
                                    Margin="0,0,0,8"
                                    Visibility="{x:Bind ViewModel.IsReplying, Mode=OneWay}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0"
                                               Text="{x:Bind ViewModel.ReplyTargetComment.User, Mode=OneWay}"
                                               VerticalAlignment="Center"/>
                                    <Button Grid.Column="1"
                                            Content="답글 취소"
                                            Click="CancelReplyButton_Click"
                                            Padding="8,4"/>
                                </Grid>
                            </Border>

                            <!-- 댓글 내용 -->
                            <TextBox Grid.Row="1"
                 x:Name="NewCommentTextBox"
                 PlaceholderText="댓글을 입력하세요"
                 AcceptsReturn="True"
                 TextWrapping="Wrap"
                 MinHeight="80"
                 Text="{x:Bind ViewModel.NewCommentContent, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

                            <!-- 파일 첨부 영역 -->
                            <StackPanel Grid.Row="2"
                    Margin="0,8,0,0"
                    Spacing="8">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <Button x:Name="CommentAttachFileButton"
                        Click="CommentAttachFileButton_Click"
                        Padding="8,4">
                                        <Button.Content>
                                            <StackPanel Orientation="Horizontal" Spacing="4">
                                                <FontIcon Glyph="&#xE723;" FontSize="14"/>
                                                <TextBlock Text="파일 첨부"/>
                                            </StackPanel>
                                        </Button.Content>
                                    </Button>

                                    <Button x:Name="CommentRemoveFileButton"
                        Click="CommentRemoveFileButton_Click"
                        Padding="8,4"
                        Visibility="Collapsed">
                                        <Button.Content>
                                            <StackPanel Orientation="Horizontal" Spacing="4">
                                                <FontIcon Glyph="&#xE738;" FontSize="14"/>
                                                <TextBlock Text="파일 제거"/>
                                            </StackPanel>
                                        </Button.Content>
                                    </Button>
                                </StackPanel>

                                <!-- 선택된 파일 정보 -->
                                <Border x:Name="CommentFileInfoBorder"
                    Background="{ThemeResource SubtleFillColorSecondaryBrush}"
                    Padding="8"
                    CornerRadius="4"
                    Visibility="Collapsed">
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <FontIcon Glyph="&#xE8E5;" FontSize="14"/>
                                        <TextBlock x:Name="CommentFileNameTextBlock" 
                               VerticalAlignment="Center"/>
                                        <TextBlock x:Name="CommentFileSizeTextBlock" 
                               VerticalAlignment="Center"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                    </StackPanel>
                                </Border>
                            </StackPanel>

                            <!-- 버튼 -->
                            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8" Margin="0,8,0,0">
                                <Button x:Name="CancelEditButton"
                                        Content="취소"
                                        Click="CancelEditButton_Click"
                                        Visibility="Collapsed"/>
                                <Button x:Name="AddCommentButton"
                                        Content="댓글 작성"
                                        Click="AddCommentButton_Click"
                                        Style="{StaticResource AccentButtonStyle}"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                    <!-- 댓글 목록 -->
                    <!-- 댓글 목록 -->
                    <ItemsControl ItemsSource="{x:Bind ViewModel.Comments, Mode=OneWay}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="board:Comment">
                                <Border Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="16"
                    Margin="{x:Bind IndentMargin}">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>

                                        <!-- 댓글 헤더 -->
                                        <Grid Grid.Row="0" Margin="0,0,0,8">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <TextBlock Grid.Column="0"
                                   Text="{x:Bind User}"
                                   FontWeight="SemiBold"
                                   Margin="0,0,8,0"/>

                                            <TextBlock Grid.Column="1"
                                   Text="|"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                   Margin="0,0,8,0"/>

                                            <TextBlock Grid.Column="2"
                                   Text="{x:Bind DateTime}"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>

                                            <StackPanel Grid.Column="3" Orientation="Horizontal" Spacing="4">
                                                <Button Content="답글"
                                                        Click="ReplyCommentButton_Click"
                                                        Tag="{x:Bind}"
                                                        Visibility="{x:Bind NotReply}"
                                                        Padding="8,4"/>
                                                <Button Content="수정"
                                                        Click="EditCommentButton_Click"
                                                        Tag="{x:Bind}"
                                                        Padding="8,4"/>
                                                <Button Content="삭제"
                                                        Click="DeleteCommentButton_Click"
                                                        Tag="{x:Bind}"
                                                        Padding="8,4"/>
                                            </StackPanel>
                                        </Grid>

                                        <!-- 댓글 내용 -->
                                        <TextBlock Grid.Row="1"
                               Text="{x:Bind Content}"
                               TextWrapping="Wrap"/>

                                        <!-- 첨부파일 -->
                                        <Border Grid.Row="2"
                            Visibility="{x:Bind FileIconVisibility}"
                            Background="{ThemeResource SubtleFillColorSecondaryBrush}"
                            Padding="8"
                            Margin="0,8,0,0"
                            CornerRadius="4">
                                            <Button Background="Transparent"
                                BorderThickness="0"
                                Click="CommentFileButton_Click"
                                Tag="{x:Bind}"
                                Padding="4"
                                HorizontalAlignment="Left">
                                                <StackPanel Orientation="Horizontal" Spacing="8">
                                                    <FontIcon Glyph="&#xE8E5;" FontSize="14"/>
                                                    <TextBlock Text="{x:Bind FileName}"
                                           VerticalAlignment="Center"/>
                                                </StackPanel>
                                            </Button>
                                        </Border>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>

    </Grid>
</Page>

<UserControl
    x:Class="NewSchool.Board.CommentBox"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:NewSchool.Board"
    xmlns:newschool="using:NewSchool"
    Background="White">

    <UserControl.Resources>
        <newschool:DateStringConverter x:Key="DateStringConverter"/>
    </UserControl.Resources>

    <Border BorderBrush="Bisque" BorderThickness="0,0,0,1">
        <Grid Margin="2,2,2,4">
            <Grid.RowDefinitions>
                <RowDefinition Height="24" />
                <RowDefinition Height="*" />
                <RowDefinition Height="24" />
            </Grid.RowDefinitions>

            <TextBox x:Name="TBoxContent" 
                     Grid.Row="1" 
                     AcceptsReturn="True" 
                     TextWrapping="Wrap"
                     ScrollViewer.VerticalScrollBarVisibility="Auto" 
                     Margin="30,0,2,0" 
                     Text="{x:Bind Comment.Content, Mode=TwoWay}"/>

            <Grid Grid.Row="0" VerticalAlignment="Center">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="30"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <FontIcon Grid.Column="0" 
                         Glyph="&#xEBDB;" 
                         FontWeight="Bold" 
                         Margin="10,2,2,2" 
                         FontSize="14"/>

                <TextBlock x:Name="LBUser" 
                          Grid.Column="1" 
                          VerticalAlignment="Center" 
                          Margin="2,0,2,0"/>

                <TextBlock x:Name="LBDate" 
                          Grid.Column="2" 
                          VerticalAlignment="Center" 
                          Margin="2,0,2,0"
                          Text="{x:Bind Comment.DateTime, Mode=OneWay, Converter={StaticResource DateStringConverter}}"/>

                <Button x:Name="BtnCommentSave" 
                       Grid.Column="4" 
                       Margin="2,1,2,1" 
                       Click="BtnCommentSave_Click" 
                       Padding="2,1,2,1" 
                       Background="Transparent" 
                       BorderBrush="Transparent">
                    <FontIcon Glyph="&#xECC8;" FontSize="14"/>
                </Button>

                <Button x:Name="BtnCommentDelete" 
                       Grid.Column="5" 
                       Margin="2,1,2,1" 
                       Click="BtnCommentDelete_Click" 
                       Padding="2,1,2,1" 
                       Background="Transparent" 
                       BorderBrush="Transparent">
                    <FontIcon Glyph="&#xECC9;" FontSize="14"/>
                </Button>
            </Grid>

            <Grid Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="40"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="1" 
                          Text="• 첨부 파일" 
                          VerticalAlignment="Center"/>

                <Button x:Name="BtnFile" 
                       Grid.Column="2" 
                       VerticalAlignment="Center" 
                       Margin="4,0,0,0" 
                       Padding="2,1,0,1" 
                       Click="BtnFile_Click" 
                       Background="Transparent" 
                       BorderBrush="Transparent">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock x:Name="TBFileName" Text="{x:Bind FileNameText, Mode=OneWay}"/>
                        <TextBlock x:Name="TBFileSize" Text="{x:Bind FileSizeText, Mode=OneWay}" Margin="4,0,0,0"/>
                    </StackPanel>
                </Button>

                <Button x:Name="BtnFileOpenOrDelete" 
                       Grid.Column="3" 
                       Background="Transparent" 
                       BorderThickness="0" 
                       Click="BtnFileOpenOrDelete_Click" 
                       Margin="0,2,2,2" 
                       Padding="2,1,2,1">
                    <FontIcon Glyph="&#xED25;" FontSize="16"/>
                </Button>
            </Grid>
        </Grid>
    </Border>
</UserControl>

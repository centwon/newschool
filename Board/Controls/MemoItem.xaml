<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="NewSchool.Board.Controls.MemoItem"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:board="using:NewSchool.Board"
    mc:Ignorable="d">

    <Expander x:Name="MemoExpander"
              HorizontalAlignment="Stretch"
              HorizontalContentAlignment="Stretch"
              Expanding="MemoExpander_Expanding">
        <!-- 헤더: 항상 표시 -->
        <Expander.Header>
            <Grid HorizontalAlignment="Stretch" Padding="0,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <!-- 체크박스 -->
                    <ColumnDefinition Width="Auto"/>
                    <!-- 카테고리 배지 -->
                    <ColumnDefinition Width="*"/>
                    <!-- 제목 -->
                    <ColumnDefinition Width="Auto"/>
                    <!-- 첨부파일 아이콘 -->
                    <ColumnDefinition Width="Auto"/>
                    <!-- 날짜 -->
                    <ColumnDefinition Width="Auto"/>
                    <!-- 삭제 버튼 -->
                </Grid.ColumnDefinitions>

                <!-- 완료 체크박스 -->
                <CheckBox x:Name="ChkCompleted"
                          Grid.Column="0"
                          VerticalAlignment="Center"
                          Margin="0,0,8,0"
                          Click="ChkCompleted_Click"/>

                <!-- 카테고리 배지 -->
                <Border x:Name="BadgeSubject"
                        Grid.Column="1"
                        Background="{ThemeResource AccentFillColorDefaultBrush}"
                        CornerRadius="4"
                        Padding="6,2"
                        Margin="0,0,8,0"
                        VerticalAlignment="Center">
                    <TextBlock x:Name="TxtSubject"
                               Text="업무"
                               FontSize="11"
                               Foreground="White"/>
                </Border>

                <!-- 제목 -->
                <TextBlock x:Name="TxtTitle"
                           Grid.Column="2"
                           Text="메모 제목"
                           VerticalAlignment="Center"
                           TextTrimming="CharacterEllipsis"
                           FontSize="13"/>

                <!-- 첨부파일 아이콘 -->
                <FontIcon x:Name="IconFile"
                          Grid.Column="3"
                          Glyph="&#xE723;"
                          FontSize="12"
                          Margin="8,0,0,0"
                          Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                          VerticalAlignment="Center"
                          Visibility="Collapsed"/>

                <!-- 날짜 -->
                <TextBlock x:Name="TxtDate"
                           Grid.Column="4"
                           Text="12/5 10:30"
                           FontSize="12"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                           VerticalAlignment="Center"
                           Margin="12,0,0,0"/>

                <!-- 삭제 버튼 -->
                <Button x:Name="BtnDelete"
                        Grid.Column="5"
                        Background="Transparent"
                        BorderThickness="0"
                        Padding="6,4"
                        Margin="8,0,0,0"
                        VerticalAlignment="Center"
                        Click="BtnDelete_Click"
                        ToolTipService.ToolTip="삭제">
                    <FontIcon Glyph="&#xE74D;" FontSize="12"/>
                </Button>
            </Grid>
        </Expander.Header>

        <!-- 내용: 펼쳤을 때만 표시 -->
        <StackPanel Padding="8,8,8,12">
            <!-- 메모 내용 -->
            <TextBox x:Name="TxtContent"
                     AcceptsReturn="True"
                     TextWrapping="Wrap"
                     MinHeight="80"
                     MaxHeight="200"
                     PlaceholderText="메모 내용을 입력하세요..."
                     TextChanged="TxtContent_TextChanged"/>

            <!-- 첨부파일 영역 -->
            <StackPanel x:Name="PanelFiles"
                        Margin="0,12,0,0"
                        Visibility="Collapsed">
                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                    <FontIcon Glyph="&#xE723;" FontSize="14" 
                              Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    <TextBlock x:Name="TxtFileCount"
                               Text="첨부파일 (0)"
                               FontSize="12"
                               FontWeight="SemiBold"
                               Margin="6,0,0,0"
                               VerticalAlignment="Center"/>
                </StackPanel>

                <!-- 파일 목록 -->
                <ItemsControl x:Name="FileList">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal" Spacing="8"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="board:PostFile">
                            <Border Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
                                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                    BorderThickness="1"
                                    CornerRadius="4"
                                    Padding="8,6"
                                    MinWidth="120">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <TextBlock Text="{x:Bind FileName}"
                                               Grid.ColumnSpan="2"
                                               FontSize="12"
                                               TextTrimming="CharacterEllipsis"
                                               MaxWidth="150"/>
                                    <TextBlock Text="{x:Bind FileSizeDisplay}"
                                               Grid.Row="1"
                                               FontSize="10"
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                    <Button Grid.Row="1" Grid.Column="1"
                                            Content="열기"
                                            FontSize="10"
                                            Padding="4,2"
                                            Background="Transparent"
                                            Click="BtnOpenFile_Click"
                                            Tag="{x:Bind}"/>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>

            <!-- 하단 버튼 -->
            <Grid Margin="0,12,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- 파일 추가 버튼 -->
                <Button x:Name="BtnAddFile"
                        Grid.Column="0"
                        Click="BtnAddFile_Click"
                        Background="Transparent"
                        BorderThickness="0"
                        Padding="8,4">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <FontIcon Glyph="&#xE723;" FontSize="14"/>
                        <TextBlock Text="파일 추가" FontSize="12"/>
                    </StackPanel>
                </Button>

                <!-- 저장 버튼 -->
                <Button x:Name="BtnSave"
                        Grid.Column="2"
                        Click="BtnSave_Click"
                        Style="{ThemeResource AccentButtonStyle}"
                        Padding="12,6">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <FontIcon Glyph="&#xE74E;" FontSize="14"/>
                        <TextBlock Text="저장" FontSize="12"/>
                    </StackPanel>
                </Button>
            </Grid>
        </StackPanel>
    </Expander>
</UserControl>

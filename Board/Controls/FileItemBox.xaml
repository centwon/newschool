<UserControl
    x:Class="NewSchool.Board.Controls.FileItemBox"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:board="using:NewSchool.Board"
    Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
    BorderThickness="1"
    CornerRadius="4"
   >

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="26"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- 체크박스 -->
        <CheckBox x:Name="SelectCheckBox"
                  Grid.Column="0"
                  VerticalAlignment="Center"
                  Margin="0,0,0,0"
                  Checked="SelectCheckBox_Checked"
                  Unchecked="SelectCheckBox_Unchecked"/>

        <!-- 파일 정보 버튼 -->
        <Button Grid.Column="1"
                Background="Transparent"
                BorderThickness="0"
                HorizontalAlignment="Stretch"
                HorizontalContentAlignment="Left"
                Click="FileButton_Click"
                Padding="2"
                Margin="0,0,4,0">
            <StackPanel Orientation="Horizontal" Spacing="8">
                <FontIcon Glyph="&#xE8E5;" FontSize="16"/>
                <TextBlock x:Name="FileNameTextBlock" 
                           VerticalAlignment="Center"/>
                <TextBlock x:Name="FileSizeTextBlock" 
                           VerticalAlignment="Center"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
            </StackPanel>
        </Button>
    </Grid>
</UserControl>

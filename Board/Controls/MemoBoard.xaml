<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="NewSchool.Board.Controls.MemoBoard"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:appcontrols="using:NewSchool.Controls"
    xmlns:board="using:NewSchool.Board"
    mc:Ignorable="d">

    <Border BorderBrush="CornflowerBlue"
            BorderThickness="1"
            CornerRadius="5"
            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="36"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- 헤더 -->
            <Border Grid.Row="0" BorderBrush="CornflowerBlue" BorderThickness="0,0,0,1"
                    Background="Lavender" CornerRadius="5,5,0,0">
                <Grid Padding="6,2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock
                        Text="&#x1F4DD; &#xBA54;&#xBAA8;"
                        FontWeight="Bold"
                        VerticalAlignment="Center"
                        FontSize="14"/>

                    <!-- 카테고리 필터 -->
                    <ComboBox x:Name="CBoxCategoryFilter"
                              Grid.Column="1"
                              MinWidth="80"
                              Margin="8,0,0,0"
                              VerticalAlignment="Center"
                              SelectionChanged="CBoxCategoryFilter_SelectionChanged">
                        <ComboBoxItem Content="전체" Tag=""/>
                        <ComboBoxItem Content="수업" Tag="수업"/>
                        <ComboBoxItem Content="담임" Tag="담임"/>
                        <ComboBoxItem Content="업무" Tag="업무"/>
                        <ComboBoxItem Content="개인" Tag="개인"/>
                    </ComboBox>

                    <Button x:Name="BtnAddMemo"
                        Grid.Column="3"
                        Click="BtnAddMemo_Click"
                        Background="Transparent"
                        Padding="6,2"
                        ToolTipService.ToolTip="&#xC0C8; &#xBA54;&#xBAA8; &#xCD94;&#xAC00;">
                        <StackPanel Orientation="Horizontal" Spacing="4">
                            <FontIcon Glyph="&#xE710;" FontSize="12"/>
                            <TextBlock Text="&#xCD94;&#xAC00;" FontSize="12"/>
                        </StackPanel>
                    </Button>
                </Grid>
            </Border>

            <!-- 메모 리스트 (compact + 인라인 확장) -->
            <ScrollViewer VerticalScrollBarVisibility="Auto"
                          Grid.Row="1"
                          Padding="0">
                <StackPanel x:Name="MemoPanel" Spacing="0"/>
            </ScrollViewer>

            <!-- 빈 상태 표시 -->
            <StackPanel x:Name="PanelEmpty"
                        Grid.Row="1"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Visibility="Collapsed">
                <FontIcon Glyph="&#xE70B;"
                          FontSize="32"
                          Foreground="{ThemeResource TextFillColorDisabledBrush}"/>
                <TextBlock Text="&#xBA54;&#xBAA8;&#xAC00; &#xC5C6;&#xC2B5;&#xB2C8;&#xB2E4;"
                           FontSize="13"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                           Margin="0,8,0,0"/>
            </StackPanel>

            <!-- 로딩 표시 -->
            <ProgressRing x:Name="LoadingRing"
                          Grid.Row="1"
                          IsActive="False"
                          Width="32"
                          Height="32"
                          HorizontalAlignment="Center"
                          VerticalAlignment="Center"/>
        </Grid>
    </Border>
</UserControl>

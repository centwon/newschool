<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="NewSchool.Controls.CoursePicker"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:NewSchool.Models"
    mc:Ignorable="d">

    <StackPanel Orientation="Horizontal" Spacing="8">
        <!-- 과목 -->
        <ComboBox
            x:Name="CBoxCourse"
            MinWidth="180"
            PlaceholderText="과목 선택"
            SelectionChanged="CBoxCourse_SelectionChanged">
            <ComboBox.ItemTemplate>
                <DataTemplate x:DataType="models:Course">
                    <TextBlock Text="{x:Bind DisplayName}"/>
                </DataTemplate>
            </ComboBox.ItemTemplate>
        </ComboBox>

        <!-- 강의실 -->
        <ComboBox
            x:Name="CBoxRoom"
            MinWidth="110"
            PlaceholderText="강의실"
            SelectionChanged="CBoxRoom_SelectionChanged"/>
    </StackPanel>
</UserControl>

<UserControl
    x:Class="NewSchool.Controls.LogListViewer"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="using:NewSchool.ViewModels"
    mc:Ignorable="d">

    <Border
        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
        BorderThickness="1"
        CornerRadius="8">

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <!-- 헤더 -->
                <RowDefinition Height="*"/>
                <!-- 로그 목록 -->
            </Grid.RowDefinitions>

            <!-- 헤더 -->
            <Grid x:Name="HeaderGrid"
                  Grid.Row="0"
                  Padding="8,10"
                  Background="{ThemeResource LayerFillColorDefaultBrush}"
                  BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                  BorderThickness="0,0,0,1">
                
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="24"/>
                    <!-- 체크박스 + 카테고리 라벨 -->
                    <ColumnDefinition x:Name="ColYearHeader" Width="60"/>
                    <!-- 학년도 -->
                    <ColumnDefinition x:Name="ColSemesterHeader" Width="40"/>
                    <!-- 학기 -->
                    <ColumnDefinition x:Name="ColCategoryHeader" Width="100"/>
                    <!-- 카테고리 -->
                    <ColumnDefinition x:Name="ColSubjectHeader" Width="100"/>
                    <!-- 과목 -->
                    <ColumnDefinition x:Name="ColGradeHeader" Width="40"/>
                    <!-- 학년 -->
                    <ColumnDefinition x:Name="ColClassHeader" Width="40"/>
                    <!-- 반 -->
                    <ColumnDefinition x:Name="ColNumberHeader" Width="40"/>
                    <!-- 번호 -->
                    <ColumnDefinition x:Name="ColNameHeader" Width="60"/>
                    <!-- 이름 -->
                    <ColumnDefinition Width="90"/>
                    <!-- 일시 -->
                    <ColumnDefinition Width="150"/>
                    <!-- 주제 -->
                    <ColumnDefinition Width="*" MinWidth="200"/>
                    <!-- 기록 내용 -->
                </Grid.ColumnDefinitions>

                <CheckBox x:Name="ChkSelectAll"
                          Grid.Column="0"
                          HorizontalAlignment="Left"
                          VerticalAlignment="Center"
                          Margin="4,0,0,0"
                          Checked="OnSelectAllChecked"
                          Unchecked="OnSelectAllUnchecked"/>

                <TextBlock Grid.Column="1" x:Name="TxtYearHeader" Text="학년도" FontWeight="SemiBold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                <TextBlock Grid.Column="2" x:Name="TxtSemesterHeader" Text="학기" FontWeight="SemiBold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                <TextBlock Grid.Column="3" x:Name="TxtCategoryHeader" Text="영역" FontWeight="SemiBold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                <TextBlock Grid.Column="4" x:Name="TxtSubjectHeader" Text="과목" FontWeight="SemiBold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                <TextBlock Grid.Column="5" x:Name="TxtGradeHeader" Text="학년" FontWeight="SemiBold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                <TextBlock Grid.Column="6" x:Name="TxtClassHeader" Text="반" FontWeight="SemiBold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                <TextBlock Grid.Column="7" x:Name="TxtNumberHeader" Text="번호" FontWeight="SemiBold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                <TextBlock Grid.Column="8" x:Name="TxtNameHeader" Text="이름" FontWeight="SemiBold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                <TextBlock Grid.Column="9" Text="일시" FontWeight="SemiBold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                <TextBlock Grid.Column="10" Text="주제" FontWeight="SemiBold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                <TextBlock Grid.Column="11" Text="기록 내용" FontWeight="SemiBold" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="12,0,0,0"/>
            </Grid>

            <!-- 로그 목록 -->
            <ScrollViewer Grid.Row="1" 
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                
                <ItemsRepeater x:Name="LogItemsRepeater"
                               Margin="0">
                    
                    <ItemsRepeater.Layout>
                        <StackLayout Spacing="0"/>
                    </ItemsRepeater.Layout>

                    <ItemsRepeater.ItemTemplate>
                        <DataTemplate x:DataType="vm:StudentLogViewModel">
                            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                    BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                                    BorderThickness="0,0,0,1"
                                    Padding="0"
                                    Tag="{x:Bind}"
                                    Tapped="OnRowTapped">

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- 선택 표시 바 -->
                                    <Border x:Name="SelectionIndicator"
                                            Grid.Column="0"
                                            Width="3"
                                            Background="Transparent"
                                            VerticalAlignment="Stretch"/>

                                <Grid Grid.Column="1" x:Name="DataRowGrid" Padding="8,8" Loaded="OnDataRowGridLoaded">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="24"/>
                                        <ColumnDefinition Width="60"/>
                                        <ColumnDefinition Width="40"/>
                                        <ColumnDefinition Width="100"/>
                                        <ColumnDefinition Width="100"/>
                                        <ColumnDefinition Width="40"/>
                                        <ColumnDefinition Width="40"/>
                                        <ColumnDefinition Width="40"/>
                                        <ColumnDefinition Width="60"/>
                                        <ColumnDefinition Width="90"/>
                                        <ColumnDefinition Width="150"/>
                                        <ColumnDefinition Width="*" MinWidth="200"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- 체크박스 -->
                                    <CheckBox Grid.Column="0"
                                              HorizontalAlignment="Left"
                                              VerticalAlignment="Top"
                                              Margin="4,0,0,0"
                                              Padding="0"
                                              IsChecked="{x:Bind IsSelected, Mode=TwoWay}"/>

                                    <!-- 학년도 -->
                                    <TextBlock Grid.Column="1"
                                               Text="{x:Bind Year}"
                                               Visibility="{Binding ElementName=TxtYearHeader, Path=Visibility}"
                                               VerticalAlignment="Top"
                                               HorizontalAlignment="Center"
                                               FontSize="12"
                                               Margin="0,4,0,0"/>

                                    <!-- 학기 -->
                                    <TextBlock Grid.Column="2"
                                               Text="{x:Bind Semester}"
                                               Visibility="{Binding ElementName=TxtSemesterHeader, Path=Visibility}"
                                               VerticalAlignment="Top"
                                               HorizontalAlignment="Center"
                                               FontSize="12"
                                               Margin="0,4,0,0"/>

                                    <!-- 영역 (라벨만 표시) -->
                                    <Border Grid.Column="3"
                                            x:Name="CategoryLabelBorder"
                                            Background="{x:Bind CategoryColor}"
                                            CornerRadius="3"
                                            Padding="4,2"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Top"
                                            Margin="0,2,0,0"
                                            Visibility="{Binding ElementName=TxtCategoryHeader, Path=Visibility}">
                                        <TextBlock Text="{x:Bind CategoryLabel}"
                                                   FontSize="9"
                                                   FontWeight="SemiBold"
                                                   Foreground="White"/>
                                    </Border>

                                    <!-- 과목 -->
                                    <TextBlock Grid.Column="4"
                                               Text="{x:Bind SubjectName}"
                                               Visibility="{Binding ElementName=TxtSubjectHeader, Path=Visibility}"
                                               VerticalAlignment="Top"
                                               HorizontalAlignment="Center"
                                               FontSize="12"
                                               Margin="0,4,0,0"
                                               TextWrapping="NoWrap"
                                               TextTrimming="CharacterEllipsis"/>

                                    <!-- 학년 -->
                                    <TextBlock Grid.Column="5"
                                               Text="{x:Bind Grade}"
                                               Visibility="{Binding ElementName=TxtGradeHeader, Path=Visibility}"
                                               VerticalAlignment="Top"
                                               HorizontalAlignment="Center"
                                               FontSize="12"
                                               Margin="0,4,0,0"/>

                                    <!-- 반 -->
                                    <TextBlock Grid.Column="6"
                                               Text="{x:Bind Class}"
                                               Visibility="{Binding ElementName=TxtClassHeader, Path=Visibility}"
                                               VerticalAlignment="Top"
                                               HorizontalAlignment="Center"
                                               FontSize="12"
                                               Margin="0,4,0,0"/>

                                    <!-- 번호 -->
                                    <TextBlock Grid.Column="7"
                                               Text="{x:Bind Number}"
                                               Visibility="{Binding ElementName=TxtNumberHeader, Path=Visibility}"
                                               VerticalAlignment="Top"
                                               HorizontalAlignment="Center"
                                               FontSize="12"
                                               Margin="0,4,0,0"/>

                                    <!-- 이름 -->
                                    <TextBlock Grid.Column="8"
                                               Text="{x:Bind Name}"
                                               Visibility="{Binding ElementName=TxtNameHeader, Path=Visibility}"
                                               VerticalAlignment="Top"
                                               HorizontalAlignment="Center"
                                               FontSize="12"
                                               Margin="0,4,0,0"
                                               FontWeight="SemiBold"/>

                                    <!-- 일시 -->
                                    <TextBlock Grid.Column="9"
                                               Text="{x:Bind DateString}"
                                               VerticalAlignment="Top"
                                               HorizontalAlignment="Center"
                                               FontSize="12"
                                               Margin="0,4,0,0"
                                               TextWrapping="NoWrap"/>

                                    <!-- 주제 -->
                                    <TextBox Grid.Column="10"
                                             Text="{x:Bind Topic, Mode=TwoWay}"
                                             Tag="{x:Bind}"
                                             VerticalAlignment="Top"
                                             FontSize="12"
                                             PlaceholderText="주제"
                                             Margin="0,0,0,0"
                                             TextChanged="OnTopicChanged"/>

                                    <!-- 기록 내용 -->
                                    <Grid Grid.Column="11">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="*"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>

                                        <TextBox Grid.Row="0"
                                                 Text="{x:Bind Log, Mode=TwoWay}"
                                                 Tag="{x:Bind}"
                                                 AcceptsReturn="True"
                                                 TextWrapping="Wrap"
                                                 MinHeight="60"
                                                 MaxHeight="200"
                                                 FontSize="12"
                                                 PlaceholderText="기록 내용 입력"
                                                 TextChanged="OnLogChanged"
                                                 ScrollViewer.VerticalScrollBarVisibility="Auto"/>

                                        <!--<TextBlock Grid.Row="1"
                                                   Text="{x:Bind LogByteInfo, Mode=OneWay}"
                                                   FontSize="10"
                                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                   HorizontalAlignment="Right"
                                                   Margin="0,4,0,0"/>-->
                                    </Grid>
                                </Grid>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsRepeater.ItemTemplate>
                </ItemsRepeater>
            </ScrollViewer>
        </Grid>
    </Border>
</UserControl>

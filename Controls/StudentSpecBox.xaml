<UserControl
    x:Class="NewSchool.Controls.StudentSpecBox"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Border 
        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
        BorderThickness="1"
        CornerRadius="8">

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <!-- 헤더 -->
                <RowDefinition Height="*"/>
                <!-- 내용 -->
                <RowDefinition Height="Auto"/>
                <!-- 바이트 정보 -->
            </Grid.RowDefinitions>

            <!-- 헤더 영역 -->
            <Grid Grid.Row="0" 
                  Padding="16,12"
                  Background="{ThemeResource LayerFillColorDefaultBrush}"
                  BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                  BorderThickness="0,0,0,1">
                
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- 왼쪽: 정보 표시 -->
                <StackPanel Grid.Column="0" 
                            Orientation="Horizontal" 
                            Spacing="12"
                            VerticalAlignment="Center">
                    
                    <!-- 학년도 -->
                    <TextBlock x:Name="TxtYear" 
                               Text="2024"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center"/>
                    <TextBlock Text="학년도" 
                               VerticalAlignment="Center"/>

                    <!-- 학기 (교과활동인 경우만 표시) -->
                    <TextBlock x:Name="TxtSemester"
                               Text="1"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center"
                               Visibility="Collapsed"/>
                    <TextBlock x:Name="TxtSemesterLabel"
                               Text="학기"
                               VerticalAlignment="Center"
                               Visibility="Collapsed"/>

                    <!-- 유형 -->
                    <TextBlock x:Name="TxtType"
                               Text="건강"
                               FontWeight="SemiBold"
                               Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"
                               VerticalAlignment="Center"/>

                    <!-- 과목명 -->
                    <TextBlock x:Name="TxtSubject"
                               Text=""
                               FontWeight="SemiBold"
                               VerticalAlignment="Center"/>

                    <TextBlock Text="학생부 기록"
                               Margin="12,0,0,0"
                               VerticalAlignment="Center"/>

                    <!-- 학생 정보 -->
                    <TextBlock x:Name="TxtStudent"
                               Text=""
                               FontWeight="SemiBold"
                               Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"
                               VerticalAlignment="Center"
                               Margin="12,0,0,0"/>
                </StackPanel>

                <!-- 오른쪽: 버튼들 -->
                <StackPanel Grid.Column="1" 
                            Orientation="Horizontal" 
                            Spacing="4">
                    
                    <!-- 맞춤법 검사 -->
                    <Button x:Name="BtnSpellCheck"
                            Click="OnSpellCheckClick"
                            ToolTipService.ToolTip="맞춤법 검사"
                            Background="Transparent"
                            BorderThickness="0"
                            Padding="8,4">
                        <FontIcon Glyph="&#xF87C;" FontSize="18"/>
                    </Button>

                    <!-- 저장 -->
                    <Button x:Name="BtnSave"
                            Click="OnSaveClick"
                            ToolTipService.ToolTip="저장"
                            Background="Transparent"
                            BorderThickness="0"
                            Padding="8,4">
                        <FontIcon Glyph="&#xE74E;" FontSize="18"/>
                    </Button>

                    <!-- 삭제 -->
                    <Button x:Name="BtnDelete"
                            Click="OnDeleteClick"
                            ToolTipService.ToolTip="삭제하고 초기화"
                            Background="Transparent"
                            BorderThickness="0"
                            Padding="8,4">
                        <FontIcon Glyph="&#xE74D;" FontSize="18"/>
                    </Button>
                </StackPanel>
            </Grid>

            <!-- 내용 편집 영역 -->
            <TextBox x:Name="TxtContent"
                     Grid.Row="1"
                     AcceptsReturn="True"
                     TextWrapping="Wrap"
                     ScrollViewer.VerticalScrollBarVisibility="Auto"
                     Padding="16"
                     BorderThickness="0"
                     Background="Transparent"
                     TextChanged="OnTextChanged"
                     LostFocus="OnLostFocus"
                     PlaceholderText="특이사항을 입력하세요"/>

            <!-- 바이트 정보 -->
            <Grid Grid.Row="2" 
                  Padding="16,8"
                  Background="{ThemeResource LayerFillColorDefaultBrush}"
                  BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                  BorderThickness="0,1,0,0">
                
                <TextBlock x:Name="TxtByteInfo"
                           Text="0 / 1500 Byte (0자)"
                           FontSize="12"
                           FontWeight="SemiBold"
                           HorizontalAlignment="Right"
                           VerticalAlignment="Center"/>
            </Grid>
        </Grid>
    </Border>
</UserControl>

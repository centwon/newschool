<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="NewSchool.Controls.AttachmentBox"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:NewSchool.Models"
    mc:Ignorable="d">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- 헤더 -->
            <RowDefinition Height="*"/>
            <!-- 파일 목록 -->
        </Grid.RowDefinitions>

        <!-- 헤더: 첨부파일 + 추가/폴더 열기 버튼 -->
        <Grid Grid.Row="0" Padding="8,4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <FontIcon Grid.Column="0" 
                      Glyph="&#xE723;" 
                      FontSize="13"
                      Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                      VerticalAlignment="Center"/>

            <TextBlock Grid.Column="1" 
                       Text="첨부파일" 
                       FontSize="12"
                       FontWeight="SemiBold"
                       Margin="6,0,0,0"
                       VerticalAlignment="Center"/>

            <StackPanel Grid.Column="3" 
                        Orientation="Horizontal" 
                        Spacing="2">
                <Button x:Name="BtnAddFile" 
                        Click="BtnAddFile_Click"
                        ToolTipService.ToolTip="파일 추가"
                        Background="Transparent"
                        BorderThickness="0"
                        Padding="6,4">
                    <FontIcon Glyph="&#xE710;" FontSize="12"/>
                </Button>
                <Button x:Name="BtnOpenFolder" 
                        Click="BtnOpenFolder_Click"
                        ToolTipService.ToolTip="폴더 열기"
                        Background="Transparent"
                        BorderThickness="0"
                        Padding="6,4">
                    <FontIcon Glyph="&#xE838;" FontSize="12"/>
                </Button>
            </StackPanel>
        </Grid>

        <!-- 파일 목록 -->
        <ListView x:Name="LvFiles"
                  Grid.Row="1"
                  SelectionMode="None"
                  IsItemClickEnabled="True"
                  ItemClick="LvFiles_ItemClick">
            <ListView.ItemTemplate>
                <DataTemplate x:DataType="models:Attachment">
                    <Grid Padding="4,3" ColumnSpacing="6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <FontIcon Grid.Column="0"
                                  Glyph="{x:Bind FileIcon}"
                                  FontFamily="Segoe Fluent Icons"
                                  FontSize="14"
                                  VerticalAlignment="Center"
                                  Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>

                        <TextBlock Grid.Column="1"
                                   Text="{x:Bind OriginalFileName}"
                                   FontSize="12"
                                   VerticalAlignment="Center"
                                   TextTrimming="CharacterEllipsis"
                                   MaxLines="1"
                                   ToolTipService.ToolTip="{x:Bind OriginalFileName}"/>

                        <TextBlock Grid.Column="2"
                                   Text="{x:Bind FileSizeDisplay}"
                                   FontSize="11"
                                   VerticalAlignment="Center"
                                   Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                   Margin="4,0"/>

                        <Button Grid.Column="3"
                                Tag="{x:Bind No}"
                                Click="BtnDeleteFile_Click"
                                ToolTipService.ToolTip="삭제"
                                Background="Transparent"
                                BorderThickness="0"
                                Padding="4,2">
                            <FontIcon Glyph="&#xE74D;" FontSize="11"
                                      Foreground="{ThemeResource SystemFillColorCriticalBrush}"/>
                        </Button>
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>

            <ListView.ItemContainerStyle>
                <Style TargetType="ListViewItem">
                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                    <Setter Property="Padding" Value="0"/>
                    <Setter Property="MinHeight" Value="30"/>
                </Style>
            </ListView.ItemContainerStyle>
        </ListView>

        <!-- 빈 상태 -->
        <TextBlock x:Name="TxtEmpty"
                   Grid.Row="1"
                   Text="첨부파일 없음"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"
                   FontSize="12"
                   Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                   Visibility="Collapsed"/>
    </Grid>
</UserControl>

<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="NewSchool.Controls.TimetableControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Border 
            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
            BorderThickness="1"
            CornerRadius="8">

        <Grid x:Name="TimetableGrid">
            <Grid.RowDefinitions>
                <!-- 헤더 행 -->
                <RowDefinition Height="auto"/>
                <!-- 1~7교시 행 -->
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Grid.ColumnDefinitions>
                <!-- 교시 열 -->
                <ColumnDefinition Width="30"/>
                <!-- 월~금 열 -->
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- 헤더 행 -->
            <Border Grid.Row="0" Grid.Column="0" Padding="4"
                        BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}" 
                        BorderThickness="0,0,1,1"
                        Background="{ThemeResource LayerFillColorDefaultBrush}"/>

            <Border Grid.Row="0" Grid.Column="1"  Padding="4"
                        BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}" 
                        BorderThickness="0,0,1,1"
                        Background="{ThemeResource LayerFillColorDefaultBrush}">
                <TextBlock Text="월" HorizontalAlignment="Center" VerticalAlignment="Center" 
                               FontSize="12" FontWeight="SemiBold"/>
            </Border>

            <Border Grid.Row="0" Grid.Column="2"  Padding="4"
                        BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}" 
                        BorderThickness="0,0,1,1"
                        Background="{ThemeResource LayerFillColorDefaultBrush}">
                <TextBlock Text="화" HorizontalAlignment="Center" VerticalAlignment="Center" 
                               FontSize="12" FontWeight="SemiBold"/>
            </Border>

            <Border Grid.Row="0" Grid.Column="3"  Padding="4"
                        BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}" 
                        BorderThickness="0,0,1,1"
                        Background="{ThemeResource LayerFillColorDefaultBrush}">
                <TextBlock Text="수" HorizontalAlignment="Center" VerticalAlignment="Center" 
                               FontSize="12" FontWeight="SemiBold"/>
            </Border>

            <Border Grid.Row="0" Grid.Column="4"  Padding="4"
                        BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}" 
                        BorderThickness="0,0,1,1"
                        Background="{ThemeResource LayerFillColorDefaultBrush}">
                <TextBlock Text="목" HorizontalAlignment="Center" VerticalAlignment="Center" 
                               FontSize="12" FontWeight="SemiBold"/>
            </Border>

            <Border Grid.Row="0" Grid.Column="5"  Padding="4"
                        BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}" 
                        BorderThickness="0,0,0,1"
                        Background="{ThemeResource LayerFillColorDefaultBrush}">
                <TextBlock Text="금" HorizontalAlignment="Center" VerticalAlignment="Center" 
                               FontSize="12" FontWeight="SemiBold"/>
            </Border>

            <!-- 교시 열 (1~7교시) -->
            <Border Grid.Row="1" Grid.Column="0"  Padding="4"
                        BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}" 
                        BorderThickness="0,0,1,1"
                        Background="{ThemeResource LayerFillColorDefaultBrush}">
                <TextBlock Text="1" HorizontalAlignment="Center" VerticalAlignment="Center" 
                               FontSize="12" FontWeight="Medium"/>
            </Border>

            <Border Grid.Row="2" Grid.Column="0"  Padding="4"
                        BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}" 
                        BorderThickness="0,0,1,1"
                        Background="{ThemeResource LayerFillColorDefaultBrush}">
                <TextBlock Text="2" HorizontalAlignment="Center" VerticalAlignment="Center" 
                               FontSize="12" FontWeight="Medium"/>
            </Border>

            <Border Grid.Row="3" Grid.Column="0" Padding="4"
                        BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}" 
                        BorderThickness="0,0,1,1"
                        Background="{ThemeResource LayerFillColorDefaultBrush}">
                <TextBlock Text="3" HorizontalAlignment="Center" VerticalAlignment="Center" 
                               FontSize="12" FontWeight="Medium"/>
            </Border>

            <Border Grid.Row="4" Grid.Column="0"  Padding="4"
                        BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}" 
                        BorderThickness="0,0,1,1"
                        Background="{ThemeResource LayerFillColorDefaultBrush}">
                <TextBlock Text="4" HorizontalAlignment="Center" VerticalAlignment="Center" 
                               FontSize="12" FontWeight="Medium"/>
            </Border>

            <Border Grid.Row="5" Grid.Column="0"  Padding="4"
                        BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}" 
                        BorderThickness="0,0,1,1"
                        Background="{ThemeResource LayerFillColorDefaultBrush}">
                <TextBlock Text="5" HorizontalAlignment="Center" VerticalAlignment="Center" 
                               FontSize="12" FontWeight="Medium"/>
            </Border>

            <Border Grid.Row="6" Grid.Column="0"  Padding="4"
                        BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}" 
                        BorderThickness="0,0,1,1"
                        Background="{ThemeResource LayerFillColorDefaultBrush}">
                <TextBlock Text="6" HorizontalAlignment="Center" VerticalAlignment="Center" 
                               FontSize="12" FontWeight="Medium"/>
            </Border>

            <Border Grid.Row="7" Grid.Column="0"  Padding="4"
                        BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}" 
                        BorderThickness="0,0,1,0"
                        Background="{ThemeResource LayerFillColorDefaultBrush}">
                <TextBlock Text="7" HorizontalAlignment="Center" VerticalAlignment="Center" 
                               FontSize="12" FontWeight="Medium"/>
            </Border>

            <!-- 시간표 셀들은 코드비하인드에서 동적으로 생성 -->
        </Grid>
    </Border>

</UserControl>

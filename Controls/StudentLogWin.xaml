<Window
    x:Class="NewSchool.Controls.StudentLogWin"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:NewSchool.Models"
    mc:Ignorable="d"
    Title="학생 생활 기록">

    <Window.SystemBackdrop>
        <MicaBackdrop Kind="BaseAlt"/>
    </Window.SystemBackdrop>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 메인 콘텐츠 -->
        <ScrollViewer Grid.Row="0" 
                      VerticalScrollBarVisibility="Auto"
                      Padding="24,20">
            <StackPanel Spacing="16">
                
                <!-- 학생 정보 -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="100"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" 
                               Text="학생" 
                               VerticalAlignment="Center"
                               FontWeight="SemiBold"/>
                    
                    <ComboBox x:Name="CboStudent"
                              Grid.Row="0" Grid.Column="1"
                              HorizontalAlignment="Stretch"
                              PlaceholderText="학생 선택"
                              SelectionChanged="CboStudent_SelectionChanged"/>

                    <TextBlock x:Name="TxtStudentInfo"
                               Grid.Row="1" Grid.Column="1"
                               Margin="0,4,0,0"
                               FontSize="12"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                </Grid>

                <!-- 기본 정보 -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="100"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="100"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- 날짜 -->
                    <TextBlock Grid.Row="0" Grid.Column="0" 
                               Text="날짜" 
                               VerticalAlignment="Center"
                               FontWeight="SemiBold"/>
                    <DatePicker x:Name="DatePickerLog"
                                Grid.Row="0" Grid.Column="1"
                                HorizontalAlignment="Stretch"
                                Margin="0,0,8,0"/>

                    <!-- 카테고리 -->
                    <TextBlock Grid.Row="0" Grid.Column="2" 
                               Text="영역" 
                               VerticalAlignment="Center"
                               FontWeight="SemiBold"
                               Margin="8,0,0,0"/>
                    <ComboBox x:Name="CboCategory"
                              Grid.Row="0" Grid.Column="3"
                              HorizontalAlignment="Stretch"
                              Margin="8,0,0,0"
                              PlaceholderText="영역 선택"
                              SelectionChanged="CboCategory_SelectionChanged"/>

                    <!-- 과목 (교과활동일 때만) -->
                    <TextBlock x:Name="TxtSubject"
                               Grid.Row="1" Grid.Column="0" 
                               Text="과목" 
                               VerticalAlignment="Center"
                               FontWeight="SemiBold"
                               Margin="0,12,0,0"
                               Visibility="Collapsed"/>
                    <ComboBox x:Name="CboSubject"
                              Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="3"
                              HorizontalAlignment="Stretch"
                              Margin="0,12,0,0"
                              PlaceholderText="과목 선택"
                              Visibility="Collapsed"/>
                </Grid>

                <!-- 활동명/주제 -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="100"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" 
                               Text="활동명" 
                               VerticalAlignment="Center"
                               FontWeight="SemiBold"/>
                    <TextBox x:Name="TxtActivityName"
                             Grid.Row="0" Grid.Column="1"
                             PlaceholderText="활동명 입력"/>

                    <TextBlock Grid.Row="1" Grid.Column="0" 
                               Text="주제" 
                               VerticalAlignment="Center"
                               FontWeight="SemiBold"
                               Margin="0,12,0,0"/>
                    <TextBox x:Name="TxtTopic"
                             Grid.Row="1" Grid.Column="1"
                             PlaceholderText="주제 입력"
                             Margin="0,12,0,0"/>
                </Grid>
                <!-- 추가 정보 (접기 가능) -->
                <Expander x:Name="ExpanderAdditional"
                          Header="추가 정보 (선택사항)"
                          IsExpanded="False"
                          HorizontalAlignment="Stretch">
                    <StackPanel Spacing="12" Margin="0,12,0,0">

                        <!-- 구체적 활동 내용 -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" 
                                       Text="활동 내용" 
                                       VerticalAlignment="Top"
                                       Margin="0,8,0,0"/>
                            <TextBox x:Name="TxtDescription"
                                     Grid.Column="1"
                                     AcceptsReturn="True"
                                     TextWrapping="Wrap"
                                     MinHeight="80"
                                     PlaceholderText="구체적인 활동 내용"/>
                        </Grid>

                        <!-- 역할 -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" 
                                       Text="역할" 
                                       VerticalAlignment="Center"/>
                            <TextBox x:Name="TxtRole"
                                     Grid.Column="1"
                                     PlaceholderText="학생이 맡은 역할"/>
                        </Grid>

                        <!-- 기른 능력 -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" 
                                       Text="기른 능력" 
                                       VerticalAlignment="Center"/>
                            <TextBox x:Name="TxtSkillDeveloped"
                                     Grid.Column="1"
                                     PlaceholderText="활동을 통해 기른 능력"/>
                        </Grid>

                        <!-- 장점 -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" 
                                       Text="장점" 
                                       VerticalAlignment="Center"/>
                            <TextBox x:Name="TxtStrengthShown"
                                     Grid.Column="1"
                                     PlaceholderText="드러난 장점"/>
                        </Grid>

                        <!-- 성취 및 결과 -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" 
                                       Text="성취/결과" 
                                       VerticalAlignment="Center"/>
                            <TextBox x:Name="TxtResultOrOutcome"
                                     Grid.Column="1"
                                     PlaceholderText="활동의 결과 또는 성취"/>
                        </Grid>

                        <!-- 태그 -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" 
                                       Text="태그" 
                                       VerticalAlignment="Center"/>
                            <TextBox x:Name="TxtTag"
                                     Grid.Column="1"
                                     PlaceholderText="태그 (쉼표로 구분)"/>
                        </Grid>

                        <!-- 중요 표시 -->
                        <CheckBox x:Name="ChkIsImportant"
                                  Content="중요 기록으로 표시"/>
                    </StackPanel>
                </Expander>

                <!-- 기록 내용 -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="100"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Column="0" 
                               Text="기록 내용" 
                               VerticalAlignment="Top"
                               FontWeight="SemiBold"
                               Margin="0,8,0,0"/>
                    
                    <Grid Grid.Column="1">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBox x:Name="TxtLog"
                                 Grid.Row="0"
                                 AcceptsReturn="True"
                                 TextWrapping="Wrap"
                                 MinHeight="200"
                                 MaxHeight="300"
                                 PlaceholderText="학생 활동 및 특성 기록"
                                 TextChanged="TxtLog_TextChanged"
                                 ScrollViewer.VerticalScrollBarVisibility="Auto"/>

                        <StackPanel Grid.Row="1" 
                                    Orientation="Horizontal" 
                                    HorizontalAlignment="Right"
                                    Spacing="12"
                                    Margin="0,8,0,0">
                            <TextBlock x:Name="TxtByteCount"
                                       FontSize="11"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                       Text="0 Byte / 0 자"/>
                            <TextBlock FontSize="11"
                                       Foreground="{ThemeResource SystemFillColorCriticalBrush}"
                                       Text="(최대 500자 권장)"/>
                        </StackPanel>
                    </Grid>
                </Grid>


            </StackPanel>
        </ScrollViewer>

        <!-- 버튼 영역 -->
        <Border Grid.Row="1"
                Background="{ThemeResource LayerFillColorDefaultBrush}"
                BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                BorderThickness="0,1,0,0"
                Padding="24,16">
            <StackPanel Orientation="Horizontal" 
                        HorizontalAlignment="Right"
                        Spacing="12">
                <Button x:Name="BtnSave"
                        Click="BtnSave_Click"
                        Style="{ThemeResource AccentButtonStyle}"
                        MinWidth="100">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon Glyph="&#xE74E;" FontSize="14"/>
                        <TextBlock Text="저장"/>
                    </StackPanel>
                </Button>
                <Button x:Name="BtnCancel"
                        Click="BtnCancel_Click"
                        MinWidth="100">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon Glyph="&#xE711;" FontSize="14"/>
                        <TextBlock Text="취소"/>
                    </StackPanel>
                </Button>
            </StackPanel>
        </Border>
    </Grid>
</Window>

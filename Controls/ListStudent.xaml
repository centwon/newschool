<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="NewSchool.Controls.ListStudent"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:NewSchool.Models"
    mc:Ignorable="d">

    <UserControl.Resources>
        <!-- ★ Multiple 모드 체크마크/선택 색상 강조 -->
        <SolidColorBrush x:Key="ListViewItemCheckBrush" Color="#0063B1"/>
        <SolidColorBrush x:Key="ListViewItemCheckBoxBrush" Color="#0063B1"/>
        <SolidColorBrush x:Key="ListViewItemCheckSelectedBrush" Color="White"/>
        <SolidColorBrush x:Key="ListViewItemBackgroundSelected" Color="#1A0078D4"/>
        <SolidColorBrush x:Key="ListViewItemBackgroundSelectedPointerOver" Color="#260078D4"/>
        <SolidColorBrush x:Key="ListViewItemBackgroundSelectedPressed" Color="#330078D4"/>

        <Style x:Key="StudentListViewItemStyle" TargetType="ListViewItem">
            <Setter Property="Padding" Value="4,2"/>
            <Setter Property="Margin" Value="0,1"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="MinHeight" Value="38"/>
            <Setter Property="BorderBrush" Value="{ThemeResource DividerStrokeColorDefaultBrush}"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
        </Style>
    </UserControl.Resources>

    <Border 
        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
        BorderThickness="1"
        CornerRadius="8">

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- 헤더 -->
            <Grid x:Name="HeaderGrid"
                  Grid.Row="0"
                  Padding="12,8,12,8"
                  Background="{ThemeResource LayerFillColorDefaultBrush}"
                  BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                  BorderThickness="0,0,0,1">

                <Grid.ColumnDefinitions>
                    <ColumnDefinition x:Name="ColCheckHeader" Width="0"/>
                    <ColumnDefinition x:Name="ColGradeHeader" Width="0"/>
                    <ColumnDefinition x:Name="ColClassHeader" Width="0"/>
                    <ColumnDefinition x:Name="ColNumberHeader" Width="50"/>
                    <ColumnDefinition x:Name="ColNameHeader" Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- 전체 선택 체크박스 -->
                <CheckBox x:Name="ChkSelectAll"
                          Grid.Column="0"
                          Content="전체"
                          FontSize="12"
                          FontWeight="SemiBold"
                          MinWidth="0"
                          IsThreeState="True"
                          Checked="OnSelectAllChecked"
                          Unchecked="OnSelectAllUnchecked"
                          Visibility="Collapsed"/>

                <TextBlock Grid.Column="1" x:Name="TxtGradeHeader"
                           Text="학년" FontWeight="SemiBold"
                           VerticalAlignment="Center" HorizontalAlignment="Center"/>

                <TextBlock Grid.Column="2" x:Name="TxtClassHeader"
                           Text="반" FontWeight="SemiBold"
                           VerticalAlignment="Center" HorizontalAlignment="Center"/>

                <TextBlock Grid.Column="3" x:Name="TxtNumberHeader"
                           Text="번호" FontWeight="SemiBold"
                           VerticalAlignment="Center" HorizontalAlignment="Center"/>

                <TextBlock Grid.Column="4" x:Name="TxtNameHeader"
                           Text="이름" FontWeight="SemiBold"
                           VerticalAlignment="Center" HorizontalAlignment="Center"/>
            </Grid>

            <!-- 학생 목록 -->
            <ListView x:Name="StudentListView"
                      Grid.Row="1"
                      SelectionMode="Single"
                      IsItemClickEnabled="False"
                      ItemContainerStyle="{StaticResource StudentListViewItemStyle}"
                      SelectionChanged="OnSelectionChanged"
                      CanDragItems="True"
                      DragItemsStarting="OnDragItemsStarting">

                <ListView.ItemTemplate>
                    <DataTemplate x:DataType="models:Enrollment">
                        <Grid Padding="0,4" Loaded="OnItemGridLoaded">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="0"/>
                                <ColumnDefinition Width="0"/>
                                <ColumnDefinition Width="0"/>
                                <ColumnDefinition Width="50"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- 체크박스 (코드에서 제어) -->
                            <CheckBox Grid.Column="0"
                                      HorizontalAlignment="Center"
                                      VerticalAlignment="Center"
                                      Visibility="Collapsed"/>

                            <TextBlock Grid.Column="1" Text="{x:Bind Grade}"
                                       VerticalAlignment="Center" HorizontalAlignment="Center"/>

                            <TextBlock Grid.Column="2" Text="{x:Bind Class}"
                                       VerticalAlignment="Center" HorizontalAlignment="Center"/>

                            <TextBlock Grid.Column="3" Text="{x:Bind Number}"
                                       VerticalAlignment="Center" HorizontalAlignment="Center"/>

                            <TextBlock Grid.Column="4" Text="{x:Bind Name}"
                                       VerticalAlignment="Center" HorizontalAlignment="Center"/>
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>

            <!-- 하단 선택 정보 -->
            <Border x:Name="PnlSelectionInfo"
                    Grid.Row="2"
                    Padding="12,6"
                    Background="{ThemeResource LayerFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                    BorderThickness="0,1,0,0"
                    Visibility="Collapsed">
                <TextBlock x:Name="TxtSelectionInfo"
                           FontSize="12"
                           FontWeight="SemiBold"
                           Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"/>
            </Border>
        </Grid>
    </Border>
</UserControl>

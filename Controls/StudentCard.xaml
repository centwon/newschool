<UserControl
    x:Class="NewSchool.Controls.StudentCard"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:viewmodels="using:NewSchool.ViewModels"
    xmlns:converters="using:NewSchool.Converters"
    mc:Ignorable="d"
    x:DefaultBindMode="OneWay">

    <UserControl.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        <converters:DateTimeToDateTimeOffsetConverter x:Key="DateTimeToDateTimeOffsetConverter"/>
        
        <!-- 라벨 스타일 -->
        <Style x:Key="FormLabelStyle" TargetType="TextBlock">
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="HorizontalAlignment" Value="Right"/>
            <Setter Property="Margin" Value="0,0,6,0"/>
            <Setter Property="Foreground" Value="{ThemeResource TextFillColorSecondaryBrush}"/>
        </Style>

        <!-- 섹션 헤더 스타일 -->
        <Style x:Key="SectionHeaderStyle" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Margin" Value="0,8,0,4"/>
            <Setter Property="Foreground" Value="{ThemeResource AccentTextFillColorPrimaryBrush}"/>
        </Style>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollMode="Auto" Padding="4">
        <StackPanel Spacing="2">

            <!-- ===== 기본 정보 + 사진 ===== -->
            <TextBlock Text="기본 정보" Style="{StaticResource SectionHeaderStyle}" Margin="0,0,0,4"/>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- 왼쪽: 기본 정보 입력 -->
                <Grid Grid.Column="0" RowSpacing="4" ColumnSpacing="6" Margin="0,0,12,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="65"/>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="55"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Row 0: 이름, 성별, 나이 -->
                    <TextBlock Grid.Row="0" Grid.Column="0" Text="이름" Style="{StaticResource FormLabelStyle}"/>
                    <TextBox Grid.Row="0" Grid.Column="1"
                            Text="{x:Bind ViewModel.Student.Name, Mode=TwoWay}"/>
                    
                    <TextBlock Grid.Row="0" Grid.Column="2" Text="성별" Style="{StaticResource FormLabelStyle}"/>
                    <ComboBox Grid.Row="0" Grid.Column="3"
                             SelectedItem="{x:Bind ViewModel.Student.Sex, Mode=TwoWay}"
                             HorizontalAlignment="Stretch">
                        <x:String>남</x:String>
                        <x:String>여</x:String>
                    </ComboBox>
                    
                    <TextBlock Grid.Row="0" Grid.Column="4" Text="나이" Style="{StaticResource FormLabelStyle}"/>
                    <TextBlock Grid.Row="0" Grid.Column="5" 
                              Text="{x:Bind ViewModel.Age, Mode=OneWay}"
                              VerticalAlignment="Center"/>

                    <!-- Row 1: 생년월일 -->
                    <TextBlock Grid.Row="1" Grid.Column="0" Text="생년월일" Style="{StaticResource FormLabelStyle}"/>
                    <DatePicker Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="3"
                               SelectedDate="{x:Bind ViewModel.Student.BirthDate, Mode=TwoWay, Converter={StaticResource DateTimeToDateTimeOffsetConverter}}"/>

                    <!-- Row 2: 전화번호, 이메일 -->
                    <TextBlock Grid.Row="2" Grid.Column="0" Text="전화번호" Style="{StaticResource FormLabelStyle}"/>
                    <TextBox Grid.Row="2" Grid.Column="1"
                            Text="{x:Bind ViewModel.Student.Phone, Mode=TwoWay}"/>
                    
                    <TextBlock Grid.Row="2" Grid.Column="2" Text="이메일" Style="{StaticResource FormLabelStyle}"/>
                    <TextBox Grid.Row="2" Grid.Column="3" Grid.ColumnSpan="3"
                            Text="{x:Bind ViewModel.Student.Email, Mode=TwoWay}"/>

                    <!-- Row 3: 주소 -->
                    <TextBlock Grid.Row="3" Grid.Column="0" Text="주소" Style="{StaticResource FormLabelStyle}"/>
                    <TextBox Grid.Row="3" Grid.Column="1" Grid.ColumnSpan="5"
                            Text="{x:Bind ViewModel.Student.Address, Mode=TwoWay}"/>

                    <!-- Row 4: 간단 메모 -->
                    <TextBlock Grid.Row="4" Grid.Column="0" Text="메모" Style="{StaticResource FormLabelStyle}"/>
                    <TextBox Grid.Row="4" Grid.Column="1" Grid.ColumnSpan="5"
                            Text="{x:Bind ViewModel.Student.Memo, Mode=TwoWay}"
                            PlaceholderText="간단한 메모"/>
                </Grid>

                <!-- 오른쪽: 사진 영역 -->
                <StackPanel Grid.Column="1" Spacing="4" VerticalAlignment="Top">
                    <Border BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}"
                            BorderThickness="1" CornerRadius="4">
                        <Image Source="{x:Bind ViewModel.PhotoImage, Mode=OneWay}"
                               Width="120" Height="150"
                               Stretch="UniformToFill"/>
                    </Border>
                    <StackPanel Orientation="Horizontal" Spacing="4" HorizontalAlignment="Center">
                        <Button Content="등록" Click="AddPhotoAsync" Padding="8,3" FontSize="11"/>
                        <Button Content="삭제" Click="DeletePhotoAsync" Padding="8,3" FontSize="11"/>
                    </StackPanel>
                </StackPanel>
            </Grid>

            <!-- ===== 상세 정보 (Expander 하나로 통합) ===== -->
            <Expander Header="상세 정보"
                      HorizontalAlignment="Stretch"
                      HorizontalContentAlignment="Stretch"
                      Margin="0,6,0,0"
                      Visibility="{x:Bind ViewModel.IsLoaded, Converter={StaticResource BoolToVisibilityConverter}, Mode=OneWay}">
                <StackPanel Padding="4" Spacing="0">

                    <!-- 보호자 정보 -->
                    <TextBlock Text="보호자 정보" Style="{StaticResource SectionHeaderStyle}" Margin="0,0,0,4"/>
                    <Grid RowSpacing="4" ColumnSpacing="6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="65"/>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="45"/>
                            <ColumnDefinition Width="70"/>
                            <ColumnDefinition Width="50"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0" Text="보호자" Style="{StaticResource FormLabelStyle}"/>
                        <TextBox Grid.Column="1" PlaceholderText="이름"
                                Text="{x:Bind ViewModel.Detail.GuardianName, Mode=TwoWay}"/>
                        
                        <TextBlock Grid.Column="2" Text="관계" Style="{StaticResource FormLabelStyle}"/>
                        <TextBox Grid.Column="3" PlaceholderText="부/모"
                                Text="{x:Bind ViewModel.Detail.GuardianRelation, Mode=TwoWay}"/>
                        
                        <TextBlock Grid.Column="4" Text="연락처" Style="{StaticResource FormLabelStyle}"/>
                        <TextBox Grid.Column="5"
                                Text="{x:Bind ViewModel.Detail.GuardianPhone, Mode=TwoWay}"/>
                    </Grid>

                    <!-- 가족 정보 -->
                    <TextBlock Text="가족 정보" Style="{StaticResource SectionHeaderStyle}"/>
                    <Grid RowSpacing="4" ColumnSpacing="6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="65"/>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="50"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="아버지" Style="{StaticResource FormLabelStyle}"/>
                        <TextBox Grid.Row="0" Grid.Column="1" PlaceholderText="이름"
                                Text="{x:Bind ViewModel.Detail.FatherName, Mode=TwoWay}"/>
                        <TextBlock Grid.Row="0" Grid.Column="2" Text="연락처" Style="{StaticResource FormLabelStyle}"/>
                        <TextBox Grid.Row="0" Grid.Column="3"
                                Text="{x:Bind ViewModel.Detail.FatherPhone, Mode=TwoWay}"/>

                        <TextBlock Grid.Row="1" Grid.Column="0" Text="어머니" Style="{StaticResource FormLabelStyle}"/>
                        <TextBox Grid.Row="1" Grid.Column="1" PlaceholderText="이름"
                                Text="{x:Bind ViewModel.Detail.MotherName, Mode=TwoWay}"/>
                        <TextBlock Grid.Row="1" Grid.Column="2" Text="연락처" Style="{StaticResource FormLabelStyle}"/>
                        <TextBox Grid.Row="1" Grid.Column="3"
                                Text="{x:Bind ViewModel.Detail.MotherPhone, Mode=TwoWay}"/>

                        <TextBlock Grid.Row="2" Grid.Column="0" Text="가족구성" Style="{StaticResource FormLabelStyle}" VerticalAlignment="Top" Margin="0,8,6,0"/>
                        <TextBox Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="3"
                                Text="{x:Bind ViewModel.Detail.FamilyInfo, Mode=TwoWay}"
                                PlaceholderText="가족 구성 및 환경"
                                AcceptsReturn="True"
                                TextWrapping="Wrap"
                                MinHeight="60"/>
                    </Grid>

                    <!-- 진로 및 관심사 -->
                    <TextBlock Text="진로 및 관심사" Style="{StaticResource SectionHeaderStyle}"/>
                    <Grid RowSpacing="4" ColumnSpacing="6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="65"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="65"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="진로희망" Style="{StaticResource FormLabelStyle}"/>
                        <TextBox Grid.Row="0" Grid.Column="1"
                                Text="{x:Bind ViewModel.Detail.CareerGoal, Mode=TwoWay}"/>

                        <TextBlock Grid.Row="0" Grid.Column="2" Text="특기" Style="{StaticResource FormLabelStyle}"/>
                        <TextBox Grid.Row="0" Grid.Column="3"
                                Text="{x:Bind ViewModel.Detail.Talents, Mode=TwoWay}"/>

                        <TextBlock Grid.Row="1" Grid.Column="0" Text="관심/취미" Style="{StaticResource FormLabelStyle}"/>
                        <TextBox Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="3"
                                Text="{x:Bind ViewModel.Detail.Interests, Mode=TwoWay}"/>
                    </Grid>

                    <!-- 건강 정보 -->
                    <TextBlock Text="건강 정보" Style="{StaticResource SectionHeaderStyle}"/>
                    <Grid RowSpacing="4" ColumnSpacing="6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="65"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="65"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="건강정보" Style="{StaticResource FormLabelStyle}"/>
                        <TextBox Grid.Row="0" Grid.Column="1" Grid.ColumnSpan="3"
                                Text="{x:Bind ViewModel.Detail.HealthInfo, Mode=TwoWay}"/>

                        <TextBlock Grid.Row="1" Grid.Column="0" Text="알레르기" Style="{StaticResource FormLabelStyle}"/>
                        <TextBox Grid.Row="1" Grid.Column="1"
                                Text="{x:Bind ViewModel.Detail.Allergies, Mode=TwoWay}"/>

                        <TextBlock Grid.Row="1" Grid.Column="2" Text="특수교육" Style="{StaticResource FormLabelStyle}"/>
                        <TextBox Grid.Row="1" Grid.Column="3"
                                Text="{x:Bind ViewModel.Detail.SpecialNeeds, Mode=TwoWay}"/>
                    </Grid>

                    <!-- 상세 메모 -->
                    <TextBlock Text="상세 메모" Style="{StaticResource SectionHeaderStyle}"/>
                    <TextBox Text="{x:Bind ViewModel.Detail.Memo, Mode=TwoWay}"
                            AcceptsReturn="True"
                            MinHeight="60"
                            PlaceholderText="학생에 대한 상세 메모"/>
                </StackPanel>
            </Expander>
        </StackPanel>
    </ScrollViewer>
</UserControl>

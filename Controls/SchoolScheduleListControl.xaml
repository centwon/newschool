<UserControl
    x:Class="NewSchool.Controls.SchoolScheduleListControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:NewSchool.Models"
    xmlns:converters="using:NewSchool.Converters"
    mc:Ignorable="d">

    <UserControl.Resources>
        <converters:BoolToVacationColorConverter x:Key="VacationColorConverter"/>
        <converters:BoolToTodayBackgroundConverter x:Key="TodayBackgroundConverter"/>
    </UserControl.Resources>

    <Border Style="{StaticResource DashboardCard}" MinHeight="80">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- 헤더 -->
            <Border Grid.Row="0" Style="{StaticResource DashboardCardHeader}">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <FontIcon Glyph="&#xE787;" Style="{StaticResource DashboardCardHeaderIcon}"/>
                    <TextBlock Text="학사일정" Style="{StaticResource DashboardCardHeaderTitle}"/>
                </StackPanel>
            </Border>

            <!-- 일정 목록 -->
            <ListView x:Name="ScheduleItemsRepeater"
                      Grid.Row="1"
                      Padding="4,4,4,8"
                      SelectionMode="None"
                      IsItemClickEnabled="False">
                <ListView.ItemContainerStyle>
                    <Style TargetType="ListViewItem">
                        <Setter Property="MinHeight" Value="0"/>
                        <Setter Property="Padding" Value="8,2"/>
                    </Style>
                </ListView.ItemContainerStyle>
                <ListView.ItemTemplate>
                    <DataTemplate x:DataType="models:SchoolScheduleGroup">
                        <Grid Padding="0,2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <FontIcon Grid.Column="0"
                                      Glyph="&#xE163;"
                                      FontSize="14"
                                      Margin="0,0,8,0"
                                      VerticalAlignment="Top"
                                      Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"/>

                            <TextBlock Grid.Column="1"
                                       Text="{x:Bind DateText}"
                                       Foreground="{x:Bind IsVacation, Converter={StaticResource VacationColorConverter}}"
                                       TextWrapping="Wrap"
                                       FontSize="13"/>
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </Grid>
    </Border>
</UserControl>

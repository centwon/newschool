<UserControl
    x:Class="NewSchool.Controls.CompactTimePicker"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    mc:Ignorable="d">

    <StackPanel Orientation="Horizontal" Spacing="2" VerticalAlignment="Center">
        <NumberBox x:Name="HourBox"
                   Minimum="0" Maximum="23" SmallChange="1" LargeChange="1"
                   SpinButtonPlacementMode="Compact"
                   Value="0" Width="64"
                   ValueChanged="HourBox_ValueChanged"/>
        <TextBlock Text=":" VerticalAlignment="Center"
                   FontSize="14" FontWeight="SemiBold" Opacity="0.5"
                   Margin="2,0"/>
        <NumberBox x:Name="MinuteBox"
                   Minimum="0" Maximum="59" SmallChange="1" LargeChange="1"
                   SpinButtonPlacementMode="Compact"
                   Value="0" Width="64"
                   ValueChanged="MinuteBox_ValueChanged"/>
    </StackPanel>
</UserControl>

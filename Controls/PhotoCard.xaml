<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="NewSchool.Controls.PhotoCard"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Width="80"
    AllowDrop="True"
    CanDrag="True">

    <UserControl.ContextFlyout>
        <MenuFlyout>
            <ToggleMenuFlyoutItem x:Name="MenuSeatDisable" Text="미사용 좌석" Click="MenuSeatDisable_Click"/>
            <ToggleMenuFlyoutItem x:Name="MenuSeatFixed" Text="지정 좌석" Click="MenuSeatFixed_Click"/>
        </MenuFlyout>
    </UserControl.ContextFlyout>

    <Border x:Name="BrdrOutLine"
            BorderBrush="CornflowerBlue" 
            BorderThickness="1"
            CornerRadius="4"
            Background="Transparent">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition x:Name="RowPhoto" Height="Auto"/>
                <RowDefinition x:Name="RowName" Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- 사진 영역 -->
            <Viewbox Grid.Row="0" Stretch="Uniform" x:Name="PhotoControl">
                <Border x:Name="PhotoBorder" CornerRadius="2">
                    <Image x:Name="Photo" Stretch="UniformToFill"/>
                </Border>
            </Viewbox>

            <!-- 이름 영역 -->
            <Viewbox Grid.Row="1" Stretch="UniformToFill" x:Name="NameBox">
                <TextBlock x:Name="TBName" 
                          Text="" 
                          TextAlignment="Center" 
                          VerticalAlignment="Center" 
                          HorizontalAlignment="Center"
                          Padding="4,2"/>
            </Viewbox>
        </Grid>
    </Border>
</UserControl>

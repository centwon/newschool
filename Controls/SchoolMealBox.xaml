<UserControl
    x:Class="NewSchool.Controls.SchoolMealBox"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:model="using:NewSchool.Models"
    mc:Ignorable="d">

    <Border BorderBrush="CornflowerBlue" 
            BorderThickness="1" 
            CornerRadius="8" 
            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
            MinHeight="180">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- 헤더 -->
            <Grid Grid.Row="0" 
                  Padding="12,8"
                  Background="Lavender"
                  CornerRadius="8,8,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- 제목 -->
                <TextBlock Grid.Column="0"
                           Text="🍱 급식" 
                           FontWeight="Bold"
                           VerticalAlignment="Center" 
                           FontSize="14"
                           Margin="4,0,12,0"/>

                <!-- 날짜 선택 영역 -->
                <StackPanel Grid.Column="2" 
                            Orientation="Horizontal" 
                            Spacing="2">
                    <!-- 이전 날짜 -->
                    <Button x:Name="PreviousDayButton"
                            Content="◀"
                            Click="PreviousDayButton_Click"
                            ToolTipService.ToolTip="이전 날"
                            Width="24"
                            Height="32"
                            Padding="0"
                            FontSize="12"/>

                    <!-- 날짜 선택기 -->
                    <CalendarDatePicker x:Name="DatePicker"
                                        Date="{x:Bind SelectedDate, Mode=TwoWay}"
                                        DateChanged="DatePicker_DateChanged"
                                        PlaceholderText="날짜 선택"
                                        Width="120"
                                        Height="32"
                                        HorizontalAlignment="Center"/>

                    <!-- 다음 날짜 -->
                    <Button x:Name="NextDayButton"
                            Content="▶"
                            Click="NextDayButton_Click"
                            ToolTipService.ToolTip="다음 날"
                            Width="24"
                            Height="32"
                            Padding="0"
                            FontSize="12"/>

                    <!-- 오늘 버튼 --><!--
                    <Button x:Name="TodayButton"
                            Content="오늘"
                            Click="TodayButton_Click"
                            ToolTipService.ToolTip="오늘로 이동"
                            Height="32"
                            Padding="12,0"
                            FontSize="12"/>-->
                </StackPanel>
            </Grid>

            <!-- 급식 목록 -->
            <ScrollViewer Grid.Row="1" 
                          Padding="12,8,12,12" 
                          MaxHeight="300"
                          VerticalScrollBarVisibility="Auto">
                <ItemsRepeater x:Name="MealsRepeater">
                    <ItemsRepeater.Layout>
                        <StackLayout Spacing="12"/>
                    </ItemsRepeater.Layout>
                    <ItemsRepeater.ItemTemplate>
                        <DataTemplate x:DataType="model:SchoolMeal">
                            <TextBlock Text="{x:Bind DisplayText}"
                                       TextWrapping="Wrap"
                                       FontSize="12"
                                       Margin="8,4"
                                       Padding="4"/>
                        </DataTemplate>
                    </ItemsRepeater.ItemTemplate>
                </ItemsRepeater>
            </ScrollViewer>
        </Grid>
    </Border>
</UserControl>

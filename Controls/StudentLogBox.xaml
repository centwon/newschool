<UserControl
    x:Class="NewSchool.Controls.StudentLogBox"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:NewSchool.Models"
    mc:Ignorable="d">

    <Border 
        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
        BorderThickness="1"
        CornerRadius="8"
        Padding="24">

        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Spacing="24">

                <!-- 헤더 -->
                <StackPanel Spacing="8">
                    <TextBlock 
                        Text="📝 학생 기록 편집" 
                        Style="{StaticResource SubtitleTextBlockStyle}"
                        FontWeight="SemiBold"/>
                    <TextBlock 
                        x:Name="TxtStudentInfo"
                        Text="학생 정보"
                        FontSize="12"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                </StackPanel>

                <!-- 기본 정보 섹션 -->
                <StackPanel Spacing="16">
                    <TextBlock 
                        Text="📌 기본 정보" 
                        FontWeight="SemiBold"
                        Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"/>

                    <Grid ColumnSpacing="12" RowSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- 학년도 -->
                        <TextBlock Grid.Row="0" Grid.Column="0" 
                                   Text="학년도" 
                                   VerticalAlignment="Center"
                                   Margin="0,0,8,0"/>
                        <NumberBox x:Name="NumYear"
                                   Grid.Row="0" Grid.Column="1"
                                   SpinButtonPlacementMode="Inline"
                                   Minimum="2000"
                                   Maximum="2100"
                                   HorizontalAlignment="Stretch"/>

                        <!-- 학기 -->
                        <TextBlock Grid.Row="0" Grid.Column="2" 
                                   Text="학기" 
                                   VerticalAlignment="Center"
                                   Margin="12,0,8,0"/>
                        <ComboBox x:Name="CBoxSemester"
                                  Grid.Row="0" Grid.Column="3"
                                  HorizontalAlignment="Stretch">
                            <ComboBoxItem Content="1학기" Tag="1"/>
                            <ComboBoxItem Content="2학기" Tag="2"/>
                        </ComboBox>

                        <!-- 날짜 -->
                        <TextBlock Grid.Row="1" Grid.Column="0" 
                                   Text="날짜" 
                                   VerticalAlignment="Center"
                                   Margin="0,0,8,0"/>
                        <DatePicker x:Name="DatePickerLog"
                                    Grid.Row="1" Grid.Column="1"
                                    HorizontalAlignment="Stretch"/>

                        <!-- 중요 표시 -->
                        <CheckBox x:Name="ChkIsImportant"
                                  Grid.Row="1" Grid.Column="2" Grid.ColumnSpan="2"
                                  Content="⭐ 중요 기록"
                                  Margin="12,0,0,0"/>

                        <!-- 카테고리 -->
                        <TextBlock Grid.Row="2" Grid.Column="0" 
                                   Text="카테고리" 
                                   VerticalAlignment="Center"
                                   Margin="0,0,8,0"/>
                        <ComboBox x:Name="CBoxCategory"
                                  Grid.Row="2" Grid.Column="1"
                                  HorizontalAlignment="Stretch"
                                  SelectionChanged="OnCategoryChanged">
                            <ComboBoxItem Content="전체" Tag="0"/>
                            <ComboBoxItem Content="교과활동" Tag="1"/>
                            <ComboBoxItem Content="개인별세특" Tag="2"/>
                            <ComboBoxItem Content="자율활동" Tag="3"/>
                            <ComboBoxItem Content="동아리활동" Tag="4"/>
                            <ComboBoxItem Content="봉사활동" Tag="5"/>
                            <ComboBoxItem Content="진로활동" Tag="6"/>
                            <ComboBoxItem Content="종합의견" Tag="7"/>
                            <ComboBoxItem Content="상담기록" Tag="8"/>
                            <ComboBoxItem Content="기타" Tag="9"/>
                        </ComboBox>

                        <!-- 과목명 -->
                        <TextBlock Grid.Row="2" Grid.Column="2" 
                                   Text="과목명" 
                                   VerticalAlignment="Center"
                                   Margin="12,0,8,0"/>
                        <TextBox x:Name="TxtSubjectName"
                                 Grid.Row="2" Grid.Column="3"
                                 PlaceholderText="과목명 입력"
                                 HorizontalAlignment="Stretch"/>
                    </Grid>
                </StackPanel>

                <!-- 구조화된 활동 기록 섹션 -->
                <StackPanel Spacing="16">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <TextBlock 
                            Text="🎯 구조화된 활동 기록" 
                            FontWeight="SemiBold"
                            Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"/>
                        <TextBlock 
                            Text="(학생부 기록용 - 항목별 입력)"
                            FontSize="11"
                            Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                            VerticalAlignment="Center"/>
                    </StackPanel>

                    <Grid ColumnSpacing="12" RowSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="100"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- 활동명 -->
                        <TextBlock Grid.Row="0" Grid.Column="0" 
                                   Text="활동명" 
                                   VerticalAlignment="Center"/>
                        <TextBox x:Name="TxtActivityName"
                                 Grid.Row="0" Grid.Column="1"
                                 PlaceholderText="예: 수행평가, 프로젝트 학습, 환경보호 캠페인"
                                 TextChanged="OnStructuredFieldChanged"/>

                        <!-- 주제 -->
                        <TextBlock Grid.Row="1" Grid.Column="0" 
                                   Text="주제" 
                                   VerticalAlignment="Center"/>
                        <TextBox x:Name="TxtTopic"
                                 Grid.Row="1" Grid.Column="1"
                                 PlaceholderText="예: 조선 후기 실학사상, 기후변화 대응"
                                 TextChanged="OnStructuredFieldChanged"/>

                        <!-- 활동 내용 -->
                        <TextBlock Grid.Row="2" Grid.Column="0" 
                                   Text="활동 내용" 
                                   VerticalAlignment="Top"
                                   Margin="0,8,0,0"/>
                        <TextBox x:Name="TxtDescription"
                                 Grid.Row="2" Grid.Column="1"
                                 PlaceholderText="구체적인 활동 내용을 입력하세요"
                                 AcceptsReturn="True"
                                 TextWrapping="Wrap"
                                 MinHeight="80"
                                 MaxHeight="120"
                                 ScrollViewer.VerticalScrollBarVisibility="Auto"
                                 TextChanged="OnStructuredFieldChanged"/>

                        <!-- 역할 -->
                        <TextBlock Grid.Row="3" Grid.Column="0" 
                                   Text="역할" 
                                   VerticalAlignment="Center"/>
                        <TextBox x:Name="TxtRole"
                                 Grid.Row="3" Grid.Column="1"
                                 PlaceholderText="예: 팀장, 발표 담당, 자료 조사"
                                 TextChanged="OnStructuredFieldChanged"/>

                        <!-- 기른 능력 -->
                        <TextBlock Grid.Row="4" Grid.Column="0" 
                                   Text="기른 능력" 
                                   VerticalAlignment="Center"/>
                        <TextBox x:Name="TxtSkillDeveloped"
                                 Grid.Row="4" Grid.Column="1"
                                 PlaceholderText="예: 협업 능력, 논리적 사고력, 문제해결력"
                                 TextChanged="OnStructuredFieldChanged"/>

                        <!-- 드러난 장점 -->
                        <TextBlock Grid.Row="5" Grid.Column="0" 
                                   Text="드러난 장점" 
                                   VerticalAlignment="Center"/>
                        <TextBox x:Name="TxtStrengthShown"
                                 Grid.Row="5" Grid.Column="1"
                                 PlaceholderText="예: 주도성, 성실성, 창의성"
                                 TextChanged="OnStructuredFieldChanged"/>

                        <!-- 성취 및 결과 -->
                        <TextBlock Grid.Row="6" Grid.Column="0" 
                                   Text="성취/결과" 
                                   VerticalAlignment="Center"/>
                        <TextBox x:Name="TxtResultOrOutcome"
                                 Grid.Row="6" Grid.Column="1"
                                 PlaceholderText="예: 발표 성공, 우수 평가 획득, 1등 수상"
                                 TextChanged="OnStructuredFieldChanged"/>
                    </Grid>
                </StackPanel>

                <!-- 기존 방식 - 단순 기록 섹션 -->
                <StackPanel Spacing="16">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <TextBlock 
                            Text="📄 단순 기록 (기존 방식)" 
                            FontWeight="SemiBold"
                            Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"/>
                        <TextBlock 
                            Text="(구조화 입력 대신 자유 형식 작성)"
                            FontSize="11"
                            Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                            VerticalAlignment="Center"/>
                    </StackPanel>

                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBox x:Name="TxtLog"
                                 Grid.Row="0"
                                 PlaceholderText="기록 내용을 자유롭게 입력하세요"
                                 AcceptsReturn="True"
                                 TextWrapping="Wrap"
                                 MinHeight="120"
                                 MaxHeight="200"
                                 ScrollViewer.VerticalScrollBarVisibility="Auto"
                                 TextChanged="OnLogChanged"/>

                        <TextBlock x:Name="TxtLogByteInfo"
                                   Grid.Row="1"
                                   Text="0 Byte / 0 자"
                                   FontSize="11"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                   HorizontalAlignment="Right"
                                   Margin="0,4,0,0"/>
                    </Grid>
                </StackPanel>

                <!-- 태그 섹션 -->
                <StackPanel Spacing="12">
                    <TextBlock 
                        Text="🏷️ 태그" 
                        FontWeight="SemiBold"
                        Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"/>
                    
                    <TextBox x:Name="TxtTag"
                             PlaceholderText="쉼표로 구분하여 입력 (예: 협업, 발표, 리더십)"/>
                </StackPanel>

                <!-- 자동 생성 영역 -->
                <StackPanel Spacing="16">
                    <TextBlock 
                        Text="✨ 자동 생성" 
                        FontWeight="SemiBold"
                        Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"/>

                    <!-- 생성 버튼 -->
                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <Button x:Name="BtnGenerateSummary"
                                Content="🔍 활동 요약 생성"
                                Click="OnGenerateSummaryClick"
                                Style="{StaticResource AccentButtonStyle}"/>
                        
                        <Button x:Name="BtnGenerateDraft"
                                Content="📝 학생부 초안 생성"
                                Click="OnGenerateDraftClick"/>

                        <TextBlock 
                            Text="(구조화된 입력이 있을 때만 생성됩니다)"
                            FontSize="11"
                            Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                            VerticalAlignment="Center"/>
                    </StackPanel>

                    <!-- 생성된 텍스트 영역 -->
                    <Border 
                        Background="{ThemeResource LayerFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="4"
                        Padding="12"
                        MinHeight="100">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <TextBlock x:Name="TxtGeneratedText"
                                       Text="여기에 생성된 요약 또는 초안이 표시됩니다."
                                       TextWrapping="Wrap"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                       FontSize="13"
                                       LineHeight="22"/>
                        </ScrollViewer>
                    </Border>

                    <!-- 복사 버튼 -->
                    <Button x:Name="BtnCopyToClipboard"
                            Content="📋 클립보드에 복사"
                            Click="OnCopyToClipboardClick"
                            HorizontalAlignment="Right"
                            IsEnabled="False"/>
                </StackPanel>

                <!-- 저장/취소 버튼 -->
                <StackPanel Orientation="Horizontal" 
                            Spacing="12"
                            HorizontalAlignment="Right"
                            Margin="0,12,0,0">
                    <Button x:Name="BtnSave"
                            Content="💾 저장"
                            Click="OnSaveClick"
                            Style="{StaticResource AccentButtonStyle}"
                            MinWidth="100"/>
                    
                    <Button x:Name="BtnCancel"
                            Content="❌ 취소"
                            Click="OnCancelClick"
                            MinWidth="100"/>
                </StackPanel>

            </StackPanel>
        </ScrollViewer>
    </Border>
</UserControl>

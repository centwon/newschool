<UserControl
    x:Class="NewSchool.Controls.StudentLogBox"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Border
        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
        BorderThickness="1"
        CornerRadius="8"
        Padding="20">

        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Spacing="16">

                <!-- 학생 정보 -->
                <TextBlock
                    x:Name="TxtStudentInfo"
                    Text="학생 정보"
                    FontSize="12"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>

                <!-- 학년도 + 학기 + 날짜 + 중요 (한 줄) -->
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <NumberBox x:Name="NumYear"
                               Header="학년도"
                               SpinButtonPlacementMode="Inline"
                               Minimum="2000"
                               Maximum="2100"
                               MinWidth="140"/>

                    <ComboBox x:Name="CBoxSemester"
                              Header="학기"
                              MinWidth="90">
                        <ComboBoxItem Content="1학기" Tag="1"/>
                        <ComboBoxItem Content="2학기" Tag="2"/>
                    </ComboBox>

                    <CalendarDatePicker x:Name="DatePickerLog"
                                        Header="날짜"
                                        MinWidth="140"/>

                    <CheckBox x:Name="ChkIsImportant"
                              Content="중요"
                              VerticalAlignment="Bottom"
                              Margin="4,0,0,4"/>
                </StackPanel>

                <!-- 카테고리 + 과목명 (한 줄) -->
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <ComboBox x:Name="CBoxCategory"
                              Header="카테고리"
                              MinWidth="120"
                              SelectionChanged="OnCategoryChanged">
                        <ComboBoxItem Content="전체" Tag="0"/>
                        <ComboBoxItem Content="교과활동" Tag="1"/>
                        <ComboBoxItem Content="개인별세특" Tag="2"/>
                        <ComboBoxItem Content="자율활동" Tag="3"/>
                        <ComboBoxItem Content="동아리활동" Tag="4"/>
                        <ComboBoxItem Content="봉사활동" Tag="5"/>
                        <ComboBoxItem Content="진로활동" Tag="6"/>
                        <ComboBoxItem Content="종합의견" Tag="7"/>
                        <ComboBoxItem Content="상담기록" Tag="8"/>
                        <ComboBoxItem Content="기타" Tag="9"/>
                    </ComboBox>

                    <TextBox x:Name="TxtSubjectName"
                             Header="과목명"
                             PlaceholderText="과목명 입력"
                             MinWidth="150"
                             Visibility="Collapsed"/>
                </StackPanel>

                <!-- 기록 내용 -->
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBox x:Name="TxtLog"
                             Grid.Row="0"
                             Header="기록 내용"
                             PlaceholderText="기록 내용을 입력하세요"
                             AcceptsReturn="True"
                             TextWrapping="Wrap"
                             MinHeight="120"
                             MaxHeight="200"
                             ScrollViewer.VerticalScrollBarVisibility="Auto"
                             TextChanged="OnLogChanged"/>

                    <TextBlock x:Name="TxtLogByteInfo"
                               Grid.Row="1"
                               Text="0 Byte / 0 자"
                               FontSize="11"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                               HorizontalAlignment="Right"
                               Margin="0,4,0,0"/>
                </Grid>

                <!-- 활동 상세 항목 -->
                <Expander x:Name="ExpanderStructured"
                          HorizontalAlignment="Stretch"
                          HorizontalContentAlignment="Stretch"
                          IsExpanded="False">
                    <Expander.Header>
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <TextBlock Text="활동 상세 항목" FontWeight="SemiBold"/>
                            <TextBlock Text="(학생부 기록용)"
                                       FontSize="11"
                                       Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Expander.Header>
                    <Expander.Content>
                        <Grid ColumnSpacing="12" RowSpacing="12" Margin="0,8,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="80"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Text="활동명" VerticalAlignment="Center"/>
                            <TextBox x:Name="TxtActivityName" Grid.Row="0" Grid.Column="1"
                                     PlaceholderText="예: 수행평가, 프로젝트 학습" TextChanged="OnStructuredFieldChanged"/>

                            <TextBlock Grid.Row="1" Grid.Column="0" Text="주제" VerticalAlignment="Center"/>
                            <TextBox x:Name="TxtTopic" Grid.Row="1" Grid.Column="1"
                                     PlaceholderText="예: 조선 후기 실학사상" TextChanged="OnStructuredFieldChanged"/>

                            <TextBlock Grid.Row="2" Grid.Column="0" Text="활동 내용" VerticalAlignment="Top" Margin="0,8,0,0"/>
                            <TextBox x:Name="TxtDescription" Grid.Row="2" Grid.Column="1"
                                     PlaceholderText="구체적인 활동 내용"
                                     AcceptsReturn="True" TextWrapping="Wrap"
                                     MinHeight="80" MaxHeight="120"
                                     ScrollViewer.VerticalScrollBarVisibility="Auto"
                                     TextChanged="OnStructuredFieldChanged"/>

                            <TextBlock Grid.Row="3" Grid.Column="0" Text="역할" VerticalAlignment="Center"/>
                            <TextBox x:Name="TxtRole" Grid.Row="3" Grid.Column="1"
                                     PlaceholderText="예: 팀장, 발표 담당" TextChanged="OnStructuredFieldChanged"/>

                            <TextBlock Grid.Row="4" Grid.Column="0" Text="기른 능력" VerticalAlignment="Center"/>
                            <TextBox x:Name="TxtSkillDeveloped" Grid.Row="4" Grid.Column="1"
                                     PlaceholderText="예: 협업 능력, 논리적 사고력" TextChanged="OnStructuredFieldChanged"/>

                            <TextBlock Grid.Row="5" Grid.Column="0" Text="드러난 장점" VerticalAlignment="Center"/>
                            <TextBox x:Name="TxtStrengthShown" Grid.Row="5" Grid.Column="1"
                                     PlaceholderText="예: 주도성, 성실성" TextChanged="OnStructuredFieldChanged"/>

                            <TextBlock Grid.Row="6" Grid.Column="0" Text="성취/결과" VerticalAlignment="Center"/>
                            <TextBox x:Name="TxtResultOrOutcome" Grid.Row="6" Grid.Column="1"
                                     PlaceholderText="예: 발표 성공, 우수 평가" TextChanged="OnStructuredFieldChanged"/>
                        </Grid>
                    </Expander.Content>
                </Expander>

                <!-- 태그 -->
                <TextBox x:Name="TxtTag"
                         Header="태그"
                         PlaceholderText="쉼표로 구분 (예: 협업, 발표, 리더십)"/>

                <!-- 자동 생성 -->
                <Expander HorizontalAlignment="Stretch"
                          HorizontalContentAlignment="Stretch"
                          IsExpanded="False">
                    <Expander.Header>
                        <TextBlock Text="자동 생성" FontWeight="SemiBold"/>
                    </Expander.Header>
                    <Expander.Content>
                        <StackPanel Spacing="12" Margin="0,8,0,0">
                            <StackPanel Orientation="Horizontal" Spacing="12">
                                <Button x:Name="BtnGenerateSummary"
                                        Content="활동 요약 생성"
                                        Click="OnGenerateSummaryClick"
                                        Style="{StaticResource AccentButtonStyle}"/>
                                <Button x:Name="BtnGenerateDraft"
                                        Content="학생부 초안 생성"
                                        Click="OnGenerateDraftClick"/>
                                <TextBlock Text="(활동 상세 항목 입력 시 생성 가능)"
                                           FontSize="11"
                                           Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                           VerticalAlignment="Center"/>
                            </StackPanel>

                            <Border Background="{ThemeResource LayerFillColorDefaultBrush}"
                                    BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                                    BorderThickness="1"
                                    CornerRadius="4"
                                    Padding="12"
                                    MinHeight="80">
                                <ScrollViewer VerticalScrollBarVisibility="Auto">
                                    <TextBlock x:Name="TxtGeneratedText"
                                               Text="여기에 생성된 요약 또는 초안이 표시됩니다."
                                               TextWrapping="Wrap"
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                               FontSize="13"
                                               LineHeight="22"/>
                                </ScrollViewer>
                            </Border>

                            <Button x:Name="BtnCopyToClipboard"
                                    Content="클립보드에 복사"
                                    Click="OnCopyToClipboardClick"
                                    HorizontalAlignment="Right"
                                    IsEnabled="False"/>
                        </StackPanel>
                    </Expander.Content>
                </Expander>

                <!-- 저장/취소 -->
                <StackPanel Orientation="Horizontal"
                            Spacing="12"
                            HorizontalAlignment="Right"
                            Margin="0,8,0,0">
                    <Button x:Name="BtnSave"
                            Content="저장"
                            Click="OnSaveClick"
                            Style="{StaticResource AccentButtonStyle}"
                            MinWidth="100"/>
                    <Button x:Name="BtnCancel"
                            Content="취소"
                            Click="OnCancelClick"
                            MinWidth="100"/>
                </StackPanel>

            </StackPanel>
        </ScrollViewer>
    </Border>
</UserControl>

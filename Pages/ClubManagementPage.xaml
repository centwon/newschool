<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="NewSchool.Pages.ClubManagementPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:NewSchool.Models"
    mc:Ignorable="d">

    <Grid Padding="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 헤더 영역 -->
        <Grid Grid.Row="0" Margin="0,0,0,24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- 제목 -->
            <TextBlock 
                Grid.Row="0"
                Text="동아리 관리" 
                FontSize="28" 
                FontWeight="Bold"
                Margin="0,0,0,16"/>

            <!-- 필터 및 버튼 영역 -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- 학년도 필터 -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="12">
                    <ComboBox 
                        x:Name="CBoxYear"
                        Header="학년도"
                        Width="150"
                        SelectionChanged="OnYearChanged"/>
                </StackPanel>

                <!-- 버튼 -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8">
                    <Button 
                        x:Name="BtnAdd"
                        Content="동아리 추가"
                        Style="{StaticResource AccentButtonStyle}"
                        Click="OnAddClick">
                        <Button.KeyboardAccelerators>
                            <KeyboardAccelerator Key="N" Modifiers="Control"/>
                        </Button.KeyboardAccelerators>
                    </Button>
                </StackPanel>
            </Grid>
        </Grid>

        <!-- 컨텐츠 영역 -->
        <Grid Grid.Row="1">
            <!-- 로딩 상태 -->
            <StackPanel 
                x:Name="LoadingState"
                Visibility="Collapsed"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Spacing="12">
                <ProgressRing IsActive="True" Width="48" Height="48"/>
                <TextBlock Text="동아리 목록을 불러오는 중..." FontSize="14"/>
            </StackPanel>

            <!-- 빈 상태 -->
            <StackPanel 
                x:Name="EmptyState"
                Visibility="Collapsed"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Spacing="12">
                <FontIcon 
                    Glyph="&#xE902;" 
                    FontSize="64"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                <TextBlock 
                    Text="등록된 동아리가 없습니다" 
                    FontSize="16"
                    FontWeight="SemiBold"/>
                <TextBlock 
                    Text="[동아리 추가] 버튼을 눌러 새 동아리를 등록하세요" 
                    FontSize="14"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
            </StackPanel>

            <!-- 동아리 목록 -->
            <Grid x:Name="ClubListContainer" Visibility="Collapsed">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- 상태 표시줄 -->
                <Border 
                    Grid.Row="0"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="16,12"
                    Margin="0,0,0,12">
                    <Grid>
                        <TextBlock 
                            x:Name="TxtClubCount"
                            Text="총 0개 동아리"
                            FontSize="14"
                            FontWeight="SemiBold"/>
                    </Grid>
                </Border>

                <!-- 동아리 리스트 -->
                <ListView 
                    Grid.Row="1"
                    x:Name="ClubListView"
                    SelectionMode="None">
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="models:Club">
                            <Border
                                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                BorderThickness="1"
                                CornerRadius="8"
                                Margin="0,0,0,8">
                                <Grid 
                                    Padding="16"
                                    ColumnSpacing="16">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- 동아리 정보 -->
                                    <StackPanel Grid.Column="0" Spacing="8">
                                        <TextBlock 
                                            Text="{x:Bind ClubName}" 
                                            FontSize="16" 
                                            FontWeight="SemiBold"/>
                                        
                                        <StackPanel Orientation="Horizontal" Spacing="16">
                                            <TextBlock FontSize="13">
                                                <Run Text="지도교사:"/>
                                                <Run Text="{x:Bind TeacherID}" FontWeight="SemiBold"/>
                                            </TextBlock>
                                        </StackPanel>

                                        <!-- 활동실 정보 -->
                                        <Border 
                                            Background="{ThemeResource SubtleFillColorSecondaryBrush}"
                                            CornerRadius="4"
                                            Padding="8,4"
                                            HorizontalAlignment="Left"
                                            Visibility="{x:Bind ActivityRoom, Converter={StaticResource StringToVisibilityConverter}}">
                                            <TextBlock FontSize="12">
                                                <Run Text="📍"/>
                                                <Run Text="{x:Bind ActivityRoom}" FontWeight="SemiBold"/>
                                            </TextBlock>
                                        </Border>

                                        <!-- 비고 -->
                                        <TextBlock 
                                            Text="{x:Bind Remark}"
                                            FontSize="12"
                                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                            TextWrapping="Wrap"
                                            Visibility="{x:Bind Remark, Converter={StaticResource StringToVisibilityConverter}}"/>
                                    </StackPanel>

                                    <!-- 버튼 -->
                                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                        <Button 
                                            Content="부원 관리"
                                            Click="OnEnrollClick"
                                            Tag="{x:Bind}"/>

                                        <Button 
                                            Content="수정"
                                            Style="{StaticResource AccentButtonStyle}"
                                            Click="OnEditClick"
                                            Tag="{x:Bind}"/>

                                        <Button Click="OnDeleteClick" Tag="{x:Bind}">
                                            <FontIcon Glyph="&#xE74D;" FontSize="14"/>
                                        </Button>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Grid>
        </Grid>
    </Grid>
</Page>

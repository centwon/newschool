<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="NewSchool.Pages.ClubHomePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:NewSchool.Models"
    mc:Ignorable="d"
    Loaded="Page_Loaded">

    <Grid Padding="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 헤더 -->
        <StackPanel Grid.Row="0" Margin="0,0,0,24">
            <TextBlock Text="동아리 홈" 
                       FontSize="28" 
                       FontWeight="Bold"/>
            <TextBlock x:Name="TxtSubtitle"
                       Text="내 동아리 현황"
                       FontSize="14"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                       Margin="0,4,0,0"/>
        </StackPanel>

        <!-- 메인 컨텐츠 -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="320"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- 좌측: 동아리 정보 및 부원 목록 -->
            <Grid Grid.Column="0" Margin="0,0,16,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- 동아리 선택 -->
                <Border Grid.Row="0"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="16"
                        Margin="0,0,0,16">
                    <StackPanel Spacing="12">
                        <ComboBox x:Name="CBoxClub"
                                  Header="동아리 선택"
                                  HorizontalAlignment="Stretch"
                                  SelectionChanged="CBoxClub_SelectionChanged">
                            <ComboBox.ItemTemplate>
                                <DataTemplate x:DataType="models:Club">
                                    <TextBlock Text="{x:Bind ClubName}"/>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>

                        <StackPanel Spacing="4">
                            <TextBlock x:Name="TxtClubInfo"
                                       FontSize="13"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            <TextBlock x:Name="TxtMemberCount"
                                       FontSize="13"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        </StackPanel>

                        <Button Content="활동 기록"
                                Style="{StaticResource AccentButtonStyle}"
                                HorizontalAlignment="Stretch"
                                Click="OnActivityClick"/>
                    </StackPanel>
                </Border>

                <!-- 부원 목록 -->
                <Border Grid.Row="1"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="8">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- 헤더 -->
                        <Border Grid.Row="0"
                                Background="{ThemeResource LayerFillColorDefaultBrush}"
                                Padding="16,12"
                                CornerRadius="8,8,0,0">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon Glyph="&#xE77B;" FontSize="16"/>
                                <TextBlock Text="부원 명단" FontWeight="SemiBold"/>
                            </StackPanel>
                        </Border>

                        <!-- 부원 리스트 -->
                        <ListView x:Name="MemberListView"
                                  Grid.Row="1"
                                  SelectionMode="None"
                                  Padding="8">
                            <ListView.ItemTemplate>
                                <DataTemplate x:DataType="models:Enrollment">
                                    <Grid Padding="8,4" ColumnSpacing="12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="80"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0"
                                                   FontSize="13"
                                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}">
                                            <Run Text="{x:Bind Grade}"/>-<Run Text="{x:Bind Class}"/>
                                            <Run Text="{x:Bind Number}"/>번
                                        </TextBlock>
                                        <TextBlock Grid.Column="1"
                                                   Text="{x:Bind Name}"
                                                   FontSize="14"/>
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>

                        <!-- 빈 상태 -->
                        <StackPanel x:Name="EmptyMemberState"
                                    Grid.Row="1"
                                    Visibility="Collapsed"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    Spacing="8">
                            <FontIcon Glyph="&#xE77B;" FontSize="48"
                                      Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            <TextBlock Text="등록된 부원이 없습니다"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>

            <!-- 우측: 자료실 (PostListPage 내장) -->
            <Border Grid.Column="1"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="8">
                <Frame x:Name="MaterialFrame"/>
            </Border>
        </Grid>
    </Grid>
</Page>

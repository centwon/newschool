<Page
    x:Class="NewSchool.Pages.SchoolScheduleManagementPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:local="using:NewSchool.Pages"
    xmlns:viewmodels="using:NewSchool.ViewModels"
    mc:Ignorable="d">

    <Grid Padding="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 헤더 -->
        <StackPanel Grid.Row="0" Spacing="8" Margin="0,0,0,24">
            <TextBlock 
                Text="📅 학사일정 관리" 
                Style="{StaticResource TitleTextBlockStyle}"/>
            <TextBlock 
                Text="NEIS 학사일정을 조회하고 관리할 수 있습니다."
                Style="{StaticResource BodyTextBlockStyle}"
                Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
        </StackPanel>

        <!-- 필터 및 버튼 영역 -->
        <Grid Grid.Row="1" 
              Padding="16"
              Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
              BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
              BorderThickness="1"
              CornerRadius="8"
              Margin="0,0,0,16">

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- 첫 번째 행: 필터 -->
            <Grid Grid.Row="0" Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="180"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="180"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- 학년도 -->
                <TextBlock Grid.Column="0" 
                           Text="학년도" 
                           VerticalAlignment="Center" 
                           Margin="0,0,8,0"/>
                <ComboBox x:Name="CBoxYear" 
                          Grid.Column="1" 
                          HorizontalAlignment="Stretch"
                          SelectionChanged="OnYearChanged"/>

                <!-- 시작일 -->
                <TextBlock Grid.Column="3" 
                           Text="시작일" 
                           VerticalAlignment="Center" 
                           Margin="0,0,8,0"/>
                <CalendarDatePicker x:Name="StartDatePicker" 
                                    Grid.Column="4"
                                    HorizontalAlignment="Stretch"
                                    DateChanged="OnDateRangeChanged"/>

                <!-- 종료일 -->
                <TextBlock Grid.Column="6" 
                           Text="종료일" 
                           VerticalAlignment="Center" 
                           Margin="0,0,8,0"/>
                <CalendarDatePicker x:Name="EndDatePicker" 
                                    Grid.Column="7"
                                    HorizontalAlignment="Stretch"
                                    DateChanged="OnDateRangeChanged"/>
            </Grid>

            <!-- 두 번째 행: 버튼들 -->
            <StackPanel Grid.Row="1" 
                        Orientation="Horizontal" 
                        Spacing="8">
                
                <Button x:Name="BtnSearch" 
                        Content="🔍 조회" 
                        Click="OnSearchClick"
                        Style="{StaticResource AccentButtonStyle}"/>

                <Button x:Name="BtnSyncNeis" 
                        Content="🔄 NEIS 동기화" 
                        Click="OnSyncNeisClick"/>

                <Border Width="1" 
                        Background="{ThemeResource DividerStrokeColorDefaultBrush}"
                        Margin="4,0"/>

                <Button x:Name="BtnAddManual" 
                        Content="➕ 수동 추가" 
                        Click="OnAddManualClick"/>

                <Button x:Name="BtnSaveSelected" 
                        Content="💾 저장" 
                        Click="OnSaveSelectedClick"/>

                <Button x:Name="BtnDeleteSelected" 
                        Content="🗑️ 삭제" 
                        Click="OnDeleteSelectedClick"/>

                <Border Width="1" 
                        Background="{ThemeResource DividerStrokeColorDefaultBrush}"
                        Margin="4,0"/>

                <Button x:Name="BtnExport" 
                        Content="📊 Excel 내보내기" 
                        Click="OnExportClick"/>

                <!-- 진행 상태 -->
                <ProgressRing x:Name="LoadingRing" 
                              IsActive="False" 
                              Width="24" 
                              Height="24"
                              Margin="8,0,0,0"/>

                <!-- 상태 텍스트 -->
                <TextBlock x:Name="TxtStatus"
                           VerticalAlignment="Center"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                           Margin="8,0,0,0"/>
            </StackPanel>
        </Grid>

        <!-- 학사일정 목록 영역 -->
        <Border Grid.Row="2"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="8">

            <Grid>
                <!-- 빈 상태 메시지 -->
                <StackPanel x:Name="EmptyState"
                            Visibility="Collapsed"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Spacing="12">
                    <FontIcon Glyph="&#xE787;" 
                              FontSize="48"
                              Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    <TextBlock Text="조회된 학사일정이 없습니다."
                               Style="{StaticResource SubtitleTextBlockStyle}"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    <TextBlock Text="학년도를 선택하고 조회 버튼을 눌러주세요."
                               Style="{StaticResource BodyTextBlockStyle}"
                               Foreground="{ThemeResource TextFillColorTertiaryBrush}"/>
                </StackPanel>

                <!-- 학사일정 ListView -->
                <ScrollViewer x:Name="ScheduleListContainer" 
                              Visibility="Visible">
                    <StackPanel>
                        <!-- 헤더 -->
                        <Grid Background="{ThemeResource SubtleFillColorSecondaryBrush}"
                              Padding="16,12"
                              BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                              BorderThickness="0,0,0,1">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="50"/>   <!-- 체크박스 -->
                                <ColumnDefinition Width="140"/>  <!-- 날짜 -->
                                <ColumnDefinition Width="*"/>    <!-- 행사명/내용 -->
                                <ColumnDefinition Width="100"/>  <!-- 수업공제일 -->
                                <ColumnDefinition Width="240"/>  <!-- 학년 체크박스 -->
                                <ColumnDefinition Width="60"/>   <!-- 수동입력 -->
                            </Grid.ColumnDefinitions>

                            <CheckBox x:Name="ChkSelectAll" 
                                      Grid.Column="0"
                                      Content=""
                                      Click="OnSelectAllClick"
                                      HorizontalAlignment="Center"/>
                            <TextBlock Grid.Column="1" Text="날짜" FontWeight="SemiBold"/>
                            <TextBlock Grid.Column="2" Text="행사명 / 내용" FontWeight="SemiBold"/>
                            <TextBlock Grid.Column="3" Text="수업공제일" FontWeight="SemiBold"/>
                            <TextBlock Grid.Column="4" Text="대상학년" FontWeight="SemiBold"/>
                            <TextBlock Grid.Column="5" Text="구분" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                        </Grid>

                        <!-- ItemsRepeater로 목록 표시 -->
                        <ItemsRepeater x:Name="ScheduleList">
                            <ItemsRepeater.Layout>
                                <StackLayout Spacing="0"/>
                            </ItemsRepeater.Layout>

                            <ItemsRepeater.ItemTemplate>
                                <DataTemplate x:DataType="viewmodels:SchoolScheduleViewModel">
                                    <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                            BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                                            BorderThickness="0,0,0,1"
                                            Padding="16,12">
                                        <Grid ColumnSpacing="12">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="50"/>   <!-- 체크박스 -->
                                                <ColumnDefinition Width="140"/>  <!-- 날짜 -->
                                                <ColumnDefinition Width="*"/>    <!-- 행사명/내용 -->
                                                <ColumnDefinition Width="100"/>  <!-- 수업공제일 -->
                                                <ColumnDefinition Width="240"/>  <!-- 학년 -->
                                                <ColumnDefinition Width="60"/>   <!-- 수동입력 -->
                                            </Grid.ColumnDefinitions>

                                            <!-- 체크박스 -->
                                            <CheckBox Grid.Column="0"
                                                      IsChecked="{x:Bind IsSelected, Mode=TwoWay}"
                                                      HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"/>

                                            <!-- 날짜 -->
                                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                <TextBlock Text="{x:Bind DisplayDate}" 
                                                           FontWeight="SemiBold"
                                                           FontSize="14"
                                                           Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"/>
                                                <TextBlock Text="{x:Bind DisplayDayOfWeek}" 
                                                           FontSize="12"
                                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                            </StackPanel>

                                            <!-- 행사명 및 내용 -->
                                            <StackPanel Grid.Column="2" VerticalAlignment="Center" Spacing="4">
                                                <TextBox Text="{x:Bind EVENT_NM, Mode=TwoWay}"
                                                         FontWeight="Bold"
                                                         FontSize="14"
                                                         BorderThickness="0"
                                                         Background="Transparent"
                                                         Padding="0"/>
                                                <TextBox Text="{x:Bind EVENT_CNTNT, Mode=TwoWay}"
                                                         FontSize="12"
                                                         BorderThickness="0"
                                                         Background="Transparent"
                                                         Padding="0"
                                                         TextWrapping="Wrap"
                                                         AcceptsReturn="True"
                                                         Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                            </StackPanel>

                                            <!-- 수업공제일 -->
                                            <ComboBox Grid.Column="3"
                                                      SelectedValue="{x:Bind SBTR_DD_SC_NM, Mode=TwoWay}"
                                                      HorizontalAlignment="Stretch"
                                                      VerticalAlignment="Center">
                                                <x:String>해당없음</x:String>
                                                <x:String>휴업일</x:String>
                                                <x:String>공휴일</x:String>
                                            </ComboBox>

                                            <!-- 학년 체크박스 -->
                                            <StackPanel Grid.Column="4" 
                                                        Orientation="Horizontal" 
                                                        Spacing="8"
                                                        VerticalAlignment="Center">
                                                <CheckBox Content="1" 
                                                          IsChecked="{x:Bind ONE_GRADE_EVENT_YN, Mode=TwoWay}"
                                                          MinWidth="0"/>
                                                <CheckBox Content="2" 
                                                          IsChecked="{x:Bind TW_GRADE_EVENT_YN, Mode=TwoWay}"
                                                          MinWidth="0"/>
                                                <CheckBox Content="3" 
                                                          IsChecked="{x:Bind THREE_GRADE_EVENT_YN, Mode=TwoWay}"
                                                          MinWidth="0"/>
                                                <CheckBox Content="4" 
                                                          IsChecked="{x:Bind FR_GRADE_EVENT_YN, Mode=TwoWay}"
                                                          MinWidth="0"/>
                                                <CheckBox Content="5" 
                                                          IsChecked="{x:Bind FIV_GRADE_EVENT_YN, Mode=TwoWay}"
                                                          MinWidth="0"/>
                                                <CheckBox Content="6" 
                                                          IsChecked="{x:Bind SIX_GRADE_EVENT_YN, Mode=TwoWay}"
                                                          MinWidth="0"/>
                                            </StackPanel>

                                            <!-- 수동입력/수정 표시 -->
                                            <StackPanel Grid.Column="5"
                                                       Orientation="Horizontal"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"
                                                       Spacing="4">
                                                <TextBlock Text="{x:Bind ManualIcon}"
                                                           FontSize="16"
                                                           ToolTipService.ToolTip="수동 입력"/>
                                                <TextBlock Text="{x:Bind ModifiedIcon, Mode=OneWay}"
                                                           FontSize="16"
                                                           Foreground="{ThemeResource SystemFillColorAttentionBrush}"
                                                           ToolTipService.ToolTip="수정됨 (자동 선택)"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsRepeater.ItemTemplate>
                        </ItemsRepeater>
                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </Border>

        <!-- 상태바 -->
        <Border Grid.Row="3"
                Background="{ThemeResource LayerFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="0,1,0,0"
                Padding="16,8"
                Margin="0,8,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock x:Name="TxtItemCount"
                           Grid.Column="0"
                           Text="총 0개 항목"
                           VerticalAlignment="Center"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>

                <TextBlock x:Name="TxtSelectedCount"
                           Grid.Column="1"
                           Text="선택: 0개"
                           VerticalAlignment="Center"
                           Margin="16,0"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>

                <TextBlock x:Name="TxtLastUpdate"
                           Grid.Column="2"
                           Text=""
                           VerticalAlignment="Center"
                           Foreground="{ThemeResource TextFillColorTertiaryBrush}"/>
            </Grid>
        </Border>
    </Grid>
</Page>

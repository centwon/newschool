<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="NewSchool.Pages.LessonActivityPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:controls="using:NewSchool.Controls"
    xmlns:models="using:NewSchool.Models"
    mc:Ignorable="d"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}"
    Loaded="Page_Loaded"
    Unloaded="Page_Unloaded">

    <Grid Padding="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- InfoBar -->
            <RowDefinition Height="Auto"/>
            <!-- 헤더 -->
            <RowDefinition Height="12"/>
            <RowDefinition Height="*"/>
            <!-- 컨텐츠 -->
        </Grid.RowDefinitions>

        <!-- InfoBar -->
        <InfoBar x:Name="PageInfoBar"
                 Grid.Row="0"
                 IsOpen="False"
                 IsClosable="True"
                 Margin="0,0,0,8"/>

        <!-- ========== 헤더 영역 ========== -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- 필터 영역 -->
            <StackPanel Orientation="Horizontal" Spacing="12">
                <!-- 페이지 제목 -->
                <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                    <FontIcon Glyph="&#xE70F;" FontSize="20"/>
                    <TextBlock Text="수업 활동 기록"
                               Style="{ThemeResource SubtitleTextBlockStyle}"/>
                </StackPanel>

                <AppBarSeparator Margin="4,0"/>

                <!-- 수업 선택 -->
                <ComboBox x:Name="CBoxCourse"
                          Header="수업"
                          MinWidth="150"
                          SelectionChanged="CBoxCourse_SelectionChanged">
                    <ComboBox.ItemTemplate>
                        <DataTemplate x:DataType="models:Course">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <TextBlock Text="{x:Bind Subject}"/>
                                <TextBlock Text="{x:Bind TypeDisplay}"
                                           FontSize="11"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>

                <!-- 강의실 선택 -->
                <ComboBox x:Name="CBoxRoom"
                          Header="강의실"
                          MinWidth="120"
                          SelectionChanged="CBoxRoom_SelectionChanged"/>

                <!-- 수강생 수 표시 -->
                <StackPanel Orientation="Horizontal" 
                            Spacing="4" 
                            VerticalAlignment="Bottom"
                            Margin="8,0,0,0">
                    <FontIcon Glyph="&#xE77B;" FontSize="14" 
                              Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    <TextBlock x:Name="TxtStudentCount"
                               Text="0명"
                               FontSize="13"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                               VerticalAlignment="Center"/>
                </StackPanel>
            </StackPanel>

            <!-- 액션 버튼 -->
            <StackPanel Grid.Column="1" 
                        Orientation="Horizontal" 
                        Spacing="4"
                        VerticalAlignment="Bottom">
                <Button x:Name="BtnBatchInput"
                        Click="BtnBatchInput_Click"
                        ToolTipService.ToolTip="수강생 일괄 기록 입력">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon Glyph="&#xE8B3;" FontSize="16"/>
                        <TextBlock Text="일괄입력" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <Button x:Name="BtnAddLog"
                        Click="BtnAddLog_Click"
                        ToolTipService.ToolTip="활동 기록 추가">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon Glyph="&#xE710;" FontSize="16"/>
                        <TextBlock Text="추가" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <Button x:Name="BtnEditLog"
                        Click="BtnEditLog_Click"
                        ToolTipService.ToolTip="선택된 기록 전체 편집">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon Glyph="&#xE70F;" FontSize="16"/>
                        <TextBlock Text="편집" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <Button x:Name="BtnSaveLog"
                        Click="BtnSaveLog_Click"
                        ToolTipService.ToolTip="저장"
                        Style="{ThemeResource AccentButtonStyle}">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon Glyph="&#xE74E;" FontSize="16"/>
                        <TextBlock Text="저장" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <AppBarSeparator Margin="8,0"/>

                <Button x:Name="BtnRefresh"
                        Click="BtnRefresh_Click"
                        ToolTipService.ToolTip="새로고침">
                    <FontIcon Glyph="&#xE72C;" FontSize="16"/>
                </Button>

                <AppBarSeparator Margin="8,0"/>

                <Button x:Name="BtnDeleteLog"
                        Click="BtnDeleteLog_Click"
                        ToolTipService.ToolTip="삭제">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon Glyph="&#xE74D;" FontSize="16"/>
                        <TextBlock Text="삭제" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </StackPanel>
        </Grid>

        <!-- ========== 메인 컨텐츠 ========== -->
        <Grid Grid.Row="3">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220"/>
                <!-- 학생 목록 -->
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="*"/>
                <!-- 활동 기록 -->
            </Grid.ColumnDefinitions>

            <!-- ========== 학생 목록 ========== -->
            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- 헤더 -->
                <Border Grid.Row="0"
                        Background="{ThemeResource LayerFillColorDefaultBrush}"
                        Padding="12,8"
                        CornerRadius="8,8,0,0"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1,1,1,0">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon Glyph="&#xE77B;" FontSize="14"/>
                        <TextBlock Text="수강생"
                                   FontWeight="SemiBold"
                                   FontSize="13"/>
                    </StackPanel>
                </Border>

                <!-- ListStudent 컨트롤 -->
                <controls:ListStudent x:Name="StudentList"
                                      Grid.Row="1"
                                      ViewMode="NumName"/>
            </Grid>

            <!-- ========== 활동 기록 ========== -->
            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- LogListViewer (헤더 내장) -->
                <controls:LogListViewer x:Name="LogList"
                                        Grid.Row="0"
                                        StudentInfoMode="HideAll"/>

                <!-- 학생부 기록 (StudentSpecBox) -->
                <controls:StudentSpecBox x:Name="SpecBox"
                                         Grid.Row="1"
                                         Height="180"
                                         Margin="0,12,0,0"
                                         Visibility="Collapsed"/>
            </Grid>
        </Grid>
    </Grid>
</Page>

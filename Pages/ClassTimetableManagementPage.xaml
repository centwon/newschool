<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="NewSchool.Pages.ClassTimetableManagementPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:controls="using:NewSchool.Controls"
    mc:Ignorable="d">

    <Grid Padding="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 헤더 영역 -->
        <StackPanel Grid.Row="0" Spacing="16" Margin="0,0,0,24">
            <TextBlock 
                Text="학급 시간표 관리" 
                FontSize="28" 
                FontWeight="Bold"/>

            <!-- 필터 -->
            <StackPanel Orientation="Horizontal" Spacing="12">
                <controls:SchoolFilterPicker 
                    x:Name="FilterPicker"
                    ShowSemester="True"
                    IncludeAllGrade="False"
                    IncludeAllClass="False"/>

                <!-- 조회 버튼 -->
                <Button 
                    Content="조회"
                    Style="{StaticResource AccentButtonStyle}"
                    Click="OnLoadClick"
                    VerticalAlignment="Center"
                    MinWidth="100"/>
            </StackPanel>
        </StackPanel>

        <!-- 컨텐츠 영역 -->
        <Grid Grid.Row="1">
            <!-- 빈 상태 -->
            <StackPanel 
                x:Name="EmptyState"
                Visibility="Visible"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Spacing="12">
                <FontIcon 
                    Glyph="&#xE8F4;" 
                    FontSize="64"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                <TextBlock 
                    Text="학급을 선택하고 [조회] 버튼을 눌러주세요" 
                    FontSize="14"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
            </StackPanel>

            <!-- 시간표 그리드 -->
            <ScrollViewer 
                x:Name="TimetableContainer"
                Visibility="Collapsed">
                <StackPanel Spacing="16">
                    <!-- 제목 및 버튼 -->
                    <Grid>
                        <TextBlock 
                            x:Name="TxtTitle"
                            FontSize="20" 
                            FontWeight="SemiBold"
                            VerticalAlignment="Center"/>
                        
                        <StackPanel 
                            HorizontalAlignment="Right"
                            Orientation="Horizontal"
                            Spacing="8">
                            <Button 
                                Content="시간표 편집"
                                Style="{StaticResource AccentButtonStyle}"
                                Click="OnEditClick"/>
                            <Button 
                                Content="시간표 삭제"
                                Click="OnDeleteClick"/>
                        </StackPanel>
                    </Grid>

                    <!-- 시간표 -->
                    <Border 
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="16">
                        <Grid x:Name="TimetableGrid">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="80"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="50"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <!-- 헤더 -->
                            <Border Grid.Row="0" Grid.Column="0" 
                                    Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
                                    BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                                    BorderThickness="0,0,1,1">
                                <TextBlock Text="교시" 
                                          HorizontalAlignment="Center" 
                                          VerticalAlignment="Center"
                                          FontWeight="SemiBold"/>
                            </Border>

                            <Border Grid.Row="0" Grid.Column="1" 
                                    Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
                                    BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                                    BorderThickness="0,0,1,1">
                                <TextBlock Text="월" 
                                          HorizontalAlignment="Center" 
                                          VerticalAlignment="Center"
                                          FontWeight="SemiBold"/>
                            </Border>

                            <Border Grid.Row="0" Grid.Column="2" 
                                    Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
                                    BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                                    BorderThickness="0,0,1,1">
                                <TextBlock Text="화" 
                                          HorizontalAlignment="Center" 
                                          VerticalAlignment="Center"
                                          FontWeight="SemiBold"/>
                            </Border>

                            <Border Grid.Row="0" Grid.Column="3" 
                                    Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
                                    BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                                    BorderThickness="0,0,1,1">
                                <TextBlock Text="수" 
                                          HorizontalAlignment="Center" 
                                          VerticalAlignment="Center"
                                          FontWeight="SemiBold"/>
                            </Border>

                            <Border Grid.Row="0" Grid.Column="4" 
                                    Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
                                    BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                                    BorderThickness="0,0,1,1">
                                <TextBlock Text="목" 
                                          HorizontalAlignment="Center" 
                                          VerticalAlignment="Center"
                                          FontWeight="SemiBold"/>
                            </Border>

                            <Border Grid.Row="0" Grid.Column="5" 
                                    Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
                                    BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                                    BorderThickness="0,0,0,1">
                                <TextBlock Text="금" 
                                          HorizontalAlignment="Center" 
                                          VerticalAlignment="Center"
                                          FontWeight="SemiBold"/>
                            </Border>

                            <!-- 시간표 셀들 (동적 생성) -->
                        </Grid>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Grid>
</Page>

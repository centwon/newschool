<Page
    x:Class="NewSchool.Pages.ClassDiaryPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:controls="using:NewSchool.Controls"
    mc:Ignorable="d"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="160"/>
            <!-- 학생 목록 -->
            <ColumnDefinition Width="*"/>
            <!-- 일지 -->
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- 헤더 -->
            <RowDefinition Height="Auto"/>
            <!-- 메인 -->
            <RowDefinition Height="*"/>
            <!-- 당일 학생 기록 -->
        </Grid.RowDefinitions>

        <!-- ========================== -->
        <!-- 상단 헤더 (학년도/학년/반/날짜) -->
        <!-- ========================== -->
        <Grid Grid.Row="0" Grid.ColumnSpan="2"
              Padding="4,3"
              Background="{ThemeResource LayerFillColorDefaultBrush}"
              BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
              BorderThickness="0,0,0,1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- 학년도/학년/반 필터 -->
            <StackPanel Orientation="Horizontal" Spacing="8">
                <controls:YearSemesterPicker
                    x:Name="YearSemPicker"
                    ShowSemester="False"
                    YearSemesterChanged="YearSemPicker_YearSemesterChanged"/>
                <controls:ClassPicker
                    x:Name="ClassFilter"
                    IncludeAllClass="False"
                    AutoLoad="False"
                    ClassChanged="ClassFilter_ClassChanged"/>
            </StackPanel>

            <!-- 날짜 선택 -->
            <Grid Grid.Column="1" Margin="16,0,16,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Button x:Name="BtnDatePrev"
                        Grid.Column="0"
                        Click="BtnDatePrev_Click"
                        Background="Transparent"
                        BorderThickness="0">
                    <FontIcon Glyph="&#xE76B;" FontSize="16"/>
                </Button>

                <CalendarDatePicker x:Name="DatePicker"
                                    Grid.Column="1"
                                    MinWidth="220"
                                    Margin="4,0"
                                    DateFormat="{}{year.full}년 {month.integer}월 {day.integer}일 {dayofweek.full}"
                                    DateChanged="DatePicker_DateChanged"/>

                <Button x:Name="BtnDateNext"
                        Grid.Column="2"
                        Click="BtnDateNext_Click"
                        Background="Transparent"
                        BorderThickness="0">
                    <FontIcon Glyph="&#xE76C;" FontSize="16"/>
                </Button>
            </Grid>

            <!-- 일지 목록 보기 -->
            <Button x:Name="BtnViewDiaryList"
                    Grid.Column="3"
                    Click="BtnViewDiaryList_Click"
                    Style="{ThemeResource AccentButtonStyle}"
                    Padding="16,4" VerticalAlignment="Center" Margin="4,4,20,4">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <FontIcon Glyph="&#xE8FD;" FontSize="12"/>
                    <TextBlock Text="목록 보기"/>
                </StackPanel>
            </Button>
        </Grid>

        <!-- ========================== -->
        <!-- 학생 목록 (좌측) -->
        <!-- ========================== -->
        <controls:ListStudent x:Name="StudentList"
                              Grid.Row="1" Grid.RowSpan="2"
                              Grid.Column="0"
                              Margin="4,4,4,4"/>

        <!-- ========================== -->
        <!-- 일지 입력 (중앙) -->
        <!-- ========================== -->
        <controls:ClassDiaryBox x:Name="DiaryBox" Grid.Row="1" Grid.Column="1" Margin="4,4,4,4"/>

        <!-- ========================== -->
        <!-- 당일 학생 기록 (하단) -->
        <!-- ========================== -->
        <Grid Grid.Row="2" Grid.Column="1" Margin="4,0,4,4">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- 헤더 -->
            <Grid Grid.Row="0" Padding="8,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <FontIcon Glyph="&#xE762;" FontSize="14" VerticalAlignment="Center" Margin="0,0,6,0"/>
                <TextBlock Grid.Column="1" x:Name="TxtDailyLogTitle"
                           Text="당일 학생 기록"
                           FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center"/>
                <TextBlock Grid.Column="2" x:Name="TxtDailyLogCount"
                           Text=""
                           FontSize="12" VerticalAlignment="Center" Margin="8,0,0,0"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>

                <StackPanel Grid.Column="3" Orientation="Horizontal" Spacing="2">
                    <Button x:Name="BtnAddDailyLog"
                            Click="BtnAddDailyLog_Click"
                            Style="{ThemeResource AccentButtonStyle}"
                            Padding="10,4"
                            ToolTipService.ToolTip="학생 기록 추가">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <FontIcon Glyph="&#xE710;" FontSize="12"/>
                            <TextBlock Text="추가" FontSize="12"/>
                        </StackPanel>
                    </Button>
                    <Button x:Name="BtnRefreshLogs"
                            Click="BtnRefreshLogs_Click"
                            Background="Transparent" BorderThickness="0"
                            ToolTipService.ToolTip="새로고침" Padding="6,4">
                        <FontIcon Glyph="&#xE72C;" FontSize="12"/>
                    </Button>
                </StackPanel>
            </Grid>

            <!-- 학생 기록 목록 -->
            <controls:LogListViewer x:Name="DailyLogList"
                                    Grid.Row="1"/>
        </Grid>
    </Grid>
</Page>

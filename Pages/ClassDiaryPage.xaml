<Page
    x:Class="NewSchool.Pages.ClassDiaryPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:controls="using:NewSchool.Controls"
    mc:Ignorable="d"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="160"/>
            <!-- 학생 목록 -->
            <ColumnDefinition Width="*"/>
            <!-- 일지 -->
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- 헤더 -->
            <RowDefinition Height="Auto"/>
            <!-- 메인 -->
            <RowDefinition Height="*"/>
            <!-- 게시판 (PostListPage) -->
        </Grid.RowDefinitions>

        <!-- ========================== -->
        <!-- 상단 헤더 (학년도/학년/반/날짜) -->
        <!-- ========================== -->
        <Grid Grid.Row="0" Grid.ColumnSpan="2"
              Padding="4,3"
              Background="{ThemeResource LayerFillColorDefaultBrush}"
              BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
              BorderThickness="0,0,0,1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- 학년도/학년/반 필터 -->
            <controls:SchoolFilterPicker
                x:Name="FilterPicker"
                ShowSemester="False"
                IncludeAllGrade="False"
                IncludeAllClass="False"
                SelectionChanged="FilterPicker_SelectionChanged"/>

            <!-- 날짜 선택 -->
            <Grid Grid.Column="1" Margin="16,0,16,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Button x:Name="BtnDatePrev"
                        Grid.Column="0"
                        Click="BtnDatePrev_Click"
                        Background="Transparent"
                        BorderThickness="0">
                    <FontIcon Glyph="&#xE76B;" FontSize="16"/>
                </Button>

                <CalendarDatePicker x:Name="DatePicker"
                                    Grid.Column="1"
                                    MinWidth="180"
                                    Margin="4,0"
                                    DateChanged="DatePicker_DateChanged"/>

                <Button x:Name="BtnDateNext"
                        Grid.Column="2"
                        Click="BtnDateNext_Click"
                        Background="Transparent"
                        BorderThickness="0">
                    <FontIcon Glyph="&#xE76C;" FontSize="16"/>
                </Button>
            </Grid>

            <!-- 일지 목록 보기 -->
            <Button x:Name="BtnViewDiaryList"
                    Grid.Column="3"
                    Click="BtnViewDiaryList_Click"
                    Style="{ThemeResource AccentButtonStyle}"
                    Padding="16,4" VerticalAlignment="Center" Margin="4,4,20,4">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <FontIcon Glyph="&#xE8FD;" FontSize="12"/>
                    <TextBlock Text="목록 보기"/>
                </StackPanel>
            </Button>
        </Grid>

        <!-- ========================== -->
        <!-- 학생 목록 (좌측) -->
        <!-- ========================== -->
        <controls:ListStudent x:Name="StudentList"
                              Grid.Row="1" Grid.RowSpan="2"
                              Grid.Column="0"
                              Margin="4,4,4,4"/>

        <!-- ========================== -->
        <!-- 일지 입력 (중앙) -->
        <!-- ========================== -->
        <controls:ClassDiaryBox x:Name="DiaryBox" Grid.Row="1" Grid.Column="1" Margin="4,4,4,4"/>

        <!-- ========================== -->
        <!-- 학급 게시판 (PostListPage 내장, 하단 전체) -->
        <!-- ========================== -->
        <Border Grid.Row="2" Grid.Column="1"
                Margin="16"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="8"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
            <Frame x:Name="BoardFrame"/>
        </Border>
    </Grid>
</Page>

<Page
    x:Class="NewSchool.Pages.PageSchoolWork"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:scheduler="using:NewSchool.Scheduler"
    xmlns:board="using:NewSchool.Board.Controls"
    mc:Ignorable="d"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}"
    Loaded="Page_Loaded">

    <Grid Padding="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- 페이지 헤더 -->
            <RowDefinition Height="*"/>     <!-- 메인 콘텐츠 -->
        </Grid.RowDefinitions>

        <!-- 페이지 헤더: 날짜 표시 -->
        <StackPanel Grid.Row="0"
                    Orientation="Horizontal"
                    Spacing="10"
                    Margin="4,0,0,8">
            <FontIcon Glyph="&#xE821;" FontSize="16"
                      VerticalAlignment="Center"/>
            <TextBlock x:Name="TxtPageDate"
                       FontSize="16"
                       FontWeight="SemiBold"
                       VerticalAlignment="Center"/>
        </StackPanel>

        <!-- 메인: 좌(할 일 + 메모) + 우(업무 게시판) -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="400"/>   <!-- 좌측 사이드바 -->
                <ColumnDefinition Width="*"/>     <!-- 우측 게시판 -->
            </Grid.ColumnDefinitions>

            <!-- 좌측: 할 일 목록 + 메모 보드 -->
            <Grid Grid.Column="0" Margin="0,0,8,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>  <!-- 할 일 목록 -->
                    <RowDefinition Height="*"/>     <!-- 메모 보드 -->
                </Grid.RowDefinitions>

                <!-- 할 일 목록 (업무 카테고리 고정) -->
                <scheduler:KAgendaControl x:Name="AgendaControl"
                                           Grid.Row="0"
                                           FixedCalendarName="업무"
                                           Margin="0,0,0,8"/>

                <!-- 메모 보드 (업무 카테고리 고정, 필터 숨김) -->
                <board:MemoBoard x:Name="WorkMemoBoard"
                                  Grid.Row="1"
                                  ShowFilter="False"
                                  FixedCategory="업무"/>
            </Grid>

            <!-- 우측: 업무 게시판 (PostListPage 임베드) -->
            <Border Grid.Column="1"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                <Frame x:Name="BoardFrame"/>
            </Border>
        </Grid>
    </Grid>
</Page>

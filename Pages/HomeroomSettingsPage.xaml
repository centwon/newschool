<Page
    x:Class="NewSchool.Pages.HomeroomSettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid>
        <ScrollViewer VerticalScrollMode="Enabled">
            <StackPanel Spacing="4" Padding="40,40,40,40" MaxWidth="1000" HorizontalAlignment="Center">

                <TextBlock
                    Text="담임반 설정"
                    Style="{StaticResource TitleTextBlockStyle}"
                    Margin="0,0,0,20"/>

                <Expander Header="담임반 정보" IsExpanded="True" HorizontalAlignment="Stretch" Margin="0,0,0,8">
                    <Expander.Content>
                        <StackPanel Spacing="12" Padding="16">

                            <Grid ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <NumberBox
                                    x:Name="HomeGradeNumberBox"
                                    Grid.Column="0"
                                    Header="담임 학년"
                                    PlaceholderText="학년"
                                    SpinButtonPlacementMode="Inline"
                                    Minimum="0"
                                    Maximum="6"
                                    ValueChanged="OnHomeGradeChanged"/>

                                <NumberBox
                                    x:Name="HomeRoomNumberBox"
                                    Grid.Column="1"
                                    Header="담임 반"
                                    PlaceholderText="반"
                                    SpinButtonPlacementMode="Inline"
                                    Minimum="0"
                                    Maximum="30"
                                    ValueChanged="OnHomeRoomChanged"/>
                            </Grid>

                            <TextBox
                                x:Name="UserNameTextBox"
                                Header="사용자 이름"
                                PlaceholderText="교사 이름"
                                LostFocus="OnUserNameChanged"/>

                        </StackPanel>
                    </Expander.Content>
                </Expander>

                <Border Height="40"/>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>

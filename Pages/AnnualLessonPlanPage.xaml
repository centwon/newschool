<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="NewSchool.Pages.AnnualLessonPlanPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:NewSchool.Models"
    xmlns:vm="using:NewSchool.ViewModels"
    xmlns:local="using:NewSchool.Pages"
    mc:Ignorable="d">

    <Grid Padding="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 헤더 영역 -->
        <Grid Grid.Row="0" Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Spacing="4">
                <TextBlock
                    Text="연간수업계획"
                    FontSize="28"
                    FontWeight="Bold"/>
                <TextBlock
                    x:Name="TxtSubtitle"
                    Text="수업을 선택하여 연간수업계획을 작성하세요"
                    FontSize="14"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
            </StackPanel>

            <!-- 과목 선택 (헤더에 배치) -->
            <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                <TextBlock Text="수업" VerticalAlignment="Center" FontWeight="SemiBold"/>
                <ComboBox
                    x:Name="CmbCourse"
                    Width="200"
                    PlaceholderText="수업 선택"
                    SelectionChanged="OnCourseSelectionChanged">
                    <ComboBox.ItemTemplate>
                        <DataTemplate x:DataType="models:Course">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <TextBlock Text="{x:Bind Subject}"/>
                                <TextBlock Text="{x:Bind Grade}" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                <TextBlock Text="학년" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            </StackPanel>
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>
            </StackPanel>

            <!-- 숨김 처리된 기존 컨트롤들 -->
            <ComboBox x:Name="CmbYear" Visibility="Collapsed"/>
            <ComboBox x:Name="CmbSemester" Visibility="Collapsed"/>
            <ListView x:Name="CourseListView" Visibility="Collapsed"/>
            <ListView x:Name="TargetClassListView" Visibility="Collapsed"/>
        </Grid>

        <!-- 메인 컨텐츠 -->
        <Grid Grid.Row="1">
            <!-- 로딩 오버레이 -->
            <Grid
                x:Name="LoadingOverlay"
                Visibility="Collapsed"
                Background="{ThemeResource AcrylicBackgroundFillColorDefaultBrush}"
                Canvas.ZIndex="100">
                <StackPanel
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Spacing="16">
                    <ProgressRing IsActive="True" Width="48" Height="48"/>
                    <TextBlock
                        x:Name="TxtLoading"
                        Text="로딩 중..."
                        FontSize="14"/>
                </StackPanel>
            </Grid>

            <!-- Pivot 기반 탭 UI -->
            <Pivot x:Name="MainPivot">
                <!-- 탭 1: 단원 관리 (CourseSectionDialog 통합) -->
                <PivotItem Header="단원 관리">
                    <Grid Margin="0,16,0,0">
                        <Grid.Resources>
                            <Flyout x:Name="ImportConfirmFlyout">
                                <StackPanel Spacing="12" Width="300">
                                    <TextBlock x:Name="TxtImportConfirm" Text="" TextWrapping="Wrap"/>
                                    <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right">
                                        <Button Content="취소" Click="OnImportCancelClick"/>
                                        <Button Content="가져오기" Style="{StaticResource AccentButtonStyle}" Click="OnImportConfirmClick"/>
                                    </StackPanel>
                                </StackPanel>
                            </Flyout>
                        </Grid.Resources>

                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <!-- 도구 모음 -->
                            <RowDefinition Height="Auto"/>
                            <!-- 헤더 행 -->
                            <RowDefinition Height="*"/>
                            <!-- 단원 목록 -->
                            <RowDefinition Height="Auto"/>
                            <!-- 하단 통계 -->
                        </Grid.RowDefinitions>

                        <!-- 도구 모음 -->
                        <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="8" Margin="0,0,0,12">
                            <Button x:Name="BtnImportCsv" Click="OnImportCsvClick">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <FontIcon Glyph="&#xE8E5;" FontSize="14"/>
                                    <TextBlock Text="CSV 가져오기"/>
                                </StackPanel>
                            </Button>
                            <Button Click="OnExportCsvClick">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <FontIcon Glyph="&#xEDE1;" FontSize="14"/>
                                    <TextBlock Text="CSV 내보내기"/>
                                </StackPanel>
                            </Button>
                            <Button Click="OnDownloadTemplateClick">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <FontIcon Glyph="&#xE896;" FontSize="14"/>
                                    <TextBlock Text="템플릿 다운로드"/>
                                </StackPanel>
                            </Button>
                            <Border Width="1" Background="{ThemeResource DividerStrokeColorDefaultBrush}" Margin="8,4"/>
                            <Button x:Name="BtnAddSection" Click="OnAddSectionClick" Style="{StaticResource AccentButtonStyle}">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <FontIcon Glyph="&#xE710;" FontSize="14"/>
                                    <TextBlock Text="소단원 추가"/>
                                </StackPanel>
                            </Button>
                            <Button x:Name="BtnClearAll" Click="OnClearAllClick">
                                <Button.Flyout>
                                    <Flyout x:Name="ClearAllFlyout">
                                        <StackPanel Spacing="12" Width="250">
                                            <TextBlock x:Name="TxtClearConfirm" Text="모든 단원을 삭제하시겠습니까?" TextWrapping="Wrap"/>
                                            <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right">
                                                <Button Content="취소" Click="OnClearAllCancelClick"/>
                                                <Button Content="삭제" Style="{StaticResource AccentButtonStyle}" Click="OnClearAllConfirmClick"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </Flyout>
                                </Button.Flyout>
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <FontIcon Glyph="&#xE74D;" FontSize="14"/>
                                    <TextBlock Text="전체 삭제"/>
                                </StackPanel>
                            </Button>
                            <Border Width="1" Background="{ThemeResource DividerStrokeColorDefaultBrush}" Margin="8,4"/>
                            <Button Click="OnExportExcelClick">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <FontIcon Glyph="&#xF000;" FontSize="14"/>
                                    <TextBlock Text="엑셀 내보내기"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>

                        <!-- 단원 목록 헤더 -->
                        <Grid x:Name="SectionListHeader"
                              Grid.Row="1"
                              Visibility="Collapsed"
                              Background="{ThemeResource SubtleFillColorSecondaryBrush}"
                              Padding="8,6"
                              ColumnSpacing="8"
                              Margin="0,0,0,0"
                              CornerRadius="4,4,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="40"/>
                                <!-- 연번 -->
                                <ColumnDefinition Width="70"/>
                                <!-- 단원번호 -->
                                <ColumnDefinition Width="*"/>
                                <!-- 소단원명 -->
                                <ColumnDefinition Width="60"/>
                                <!-- 유형 -->
                                <ColumnDefinition Width="60"/>
                                <!-- 페이지 -->
                                <ColumnDefinition Width="50"/>
                                <!-- 시수 -->
                                <ColumnDefinition Width="36"/>
                                <!-- 삭제 버튼 공간 -->
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="연번" FontSize="12" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                            <TextBlock Grid.Column="1" Text="단원번호" FontSize="12" FontWeight="SemiBold"/>
                            <TextBlock Grid.Column="2" Text="소단원명" FontSize="12" FontWeight="SemiBold"/>
                            <TextBlock Grid.Column="3" Text="유형" FontSize="12" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                            <TextBlock Grid.Column="4" Text="페이지" FontSize="12" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                            <TextBlock Grid.Column="5" Text="시수" FontSize="12" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                        </Grid>

                        <!-- 단원 목록 (ListView) -->
                        <Border Grid.Row="2"
                                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                BorderThickness="1"
                                CornerRadius="0,0,4,4">
                            <Grid>
                                <!-- 빈 상태 -->
                                <StackPanel x:Name="SectionEmptyState"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center"
                                            Spacing="8">
                                    <FontIcon Glyph="&#xE8A5;" FontSize="48" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                    <TextBlock Text="등록된 단원이 없습니다"
                                               HorizontalAlignment="Center"
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                    <TextBlock Text="CSV 파일을 가져오거나 소단원을 추가하세요"
                                               FontSize="12"
                                               HorizontalAlignment="Center"
                                               Foreground="{ThemeResource TextFillColorTertiaryBrush}"/>
                                </StackPanel>

                                <!-- ListView -->
                                <ListView x:Name="SectionListView"
                                          Visibility="Collapsed"
                                          SelectionMode="Single"
                                          IsItemClickEnabled="True"
                                          ItemClick="OnSectionItemClick"
                                          CanDragItems="True"
                                          CanReorderItems="True"
                                          AllowDrop="True"
                                          ReorderMode="Enabled"
                                          DragItemsCompleted="OnSectionDragCompleted"
                                          ContainerContentChanging="OnSectionContainerContentChanging"
                                          Margin="4">
                                    <ListView.ItemTemplate>
                                        <DataTemplate x:DataType="models:CourseSection">
                                            <Grid Padding="8,4" ColumnSpacing="8" ToolTipService.ToolTip="클릭하여 편집">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="40"/>
                                                    <!-- 연번 -->
                                                    <ColumnDefinition Width="70"/>
                                                    <!-- 단원번호 -->
                                                    <ColumnDefinition Width="*"/>
                                                    <!-- 소단원명 -->
                                                    <ColumnDefinition Width="60"/>
                                                    <!-- 유형 -->
                                                    <ColumnDefinition Width="60"/>
                                                    <!-- 페이지 -->
                                                    <ColumnDefinition Width="50"/>
                                                    <!-- 시수 -->
                                                    <ColumnDefinition Width="Auto"/>
                                                    <!-- 삭제 -->
                                                </Grid.ColumnDefinitions>

                                                <!-- 연번 (동적 업데이트) -->
                                                <TextBlock Grid.Column="0"
                                                           Text=""
                                                           FontSize="12"
                                                           Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"/>

                                                <!-- 단원번호 (1.1.1 형식) -->
                                                <TextBlock Grid.Column="1"
                                                           Text="{x:Bind FullPath}"
                                                           FontSize="12"
                                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                           VerticalAlignment="Center"/>

                                                <!-- 소단원명 -->
                                                <TextBlock Grid.Column="2"
                                                           Text="{x:Bind SectionName}"
                                                           FontSize="13"
                                                           TextTrimming="CharacterEllipsis"
                                                           VerticalAlignment="Center"/>

                                                <!-- 유형 -->
                                                <TextBlock Grid.Column="3"
                                                           Text="{x:Bind SectionTypeDisplay}"
                                                           FontSize="11"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"
                                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>

                                                <!-- 페이지 -->
                                                <TextBlock Grid.Column="4"
                                                           Text="{x:Bind PageRangeDisplay}"
                                                           FontSize="11"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"/>

                                                <!-- 시수 -->
                                                <TextBlock Grid.Column="5"
                                                           Text="{x:Bind HoursDisplay}"
                                                           FontSize="12"
                                                           FontWeight="SemiBold"
                                                           Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"/>

                                                <!-- 삭제 버튼 -->
                                                <Button Grid.Column="6"
                                                        Click="OnDeleteSectionClick"
                                                        Tag="{x:Bind}"
                                                        Padding="4"
                                                        Background="Transparent"
                                                        BorderThickness="0">
                                                    <FontIcon Glyph="&#xE74D;" FontSize="11"/>
                                                </Button>
                                            </Grid>
                                        </DataTemplate>
                                    </ListView.ItemTemplate>
                                </ListView>
                            </Grid>
                        </Border>

                        <!-- 하단: 통계 + 다음 버튼 -->
                        <Grid Grid.Row="3" Margin="0,12,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" Spacing="4">
                                <TextBlock x:Name="TxtSectionStatistics"
                                           FontSize="12"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                           VerticalAlignment="Center"/>
                                <InfoBar x:Name="SectionErrorInfoBar"
                                         IsOpen="False"
                                         Severity="Error"
                                         IsClosable="True"/>
                            </StackPanel>

                            <Button Grid.Column="1"
                                    Content="다음: 시수 계획 →"
                                    Style="{StaticResource AccentButtonStyle}"
                                    Click="OnGoToHoursTabClick"/>
                        </Grid>
                    </Grid>
                </PivotItem>

                <!-- 탭 2: 시수 관리 -->
                <PivotItem Header="시수 관리">
                    <Grid Margin="0,16,0,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- 상단 정보 카드: 시간표 + 학사일정 요약 -->
                        <Grid Grid.Row="0" Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <!-- 시간표 정보 -->
                            <Border Grid.Column="0"
                                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                    BorderThickness="1"
                                    CornerRadius="8"
                                    Padding="16"
                                    Margin="0,0,8,0">
                                <StackPanel Spacing="8">
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <FontIcon Glyph="&#xE787;" FontSize="16" Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"/>
                                        <TextBlock Text="시간표 정보" FontWeight="SemiBold"/>
                                    </StackPanel>
                                    <TextBlock x:Name="TxtTimetableInfo"
                                               Text="수업을 선택하세요"
                                               FontSize="12"
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                               TextWrapping="Wrap"/>
                                    <ItemsControl x:Name="TimetableItemsControl">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Background="{ThemeResource SubtleFillColorSecondaryBrush}"
                                                        CornerRadius="4"
                                                        Padding="8,4"
                                                        Margin="0,2">
                                                    <TextBlock Text="{Binding}" FontSize="11"/>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <StackPanel Orientation="Horizontal" Spacing="4"/>
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>

                            <!-- 학사일정 정보 (NEIS 데이터포털) -->
                            <Border Grid.Column="1"
                                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                    BorderThickness="1"
                                    CornerRadius="8"
                                    Padding="16"
                                    Margin="8,0">
                                <StackPanel Spacing="8">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8">
                                            <FontIcon Glyph="&#xE8BF;" FontSize="16" Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"/>
                                            <TextBlock Text="NEIS 학사일정" FontWeight="SemiBold"/>
                                        </StackPanel>
                                        <Button Grid.Column="1" 
                                                x:Name="BtnRefreshSchedule"
                                                Click="OnRefreshScheduleClick"
                                                ToolTipService.ToolTip="NEIS에서 학사일정 새로고침"
                                                Padding="6"
                                                Background="Transparent"
                                                BorderThickness="0">
                                            <FontIcon Glyph="&#xE72C;" FontSize="12"/>
                                        </Button>
                                    </Grid>
                                    <TextBlock x:Name="TxtScheduleInfo"
                                               Text="학사일정을 불러오는 중..."
                                               FontSize="12"
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                               TextWrapping="Wrap"/>
                                </StackPanel>
                            </Border>

                            <!-- 통계 요약 -->
                            <Border Grid.Column="2"
                                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                    BorderThickness="1"
                                    CornerRadius="8"
                                    Padding="16">
                                <StackPanel Orientation="Horizontal" Spacing="20">
                                    <StackPanel HorizontalAlignment="Center">
                                        <TextBlock
                                            x:Name="TxtTotalWeeks"
                                            Text="0주"
                                            FontSize="20"
                                            FontWeight="Bold"
                                            HorizontalAlignment="Center"/>
                                        <TextBlock
                                            Text="총 주차"
                                            FontSize="11"
                                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                            HorizontalAlignment="Center"/>
                                    </StackPanel>
                                    <StackPanel HorizontalAlignment="Center">
                                        <TextBlock
                                            x:Name="TxtTotalClassDays"
                                            Text="0일"
                                            FontSize="20"
                                            FontWeight="Bold"
                                            HorizontalAlignment="Center"/>
                                        <TextBlock
                                            Text="수업일"
                                            FontSize="11"
                                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                            HorizontalAlignment="Center"/>
                                    </StackPanel>
                                    <StackPanel HorizontalAlignment="Center">
                                        <TextBlock
                                            x:Name="TxtAutoHours"
                                            Text="0"
                                            FontSize="20"
                                            FontWeight="Bold"
                                            Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"
                                            HorizontalAlignment="Center"/>
                                        <TextBlock
                                            Text="총 시수"
                                            FontSize="11"
                                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                            HorizontalAlignment="Center"/>
                                    </StackPanel>
                                    <StackPanel HorizontalAlignment="Center">
                                        <TextBlock
                                            x:Name="TxtPlannedHours"
                                            Text="0"
                                            FontSize="20"
                                            FontWeight="Bold"
                                            Foreground="{ThemeResource SystemFillColorCautionBrush}"
                                            HorizontalAlignment="Center"/>
                                        <TextBlock
                                            Text="단원시수"
                                            FontSize="11"
                                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                            HorizontalAlignment="Center"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </Grid>

                        <!-- 안내/경고 메시지 -->
                        <InfoBar x:Name="HoursInfoBar"
                                 Grid.Row="1"
                                 IsOpen="False"
                                 Severity="Warning"
                                 IsClosable="True"
                                 Margin="0,0,0,12"/>

                        <!-- 테이블 헤더 -->
                        <Border
                            Grid.Row="2"
                            Background="{ThemeResource SubtleFillColorSecondaryBrush}"
                            CornerRadius="4,4,0,0"
                            Padding="8,6">
                            <Grid x:Name="TableHeader">
                                <!-- 동적으로 열 생성됨 -->
                            </Grid>
                        </Border>

                        <!-- 테이블 본문 -->
                        <Border Grid.Row="3"
                                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                BorderThickness="1,0,1,1"
                                CornerRadius="0,0,4,4">
                            <Grid>
                                <!-- 빈 상태 -->
                                <StackPanel x:Name="HoursEmptyState"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center"
                                            Spacing="8"
                                            Visibility="Collapsed">
                                    <FontIcon Glyph="&#xE787;" FontSize="48" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                    <TextBlock x:Name="TxtHoursEmptyMessage"
                                               Text="시간표 데이터가 없습니다"
                                               HorizontalAlignment="Center"
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                    <TextBlock Text="수업 관리에서 시간표를 먼저 배치하세요"
                                               FontSize="12"
                                               HorizontalAlignment="Center"
                                               Foreground="{ThemeResource TextFillColorTertiaryBrush}"/>
                                </StackPanel>

                                <!-- 테이블 -->
                                <ScrollViewer x:Name="WeeklyHoursScrollViewer" VerticalScrollBarVisibility="Auto">
                                    <StackPanel x:Name="WeeklyHoursTable"/>
                                </ScrollViewer>
                            </Grid>
                        </Border>
                    </Grid>
                </PivotItem>

                <!-- 탭 3: 단원 배치 -->
                <PivotItem Header="단원 배치">
                    <Grid Margin="0,16,0,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>



                        <Grid Grid.Row="1">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="280"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- 왼쪽: 단원 목록 요약 -->
                            <Border Grid.Column="0"
                                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                    BorderThickness="1"
                                    CornerRadius="8"
                                    Margin="0,0,12,0"
                                    Padding="16">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>

                                    <StackPanel Grid.Row="0" Spacing="4" Margin="0,0,0,12">
                                        <TextBlock Text="단원 목록" FontWeight="SemiBold" FontSize="16"/>
                                        <TextBlock
                                            x:Name="TxtUnitSummary"
                                            Text="0개 단원 / 0시간"
                                            FontSize="12"
                                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                    </StackPanel>

                                    <!-- 유형별 통계 -->
                                    <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="12" Margin="0,0,0,12">
                                        <Border Background="{ThemeResource SubtleFillColorSecondaryBrush}" 
                                                CornerRadius="4" Padding="8,4">
                                            <TextBlock x:Name="TxtNormalCount" Text="일반: 0" FontSize="11"/>
                                        </Border>
                                        <Border Background="{ThemeResource SystemFillColorCautionBackgroundBrush}" 
                                                CornerRadius="4" Padding="8,4">
                                            <TextBlock x:Name="TxtExamCount" Text="지필: 0" FontSize="11"/>
                                        </Border>
                                        <Border Background="{ThemeResource SystemFillColorCautionBackgroundBrush}" 
                                                CornerRadius="4" Padding="8,4">
                                            <TextBlock x:Name="TxtAssessmentCount" Text="수행: 0" FontSize="11"/>
                                        </Border>
                                        <Border Background="{ThemeResource SubtleFillColorTertiaryBrush}" 
                                                CornerRadius="4" Padding="8,4">
                                            <TextBlock x:Name="TxtPinnedCount" Text="📌 고정: 0" FontSize="11"/>
                                        </Border>
                                    </StackPanel>

                                    <!-- 배치용 단원 목록 -->
                                    <ListView Grid.Row="2"
                                              x:Name="SectionSummaryListView"
                                              SelectionMode="None">
                                        <ListView.ItemTemplate>
                                            <DataTemplate x:DataType="models:CourseSection">
                                                <Grid Padding="8,4" ColumnSpacing="8">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>

                                                    <!-- 유형 아이콘 -->
                                                    <FontIcon Grid.Column="0"
                                                              Glyph="{x:Bind SectionTypeIcon}"
                                                              FontSize="12"
                                                              VerticalAlignment="Center"/>

                                                    <TextBlock Grid.Column="1"
                                                               Text="{x:Bind SectionName}"
                                                               FontSize="12"
                                                               TextTrimming="CharacterEllipsis"
                                                               VerticalAlignment="Center"/>

                                                    <!-- 고정 날짜 표시 -->
                                                    <TextBlock Grid.Column="2"
                                                               Text="{x:Bind PinnedDateDisplay}"
                                                               FontSize="11"
                                                               Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"
                                                               Visibility="{x:Bind IsPinned}"
                                                               VerticalAlignment="Center"/>

                                                    <TextBlock Grid.Column="3"
                                                               Text="{x:Bind PageRangeDisplay}"
                                                               FontSize="11"
                                                               Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                                               VerticalAlignment="Center"/>

                                                    <TextBlock Grid.Column="4"
                                                               Text="{x:Bind HoursDisplay}"
                                                               FontSize="11"
                                                               Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"
                                                               VerticalAlignment="Center"
                                                               MinWidth="35"/>
                                                </Grid>
                                            </DataTemplate>
                                        </ListView.ItemTemplate>
                                    </ListView>
                                </Grid>
                            </Border>

                            <!-- 오른쪽: 배치 컨트롤 -->
                            <Border Grid.Column="1"
                                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                    BorderThickness="1"
                                    CornerRadius="8"
                                    Padding="16">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <!-- 헤더 + Undo/Redo -->
                                    <Grid Grid.Row="0" Margin="0,0,0,12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Grid.Column="0"
                                                   Text="수업 배치"
                                                   FontWeight="SemiBold"
                                                   FontSize="16"/>

                                        <!-- Undo/Redo 버튼 -->
                                        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="4">
                                            <Button x:Name="BtnUndo"
                                                    Click="OnUndoClick"
                                                    ToolTipService.ToolTip="실행 취소 (Ctrl+Z)"
                                                    IsEnabled="False"
                                                    Padding="8">
                                                <FontIcon Glyph="&#xE7A7;" FontSize="14"/>
                                            </Button>
                                            <Button x:Name="BtnRedo"
                                                    Click="OnRedoClick"
                                                    ToolTipService.ToolTip="다시 실행 (Ctrl+Y)"
                                                    IsEnabled="False"
                                                    Padding="8">
                                                <FontIcon Glyph="&#xE7A6;" FontSize="14"/>
                                            </Button>
                                        </StackPanel>
                                    </Grid>

                                    <!-- 배치 설정 -->
                                    <StackPanel Grid.Row="1" Spacing="12" Margin="0,0,0,16">
                                        <!-- 학급 선택 -->
                                        <Grid ColumnSpacing="12">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="학급" VerticalAlignment="Center"/>
                                            <ComboBox x:Name="CmbRoom" 
                                                      Grid.Column="1" 
                                                      PlaceholderText="학급 선택"
                                                      HorizontalAlignment="Stretch"
                                                      SelectionChanged="OnRoomSelectionChanged"/>
                                        </Grid>

                                        <!-- 기간 설정 -->
                                        <Grid ColumnSpacing="12">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="시작" VerticalAlignment="Center"/>
                                            <CalendarDatePicker x:Name="DpStartDate" 
                                                                Grid.Column="1"
                                                                PlaceholderText="시작일"
                                                                HorizontalAlignment="Stretch"/>
                                            <TextBlock Grid.Column="2" Text="종료" VerticalAlignment="Center"/>
                                            <CalendarDatePicker x:Name="DpEndDate" 
                                                                Grid.Column="3"
                                                                PlaceholderText="종료일"
                                                                HorizontalAlignment="Stretch"/>
                                        </Grid>

                                        <!-- 배치 버튼 -->
                                        <Button x:Name="BtnGeneratePlan"
                                                Content="🚀 자동 배치 실행"
                                                Style="{StaticResource AccentButtonStyle}"
                                                HorizontalAlignment="Stretch"
                                                Click="OnGeneratePlanClick"/>
                                    </StackPanel>

                                    <!-- 배치 결과 목록 (날짜 → 단원) -->
                                    <ListView Grid.Row="2"
                                              x:Name="UnitPlanListView"
                                              SelectionMode="Single"
                                              SelectionChanged="OnPlacementSelectionChanged"
                                              RightTapped="OnPlacementItemRightTapped">
                                        <ListView.ItemTemplate>
                                            <DataTemplate x:DataType="local:PlacementDisplayItem">
                                                <Grid Padding="4,2">
                                                    <!-- 주차 헤더 -->
                                                    <TextBlock Text="{x:Bind HeaderDisplay}"
                                                               Visibility="{x:Bind HeaderVisibility}"
                                                               FontWeight="SemiBold"
                                                               FontSize="13"
                                                               Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"
                                                               Margin="0,8,0,2"/>

                                                    <!-- 수업 슬롯 -->
                                                    <Grid ColumnSpacing="8"
                                                          Visibility="{x:Bind SlotVisibility}">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="80"/>
                                                            <ColumnDefinition Width="45"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>

                                                        <!-- 날짜 -->
                                                        <TextBlock Grid.Column="0"
                                                                   Text="{x:Bind DateDisplay}"
                                                                   FontSize="12"
                                                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                                   VerticalAlignment="Center"/>

                                                        <!-- 교시 -->
                                                        <TextBlock Grid.Column="1"
                                                                   Text="{x:Bind PeriodDisplay}"
                                                                   FontSize="12"
                                                                   Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                                                   VerticalAlignment="Center"/>

                                                        <!-- 강의실 (전체 보기 시) -->
                                                        <TextBlock Grid.Column="2"
                                                                   Text="{x:Bind RoomDisplay}"
                                                                   FontSize="11"
                                                                   FontWeight="SemiBold"
                                                                   Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"
                                                                   VerticalAlignment="Center"/>

                                                        <!-- 유형 아이콘 -->
                                                        <FontIcon Grid.Column="3"
                                                                  Glyph="{x:Bind TypeIcon}"
                                                                  FontSize="12"
                                                                  VerticalAlignment="Center"/>

                                                        <!-- 단원명 -->
                                                        <TextBlock Grid.Column="4"
                                                                   Text="{x:Bind SectionName}"
                                                                   FontSize="13"
                                                                   TextTrimming="CharacterEllipsis"
                                                                   VerticalAlignment="Center"/>

                                                        <!-- 진도 (1/3) -->
                                                        <TextBlock Grid.Column="5"
                                                                   Text="{x:Bind ProgressDisplay}"
                                                                   FontSize="11"
                                                                   Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                                                   VerticalAlignment="Center"
                                                                   MinWidth="35"/>
                                                    </Grid>
                                                </Grid>
                                            </DataTemplate>
                                        </ListView.ItemTemplate>
                                    </ListView>

                                    <!-- 수동 편집 버튼 -->
                                    <StackPanel Grid.Row="3" 
                                                Orientation="Horizontal" 
                                                Spacing="8" 
                                                Margin="0,8,0,0">
                                        <Button x:Name="BtnChangeUnit"
                                                Content="단원 변경"
                                                Click="OnChangeUnitClick"
                                                IsEnabled="False"
                                                Padding="12,6"/>
                                        <Button x:Name="BtnRemoveUnit"
                                                Content="배치 삭제"
                                                Click="OnRemoveUnitClick"
                                                IsEnabled="False"
                                                Padding="12,6"/>
                                    </StackPanel>

                                    <!-- 확정 버튼 (TODO: SchedulingEngine 기반으로 재구현 필요) -->
                                    <!--<Button Grid.Row="3"
                                            x:Name="BtnConfirmPlan"
                                            Content="계획 확정"
                                            HorizontalAlignment="Stretch"
                                            Style="{StaticResource AccentButtonStyle}"
                                            Margin="0,16,0,0"
                                            Click="OnConfirmClick"/>-->
                                </Grid>
                            </Border>
                        </Grid>
                    </Grid>
                </PivotItem>
            </Pivot>
        </Grid>
    </Grid>
</Page>

<Page
    x:Class="NewSchool.Pages.PageStudentInfo"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:controls="using:NewSchool.Controls"
    mc:Ignorable="d">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="180"/>
            <!-- 학생 목록 -->
            <ColumnDefinition Width="*"/>
            <!-- 상세 정보 -->
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- 상단 선택 -->
            <RowDefinition Height="*"/>
            <!-- 본문 + 누가기록 -->
        </Grid.RowDefinitions>
        <StackPanel Grid.Column="0" Grid.Row="0" Grid.ColumnSpan="2" Orientation="Horizontal">

            <!-- 상단 선택 영역 -->
            <controls:SchoolFilterPicker 
                x:Name="FilterPicker"
                ShowSemester="False"
                IncludeAllGrade="False"
                IncludeAllClass="False"
                Margin="8"
                SelectionChanged="FilterPicker_SelectionChanged"/>
            <!-- 학생 정보 헤더 -->
            <StackPanel Grid.Column="1" Margin="60,0,0,0"
              Orientation="Horizontal" Spacing="4"
              HorizontalAlignment="Right"
              Padding="8">

                <Button x:Name="BtnSave"
                    Content="저장"
                    Margin="4,0,4,0"
                    Click="BtnSave_Click"
                    IsEnabled="False"
                    Style="{StaticResource AccentButtonStyle}">
                    <Button.Resources>
                        <FontIcon x:Key="Icon" Glyph="&#xE74E;" FontSize="16"/>
                    </Button.Resources>
                </Button>

                <Button x:Name="BtnReset"
                    Content="초기화"
                    Margin="4,0,4,0"
                    Click="BtnReset_Click"
                    IsEnabled="False">
                    <Button.Resources>
                        <FontIcon x:Key="Icon" Glyph="&#xE894;" FontSize="16"/>
                    </Button.Resources>
                </Button>

                <Button x:Name="BtnPrint"
                    Margin="4,0,4,0"
                    Click="BtnPrint_Click"
                    IsEnabled="False"
                    ToolTipService.ToolTip="PDF 출력">
                    <StackPanel Orientation="Horizontal" Spacing="4">
                        <FontIcon Glyph="&#xEA90;" FontSize="14"/>
                        <TextBlock Text="PDF"/>
                    </StackPanel>
                </Button>

                <Button x:Name="BtnExcel"
                    Margin="4,0,4,0"
                    ToolTipService.ToolTip="엑셀 일괄 입력">
                    <Button.Content>
                        <StackPanel Orientation="Horizontal" Spacing="4">
                            <FontIcon Glyph="&#xE9F9;" FontSize="14"/>
                            <TextBlock Text="엑셀"/>
                        </StackPanel>
                    </Button.Content>
                    <Button.Flyout>
                        <MenuFlyout>
                            <MenuFlyoutItem Text="양식 다운로드" Click="BtnDownloadTemplate_Click">
                                <MenuFlyoutItem.Icon>
                                    <FontIcon Glyph="&#xE118;"/>
                                </MenuFlyoutItem.Icon>
                            </MenuFlyoutItem>
                            <MenuFlyoutItem Text="일괄 입력" Click="BtnBulkImport_Click">
                                <MenuFlyoutItem.Icon>
                                    <FontIcon Glyph="&#xE160;"/>
                                </MenuFlyoutItem.Icon>
                            </MenuFlyoutItem>
                        </MenuFlyout>
                    </Button.Flyout>
                </Button>
            </StackPanel>

        </StackPanel>

        <!-- 학생 목록 -->
        <controls:ListStudent x:Name="StudentList"
                              Grid.Column="0"
                              Grid.Row="1"
                              Margin="4"/>


        <!-- Column 1: StudentCard + 누가기록 래퍼 (너비 통일) -->
        <Grid Grid.Column="1" Grid.Row="1"
              MaxWidth="1000" HorizontalAlignment="Left" Margin="4">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- StudentCard -->
            <controls:StudentCard x:Name="SCard"
                                  Grid.Row="0"/>

            <!-- 누가기록 영역 -->
            <Border Grid.Row="1"
                    BorderBrush="CornflowerBlue"
                    BorderThickness="1"
                    CornerRadius="8"
                    Margin="0,4,0,0"
                    Padding="4">
                <Grid Background="AliceBlue">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- 누가기록 헤더 -->
                    <Grid Grid.Row="0"
                          Padding="8,4,8,4"
                          Background="#E3F2FD">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Text="누가기록"
                                   FontWeight="SemiBold"
                                   FontSize="14"
                                   VerticalAlignment="Center"/>

                        <Button x:Name="BtnNewLog"
                                Grid.Column="1"
                                Margin="4,0,4,0"
                                Background="Transparent"
                                Click="BtnNewLog_Click"
                                ToolTipService.ToolTip="추가">
                            <FontIcon Glyph="&#xECC8;" FontSize="16"/>
                        </Button>

                        <Button x:Name="BtnSaveLog"
                                Grid.Column="2"
                                Margin="4,0,4,0"
                                Background="Transparent"
                                Click="BtnSaveLog_Click"
                                ToolTipService.ToolTip="저장">
                            <FontIcon Glyph="&#xE74E;" FontSize="16"/>
                        </Button>

                        <Button x:Name="BtnDeleteLog"
                                Grid.Column="3"
                                Margin="4,0,4,0"
                                Background="Transparent"
                                Click="BtnDeleteLog_Click"
                                ToolTipService.ToolTip="삭제">
                            <FontIcon Glyph="&#xECC9;" FontSize="16"/>
                        </Button>

                        <Button x:Name="BtnPrintLog"
                                Grid.Column="4"
                                Margin="4,0,4,0"
                                Background="Transparent"
                                Click="BtnPrintLog_Click"
                                ToolTipService.ToolTip="인쇄">
                            <FontIcon Glyph="&#xE749;" FontSize="16"/>
                        </Button>

                        <Button x:Name="BtnExportLog"
                                Grid.Column="5"
                                Margin="4,0,4,0"
                                Background="Transparent"
                                Click="BtnExportLog_Click"
                                ToolTipService.ToolTip="엑셀 내보내기">
                            <FontIcon Glyph="&#xE160;" FontSize="16"/>
                        </Button>
                    </Grid>

                    <!-- 누가기록 리스트 -->
                    <controls:LogListViewer x:Name="LogList"
                                            Grid.Row="1"
                                            Margin="4"/>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Page>

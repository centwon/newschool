<Page
    x:Class="NewSchool.Pages.StudentSpecPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:controls="using:NewSchool.Controls"
    mc:Ignorable="d"
    Unloaded="Page_Unloaded">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- 필터 및 버튼 -->
            <RowDefinition Height="*"/>
            <!-- 목록 -->
        </Grid.RowDefinitions>

        <!-- 필터 및 버튼 영역 -->
        <Grid Grid.Row="0" 
              Padding="16"
              Background="{ThemeResource LayerFillColorDefaultBrush}"
              BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
              BorderThickness="0,0,0,1">
            
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <!-- 필터 -->
                <ColumnDefinition Width="Auto"/>
                <!-- 버튼 -->
            </Grid.ColumnDefinitions>

            <!-- 필터 영역 -->
            <StackPanel Grid.Column="0" 
                        Orientation="Horizontal" 
                        Spacing="8">
                
                <!-- 학년도/학년/반 필터 -->
                <controls:SchoolFilterPicker 
                    x:Name="FilterPicker"
                    ShowSemester="False"
                    IncludeAllGrade="False"
                    IncludeAllClass="False"/>

                <!-- 카테고리 -->
                <ComboBox x:Name="CBoxCategory"
                          PlaceholderText="선택"
                          MinWidth="140"
                          SelectionChanged="OnCategoryChanged"/>

                <!-- 조회 버튼 -->
                <Button x:Name="BtnQuery"
                        Content="조회"
                        Margin="0,0,0,0"
                        Style="{StaticResource AccentButtonStyle}"
                        Click="OnQueryClick">
                    <Button.KeyboardAccelerators>
                        <KeyboardAccelerator Key="Enter" Modifiers="Control"/>
                    </Button.KeyboardAccelerators>
                </Button>
            </StackPanel>

            <!-- 버튼 영역 -->
            <StackPanel Grid.Column="1"
                        Orientation="Horizontal"
                        Spacing="8"
                        Margin="16,0,0,0">

                <!-- 저장 -->
                <Button x:Name="BtnSave"
                        ToolTipService.ToolTip="선택한 항목 저장"
                        Click="OnSaveClick">
                    <StackPanel Orientation="Horizontal" Spacing="4">
                        <FontIcon Glyph="&#xE74E;" FontSize="16"/>
                        <TextBlock Text="저장"/>
                    </StackPanel>
                    <Button.KeyboardAccelerators>
                        <KeyboardAccelerator Key="S" Modifiers="Control"/>
                    </Button.KeyboardAccelerators>
                </Button>

                <!-- 삭제 -->
                <Button x:Name="BtnDelete"
                        ToolTipService.ToolTip="선택한 항목 삭제 (DB에서 완전 삭제)"
                        Click="OnDeleteClick">
                    <StackPanel Orientation="Horizontal" Spacing="4">
                        <FontIcon Glyph="&#xE74D;" FontSize="16"/>
                        <TextBlock Text="삭제"/>
                    </StackPanel>
                    <Button.KeyboardAccelerators>
                        <KeyboardAccelerator Key="Delete"/>
                    </Button.KeyboardAccelerators>
                </Button>

                <!-- 구분선 -->
                <Border Width="1" Height="24" VerticalAlignment="Center"
                        Background="{ThemeResource DividerStrokeColorDefaultBrush}"/>

                <!-- 폰트 크기 -->
                <Button x:Name="BtnFontSize"
                        ToolTipService.ToolTip="글자 크기 조절"
                        Click="OnFontSizeClick">
                    <FontIcon Glyph="&#xE8E9;" FontSize="16"/>

                    <FlyoutBase.AttachedFlyout>
                        <Flyout x:Name="FontSizeFlyout" Placement="Bottom">
                            <Grid Width="200" Height="150">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0"
                                           Text="글자 크기"
                                           FontWeight="SemiBold"
                                           Margin="0,0,0,8"/>

                                <Slider x:Name="SldFontSize"
                                        Grid.Row="1"
                                        Orientation="Vertical"
                                        Minimum="10"
                                        Maximum="24"
                                        Value="12"
                                        TickFrequency="2"
                                        TickPlacement="Outside"
                                        ValueChanged="OnFontSizeChanged"
                                        HorizontalAlignment="Center"/>

                                <TextBlock Grid.Row="2"
                                           x:Name="TxtFontSize"
                                           Text="12"
                                           FontWeight="Bold"
                                           HorizontalAlignment="Center"
                                           Margin="0,8,0,0"/>
                            </Grid>
                        </Flyout>
                    </FlyoutBase.AttachedFlyout>
                </Button>

                <!-- 구분선 -->
                <Border Width="1" Height="24" VerticalAlignment="Center"
                        Background="{ThemeResource DividerStrokeColorDefaultBrush}"/>

                <!-- 일괄 입력 -->
                <Button x:Name="BtnBatchInput"
                        ToolTipService.ToolTip="학급 전체 학생의 특기사항을 한 화면에서 편집"
                        Click="OnBatchInputClick">
                    <StackPanel Orientation="Horizontal" Spacing="4">
                        <FontIcon Glyph="&#xE70F;" FontSize="16"/>
                        <TextBlock Text="일괄 입력"/>
                    </StackPanel>
                </Button>

                <!-- 일괄 출력 -->
                <Button x:Name="BtnBatchExport"
                        ToolTipService.ToolTip="학급 전체 학생부를 PDF 또는 엑셀로 일괄 출력"
                        Click="OnBatchExportClick">
                    <StackPanel Orientation="Horizontal" Spacing="4">
                        <FontIcon Glyph="&#xEA90;" FontSize="16"/>
                        <TextBlock Text="일괄 출력"/>
                    </StackPanel>
                </Button>
            </StackPanel>
        </Grid>

        <!-- 목록 영역 -->
        <Grid Grid.Row="1" Padding="16">
            <controls:SpecListViewer x:Name="SpecListViewer"/>
        </Grid>
    </Grid>
</Page>

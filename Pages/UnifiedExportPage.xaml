<Page
    x:Class="NewSchool.Pages.UnifiedExportPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:NewSchool.Controls"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Grid Padding="16,12,16,16" RowSpacing="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Row 0: 학급 필터 -->
        <StackPanel Orientation="Horizontal" Spacing="12" Grid.Row="0">
            <controls:SchoolFilterPicker x:Name="SchoolFilter"
                ShowSemester="False"
                IncludeAllClass="False"/>
        </StackPanel>

        <!-- Row 1: 데이터 선택 -->
        <Border Grid.Row="1"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="6"
                Padding="16,10">
            <StackPanel Spacing="8">
                <TextBlock Text="데이터 선택" FontWeight="SemiBold" FontSize="13"/>
                <StackPanel Orientation="Horizontal" Spacing="24">
                    <RadioButton x:Name="RbStudentLog"
                                 Content="누가기록"
                                 GroupName="DataType"
                                 IsChecked="True"
                                 Checked="DataType_Checked"/>
                    <RadioButton x:Name="RbStudentSpec"
                                 Content="학생부 특기사항"
                                 GroupName="DataType"
                                 Checked="DataType_Checked"/>
                    <RadioButton x:Name="RbSeats"
                                 Content="좌석배정"
                                 GroupName="DataType"
                                 Checked="DataType_Checked"/>
                    <RadioButton x:Name="RbStudentCard"
                                 Content="학생카드"
                                 GroupName="DataType"
                                 Checked="DataType_Checked"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Row 2: 형식 선택 -->
        <Border Grid.Row="2"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="6"
                Padding="16,10">
            <StackPanel Spacing="8">
                <TextBlock Text="출력 형식" FontWeight="SemiBold" FontSize="13"/>
                <StackPanel Orientation="Horizontal" Spacing="24">
                    <RadioButton x:Name="RbFmtExcel"
                                 Content="Excel (.xlsx)"
                                 GroupName="Format"
                                 IsChecked="True"/>
                    <RadioButton x:Name="RbFmtPdf"
                                 Content="PDF (.pdf)"
                                 GroupName="Format"/>
                    <RadioButton x:Name="RbFmtHtml"
                                 Content="HTML (.html)"
                                 GroupName="Format"
                                 ToolTipService.ToolTip="브라우저로 열람 · Ctrl+P로 PDF 저장 가능"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Row 3: 실행 버튼 -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" Spacing="10" HorizontalAlignment="Left">
            <Button x:Name="BtnPreview"
                    Content="미리보기"
                    Click="BtnPreview_Click"
                    MinWidth="100"/>
            <Button x:Name="BtnExport"
                    Content="내보내기"
                    Style="{ThemeResource AccentButtonStyle}"
                    Click="BtnExport_Click"
                    MinWidth="120"/>
            <ProgressRing x:Name="Busy"
                          Width="22" Height="22"
                          IsActive="False"
                          VerticalAlignment="Center"/>
            <TextBlock x:Name="TxtStatus"
                       VerticalAlignment="Center"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
        </StackPanel>

        <!-- Row 4: 결과 안내 + 미리보기 -->
        <Grid Grid.Row="4" RowSpacing="8">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Background="{ThemeResource SolidBackgroundFillColorSecondaryBrush}"
                    CornerRadius="6"
                    Padding="16,10"
                    Visibility="Collapsed"
                    x:Name="ResultPanel">
                <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                    <TextBlock Text="내보내기 완료" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    <TextBlock x:Name="TxtResultPath"
                               TextWrapping="NoWrap"
                               TextTrimming="CharacterEllipsis"
                               VerticalAlignment="Center"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                               FontSize="12"/>
                    <Button x:Name="BtnOpenFile"
                            Content="파일 열기"
                            Click="BtnOpenFile_Click"/>
                    <Button x:Name="BtnOpenFolder"
                            Content="폴더 열기"
                            Click="BtnOpenFolder_Click"/>
                </StackPanel>
            </Border>

            <Border Grid.Row="1"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                <controls:JoditEditor
                    x:Name="PreviewEditor"
                    Mode="ReadOnly"/>
            </Border>
        </Grid>
    </Grid>
</Page>

<Page
    x:Class="NewSchool.Pages.AppSettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid>
        <ScrollViewer VerticalScrollMode="Enabled">
            <StackPanel Spacing="4" Padding="40,40,40,40">

                <TextBlock
                    Text="앱 설정"
                    Style="{StaticResource TitleTextBlockStyle}"
                    Margin="0,0,0,20"/>

                <!-- 일반 -->
                <Expander Header="일반" IsExpanded="True" HorizontalAlignment="Stretch" Margin="0,0,0,8">
                    <Expander.Content>
                        <StackPanel Spacing="12" Padding="16">

                            <ToggleSwitch
                                x:Name="StartWithWindowsToggle"
                                Header="Windows 시작 시 자동 실행"
                                OnContent="활성화"
                                OffContent="비활성화"
                                Toggled="OnStartWithWindowsToggled"/>

                            <ToggleSwitch
                                x:Name="TopMostToggle"
                                Header="항상 위에 표시"
                                OnContent="활성화"
                                OffContent="비활성화"
                                Toggled="OnTopMostToggled"/>

                            <ComboBox
                                x:Name="ThemeComboBox"
                                Header="테마"
                                PlaceholderText="테마 선택"
                                SelectionChanged="OnThemeChanged"
                                HorizontalAlignment="Stretch">
                                <ComboBoxItem Content="라이트" Tag="Light"/>
                                <ComboBoxItem Content="다크" Tag="Dark"/>
                                <ComboBoxItem Content="시스템 설정 따르기" Tag="Default"/>
                            </ComboBox>

                            <ComboBox
                                x:Name="LanguageComboBox"
                                Header="언어"
                                PlaceholderText="언어 선택"
                                SelectionChanged="OnLanguageChanged"
                                HorizontalAlignment="Stretch">
                                <ComboBoxItem Content="한국어" Tag="ko-KR"/>
                                <ComboBoxItem Content="English" Tag="en-US"/>
                            </ComboBox>
                        </StackPanel>
                    </Expander.Content>
                </Expander>

                <!-- 성능 및 캐시 -->
                <Expander Header="성능 및 캐시" IsExpanded="False" HorizontalAlignment="Stretch" Margin="0,0,0,8">
                    <Expander.Content>
                        <StackPanel Spacing="12" Padding="16">

                            <ToggleSwitch
                                x:Name="EnableCacheToggle"
                                Header="캐시 사용"
                                OnContent="활성화"
                                OffContent="비활성화"
                                Toggled="OnEnableCacheToggled"/>

                            <NumberBox
                                x:Name="DefaultPageSizeNumberBox"
                                Header="페이지당 항목 수"
                                PlaceholderText="20"
                                SpinButtonPlacementMode="Inline"
                                Minimum="10"
                                Maximum="100"
                                ValueChanged="OnDefaultPageSizeChanged"/>
                        </StackPanel>
                    </Expander.Content>
                </Expander>

                <!-- 백업 및 복원 -->
                <Expander Header="백업 및 복원" IsExpanded="False" HorizontalAlignment="Stretch" Margin="0,0,0,8">
                    <Expander.Content>
                        <StackPanel Spacing="12" Padding="16">

                            <ToggleSwitch
                                x:Name="AutoBackupToggle"
                                Header="자동 백업"
                                OnContent="활성화"
                                OffContent="비활성화"
                                Toggled="OnAutoBackupToggled"/>

                            <NumberBox
                                x:Name="AutoBackupIntervalDaysNumberBox"
                                Header="자동 백업 간격 (일)"
                                PlaceholderText="7"
                                SpinButtonPlacementMode="Inline"
                                Minimum="1"
                                Maximum="30"
                                IsEnabled="{x:Bind AutoBackupToggle.IsOn, Mode=OneWay}"
                                ValueChanged="OnAutoBackupIntervalDaysChanged"/>

                            <NumberBox
                                x:Name="BackupRetentionCountNumberBox"
                                Header="백업 보관 개수"
                                PlaceholderText="20"
                                SpinButtonPlacementMode="Inline"
                                Minimum="1"
                                Maximum="100"
                                ValueChanged="OnBackupRetentionCountChanged"/>

                            <TextBlock x:Name="LastBackupTimeText"
                                       Text="마지막 백업: 없음"
                                       FontSize="12" Opacity="0.7"/>

                            <Grid ColumnSpacing="8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <Button
                                    Grid.Column="0"
                                    Content="지금 백업"
                                    Click="OnBackupClick"
                                    HorizontalAlignment="Stretch"/>

                                <Button
                                    Grid.Column="1"
                                    Content="복원..."
                                    Click="OnRestoreClick"
                                    HorizontalAlignment="Stretch"/>

                                <Button
                                    Grid.Column="2"
                                    Content="폴더 열기"
                                    Click="OnOpenBackupFolderClick"
                                    HorizontalAlignment="Stretch"/>
                            </Grid>
                        </StackPanel>
                    </Expander.Content>
                </Expander>

                <!-- 고급 -->
                <Expander Header="고급" IsExpanded="False" HorizontalAlignment="Stretch" Margin="0,0,0,8">
                    <Expander.Content>
                        <StackPanel Spacing="12" Padding="16">

                            <StackPanel Spacing="4">
                                <TextBlock Text="데이터 저장 위치" FontWeight="SemiBold"/>
                                <TextBlock x:Name="DataPathText" IsTextSelectionEnabled="True"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                           TextWrapping="Wrap"/>
                                <TextBlock x:Name="DataModeText" FontSize="12"
                                           Foreground="{ThemeResource TextFillColorTertiaryBrush}"/>
                            </StackPanel>

                            <ComboBox
                                x:Name="LogLevelComboBox"
                                Header="로그 레벨"
                                PlaceholderText="로그 레벨 선택"
                                SelectionChanged="OnLogLevelChanged"
                                HorizontalAlignment="Stretch">
                                <ComboBoxItem Content="Debug" Tag="Debug"/>
                                <ComboBoxItem Content="Info" Tag="Info"/>
                                <ComboBoxItem Content="Warning" Tag="Warning"/>
                                <ComboBoxItem Content="Error" Tag="Error"/>
                            </ComboBox>

                            <Grid ColumnSpacing="8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <Button
                                    Grid.Column="0"
                                    Content="설정 초기화"
                                    Click="OnResetSettingsClick"
                                    HorizontalAlignment="Stretch"/>

                                <Button
                                    Grid.Column="1"
                                    Content="로그 폴더 열기"
                                    Click="OnOpenLogFolderClick"
                                    HorizontalAlignment="Stretch"/>

                                <Button
                                    Grid.Column="2"
                                    Content="데이터 폴더 열기"
                                    Click="OnOpenDataFolderClick"
                                    HorizontalAlignment="Stretch"/>
                            </Grid>
                        </StackPanel>
                    </Expander.Content>
                </Expander>

                <!-- 업데이트 -->
                <Expander Header="업데이트" IsExpanded="False" HorizontalAlignment="Stretch" Margin="0,0,0,8">
                    <Expander.Content>
                        <StackPanel Spacing="12" Padding="16">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <TextBlock Text="현재 버전:" VerticalAlignment="Center"/>
                                <TextBlock x:Name="CurrentVersionText" FontWeight="SemiBold" VerticalAlignment="Center"/>
                            </StackPanel>

                            <StackPanel Orientation="Horizontal" Spacing="12">
                                <Button x:Name="CheckUpdateButton"
                                        Content="업데이트 확인"
                                        Click="OnCheckUpdateClick"/>
                                <ProgressRing x:Name="UpdateProgressRing"
                                              IsActive="False"
                                              Width="20" Height="20"
                                              VerticalAlignment="Center"
                                              Visibility="Collapsed"/>
                            </StackPanel>

                            <TextBlock x:Name="UpdateStatusText"
                                       TextWrapping="Wrap"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                       Visibility="Collapsed"/>

                            <HyperlinkButton x:Name="DownloadLink"
                                             Content="다운로드 페이지 열기"
                                             Visibility="Collapsed"
                                             Click="OnDownloadLinkClick"/>
                        </StackPanel>
                    </Expander.Content>
                </Expander>

                <Border Height="40"/>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>

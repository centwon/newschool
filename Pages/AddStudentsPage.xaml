<Page
    x:Class="NewSchool.Pages.AddStudentsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:local="using:NewSchool.Pages"
    mc:Ignorable="d">

    <Grid Padding="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 헤더 -->
        <StackPanel Grid.Row="0" Spacing="8" Margin="0,0,0,24">
            <TextBlock 
                Text="학생 추가" 
                Style="{StaticResource TitleTextBlockStyle}"/>
            <TextBlock 
                Text="Excel 파일에서 가져오거나 직접 입력하여 학생을 추가합니다."
                Style="{StaticResource BodyTextBlockStyle}"
                Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
        </StackPanel>

        <!-- 수동 입력 영역 -->
        <Grid Grid.Row="1" 
              Padding="16"
              Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
              BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
              BorderThickness="1"
              CornerRadius="8"
              Margin="0,0,0,16">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="80"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="60"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="60"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="60"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0" Text="학년도" VerticalAlignment="Center" Margin="0,0,8,0"/>
            <TextBox x:Name="TxtYear" Grid.Column="1" InputScope="Number" 
                     PreviewKeyDown="NumberBox_PreviewKeyDown"/>

            <TextBlock Grid.Column="2" Text="학년" VerticalAlignment="Center" Margin="16,0,8,0"/>
            <TextBox x:Name="TxtGrade" Grid.Column="3" InputScope="Number"
                     PreviewKeyDown="NumberBox_PreviewKeyDown"/>

            <TextBlock Grid.Column="4" Text="반" VerticalAlignment="Center" Margin="16,0,8,0"/>
            <TextBox x:Name="TxtClass" Grid.Column="5" InputScope="Number"
                     PreviewKeyDown="NumberBox_PreviewKeyDown"/>

            <TextBlock Grid.Column="6" Text="번호" VerticalAlignment="Center" Margin="16,0,8,0"/>
            <TextBox x:Name="TxtNumber" Grid.Column="7" InputScope="Number"
                     PreviewKeyDown="NumberBox_PreviewKeyDown"/>

            <TextBlock Grid.Column="8" Text="이름" VerticalAlignment="Center" Margin="16,0,8,0"/>
            <TextBox x:Name="TxtName" Grid.Column="9" PlaceholderText="학생 이름 입력"
                     Margin="0,0,16,0"/>

            <Button x:Name="BtnAddStudent" Grid.Column="10" Content="추가"
                   Style="{StaticResource AccentButtonStyle}"
                   Click="BtnAddStudent_Click"/>
        </Grid>

        <!-- 학생 목록 (ItemsRepeater 사용 - 더 가볍고 빠름) -->
        <Grid Grid.Row="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- 목록 헤더 -->
            <Grid Grid.Row="0" Margin="0,0,0,8">
                <TextBlock 
                    Text="추가할 학생 목록" 
                    Style="{StaticResource SubtitleTextBlockStyle}"
                    VerticalAlignment="Center"/>

                <StackPanel Orientation="Horizontal" 
                           HorizontalAlignment="Right"
                           Spacing="8">
                    <TextBlock VerticalAlignment="Center"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}">
                        <Run Text="총 "/>
                        <Run Text="{x:Bind NewStudents.Count, Mode=OneWay}" FontWeight="SemiBold"/>
                        <Run Text="명"/>
                    </TextBlock>
                </StackPanel>
            </Grid>

            <!-- ItemsRepeater (가볍고 빠른 성능) -->
            <Border Grid.Row="1"
                   Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                   BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                   BorderThickness="1"
                   CornerRadius="8">

                <ScrollViewer>
                    <StackPanel Spacing="0">
                        <!-- 테이블 헤더 -->
                        <Grid Padding="12,12"
                              Background="{ThemeResource LayerFillColorDefaultBrush}"
                              BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                              BorderThickness="0,0,0,1">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="80"/>
                                <ColumnDefinition Width="60"/>
                                <ColumnDefinition Width="60"/>
                                <ColumnDefinition Width="60"/>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="40"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0" Text="학생ID" FontWeight="SemiBold" FontSize="12"/>
                            <TextBlock Grid.Column="1" Text="학년도" FontWeight="SemiBold" FontSize="12"/>
                            <TextBlock Grid.Column="2" Text="학년" FontWeight="SemiBold" FontSize="12"/>
                            <TextBlock Grid.Column="3" Text="반" FontWeight="SemiBold" FontSize="12"/>
                            <TextBlock Grid.Column="4" Text="번호" FontWeight="SemiBold" FontSize="12"/>
                            <TextBlock Grid.Column="5" Text="이름" FontWeight="SemiBold" FontSize="12"/>
                            <TextBlock Grid.Column="6" Text="학급 정보" FontWeight="SemiBold" FontSize="12"/>
                            <TextBlock Grid.Column="7" Text="" FontWeight="SemiBold" FontSize="12"/>
                        </Grid>

                        <!-- ItemsRepeater -->
                        <ItemsRepeater ItemsSource="{x:Bind NewStudents, Mode=OneWay}">
                            <ItemsRepeater.Layout>
                                <StackLayout Spacing="0"/>
                            </ItemsRepeater.Layout>

                            <ItemsRepeater.ItemTemplate>
                                <DataTemplate x:DataType="local:StudentAddViewModel">
                                    <Border Background="Transparent"
                                           BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                                           BorderThickness="0,0,0,1">
                                        <Grid Padding="12,10"
                                              Background="Transparent">

                                            <!-- 호버 효과 -->
                                            <Grid.Resources>
                                                <SolidColorBrush x:Key="HoverBrush" Color="{ThemeResource SubtleFillColorSecondary}" Opacity="0.5"/>
                                            </Grid.Resources>

                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="140"/>
                                                <ColumnDefinition Width="80"/>
                                                <ColumnDefinition Width="60"/>
                                                <ColumnDefinition Width="60"/>
                                                <ColumnDefinition Width="60"/>
                                                <ColumnDefinition Width="120"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="40"/>
                                            </Grid.ColumnDefinitions>

                                            <TextBlock Grid.Column="0" 
                                                      Text="{x:Bind StudentID}" 
                                                      VerticalAlignment="Center"
                                                      FontFamily="Consolas"
                                                      FontSize="12"/>

                                            <TextBlock Grid.Column="1" 
                                                      Text="{x:Bind Year}" 
                                                      VerticalAlignment="Center"/>

                                            <TextBlock Grid.Column="2" 
                                                      Text="{x:Bind Grade}" 
                                                      VerticalAlignment="Center"/>

                                            <TextBlock Grid.Column="3" 
                                                      Text="{x:Bind Class}" 
                                                      VerticalAlignment="Center"/>

                                            <TextBlock Grid.Column="4" 
                                                      Text="{x:Bind Number}" 
                                                      VerticalAlignment="Center"/>

                                            <TextBlock Grid.Column="5" 
                                                      Text="{x:Bind Name}" 
                                                      VerticalAlignment="Center"
                                                      FontWeight="SemiBold"/>

                                            <TextBlock Grid.Column="6" 
                                                      Text="{x:Bind ClassInfo}" 
                                                      VerticalAlignment="Center"
                                                      Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                      FontSize="12"/>

                                            <Button Grid.Column="7"
                                                   Content="&#xE74D;"
                                                   FontFamily="Segoe MDL2 Assets"
                                                   FontSize="12"
                                                   Width="32"
                                                   Height="32"
                                                   Padding="0"
                                                   Background="Transparent"
                                                   ToolTipService.ToolTip="삭제"
                                                   Click="BtnRemoveStudent_Click"
                                                   Tag="{x:Bind StudentID}"/>

                                            <VisualStateManager.VisualStateGroups>
                                                <VisualStateGroup x:Name="CommonStates">
                                                    <VisualState x:Name="Normal"/>
                                                    <VisualState x:Name="PointerOver">
                                                        <VisualState.Setters>
                                                            <Setter Target="RootGrid.Background" Value="{StaticResource HoverBrush}"/>
                                                        </VisualState.Setters>
                                                    </VisualState>
                                                </VisualStateGroup>
                                            </VisualStateManager.VisualStateGroups>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsRepeater.ItemTemplate>
                        </ItemsRepeater>

                        <!-- 빈 목록 메시지 -->
                        <TextBlock x:Name="TbBlankList" Text="추가된 학생이 없습니다."
                                  Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                  HorizontalAlignment="Center"
                                  Margin="0,40,0,40"/>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>

        <!-- 하단 버튼 -->
        <Grid Grid.Row="3" Margin="0,16,0,0">
            <StackPanel Orientation="Horizontal" 
                       HorizontalAlignment="Left"
                       Spacing="8">
                <Button x:Name="BtnAddFromExcel"
                       Click="BtnAddFromExcel_Click">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon Glyph="&#xE8E5;" FontSize="16"/>
                        <TextBlock Text="Excel에서 가져오기" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <Button x:Name="BtnDownloadTemplate"
                       Click="BtnDownloadTemplate_Click">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon Glyph="&#xE896;" FontSize="16"/>
                        <TextBlock Text="템플릿 다운로드" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </StackPanel>

            <StackPanel Orientation="Horizontal" 
                       HorizontalAlignment="Right"
                       Spacing="8">
                <ProgressRing x:Name="LoadingProgressRing"
                             Width="24"
                             Height="24"
                             IsActive="False"
                             VerticalAlignment="Center"/>

                <Button x:Name="BtnExport"
                       Click="BtnExport_Click"
                       IsEnabled="False">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon Glyph="&#xEDE1;" FontSize="16"/>
                        <TextBlock Text="목록 내보내기" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <Button x:Name="BtnSave"
                       Style="{StaticResource AccentButtonStyle}"
                       Click="BtnSave_Click"
                       IsEnabled="False">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon Glyph="&#xE74E;" FontSize="16"/>
                        <TextBlock Text="데이터베이스에 저장" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </StackPanel>
        </Grid>
    </Grid>
</Page>

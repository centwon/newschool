<Page
    x:Class="NewSchool.Pages.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:local="using:NewSchool.Pages"
    mc:Ignorable="d">

    <Grid>
        <ScrollViewer VerticalScrollMode="Enabled">
            <StackPanel Spacing="4" Padding="40,40,40,40" MaxWidth="1000" HorizontalAlignment="Center">

                <!-- 페이지 헤더 -->
                <TextBlock
                    Text="학교 설정"
                    Style="{StaticResource TitleTextBlockStyle}"
                    Margin="0,0,0,20"/>

                <!-- 사용자 / 담임반 -->
                <Expander Header="사용자 / 담임반" IsExpanded="True" HorizontalAlignment="Stretch" Margin="0,0,0,8">
                    <Expander.Content>
                        <StackPanel Spacing="12" Padding="16">

                            <TextBox
                                x:Name="UserNameTextBox"
                                Header="사용자 이름"
                                PlaceholderText="교사 이름"
                                LostFocus="OnUserNameChanged"/>

                            <Grid ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <NumberBox
                                    x:Name="HomeGradeNumberBox"
                                    Grid.Column="0"
                                    Header="담임 학년"
                                    PlaceholderText="학년"
                                    SpinButtonPlacementMode="Inline"
                                    Minimum="0"
                                    Maximum="6"
                                    ValueChanged="OnHomeGradeChanged"/>

                                <NumberBox
                                    x:Name="HomeRoomNumberBox"
                                    Grid.Column="1"
                                    Header="담임 반"
                                    PlaceholderText="반"
                                    SpinButtonPlacementMode="Inline"
                                    Minimum="0"
                                    Maximum="30"
                                    ValueChanged="OnHomeRoomChanged"/>
                            </Grid>
                        </StackPanel>
                    </Expander.Content>
                </Expander>

                <!-- 학교 정보 -->
                <Expander Header="학교 정보" IsExpanded="True" HorizontalAlignment="Stretch" Margin="0,0,0,8">
                    <Expander.Content>
                        <StackPanel Spacing="12" Padding="16">

                            <Button
                                Click="OnSearchSchoolClick"
                                HorizontalAlignment="Left"
                                Style="{StaticResource AccentButtonStyle}">
                                <Button.Content>
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <FontIcon Glyph="&#xE721;" FontSize="14"/>
                                        <TextBlock Text="학교 검색"/>
                                    </StackPanel>
                                </Button.Content>
                            </Button>

                            <InfoBar
                                x:Name="SchoolSearchInfoBar"
                                Title="학교 정보를 검색하세요"
                                Message="NEIS 나이스 시스템에서 학교 정보를 검색하여 자동으로 입력할 수 있습니다."
                                Severity="Informational"
                                IsOpen="True"
                                IsClosable="True"
                                Margin="0,0,0,8"/>

                            <TextBox
                                x:Name="SchoolNameTextBox"
                                Header="학교명"
                                PlaceholderText="학교명을 입력하세요"
                                LostFocus="OnSchoolNameChanged"
                                IsReadOnly="True"/>

                            <Grid ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <TextBox
                                    x:Name="ProvinceCodeTextBox"
                                    Grid.Column="0"
                                    Header="시도 코드"
                                    PlaceholderText="예: B10"
                                    LostFocus="OnProvinceCodeChanged"
                                    IsReadOnly="True"/>

                                <TextBox
                                    x:Name="SchoolCodeTextBox"
                                    Grid.Column="1"
                                    Header="학교 코드"
                                    PlaceholderText="학교 코드"
                                    LostFocus="OnSchoolCodeChanged"
                                    IsReadOnly="True"/>
                            </Grid>

                            <TextBox
                                x:Name="ProvinceNameTextBox"
                                Header="시도명"
                                PlaceholderText="예: 서울특별시"
                                LostFocus="OnProvinceNameChanged"
                                IsReadOnly="True"/>

                            <TextBox
                                x:Name="SchoolAddressTextBox"
                                Header="학교 주소"
                                PlaceholderText="학교 주소를 입력하세요"
                                LostFocus="OnSchoolAddressChanged"
                                IsReadOnly="True"/>
                        </StackPanel>
                    </Expander.Content>
                </Expander>

                <!-- 학년도 및 학기 -->
                <Expander Header="학년도 및 학기" IsExpanded="True" HorizontalAlignment="Stretch" Margin="0,0,0,8">
                    <Expander.Content>
                        <StackPanel Spacing="12" Padding="16">

                            <NumberBox
                                x:Name="WorkYearNumberBox"
                                Header="학년도"
                                PlaceholderText="예: 2025"
                                SpinButtonPlacementMode="Inline"
                                Minimum="2000"
                                Maximum="2100"
                                ValueChanged="OnWorkYearChanged"/>

                            <ComboBox
                                x:Name="WorkSemesterComboBox"
                                Header="학기"
                                PlaceholderText="학기 선택"
                                SelectionChanged="OnWorkSemesterChanged"
                                HorizontalAlignment="Stretch">
                                <ComboBoxItem Content="1학기" Tag="1"/>
                                <ComboBoxItem Content="2학기" Tag="2"/>
                            </ComboBox>
                        </StackPanel>
                    </Expander.Content>
                </Expander>

                <!-- 교시 시간 설정 -->
                <Expander Header="교시 시간 설정" IsExpanded="False" HorizontalAlignment="Stretch" Margin="0,0,0,8">
                    <Expander.Content>
                        <StackPanel Spacing="12" Padding="16">

                            <TimePicker
                                x:Name="DayStartingTimePicker"
                                Header="등교 시간"
                                ClockIdentifier="24HourClock"
                                TimeChanged="OnDayStartingChanged"/>

                            <TimePicker
                                x:Name="AssemblyTimePicker"
                                Header="조회 시간 (분)"
                                ClockIdentifier="24HourClock"
                                TimeChanged="OnAssemblyTimeChanged"/>

                            <NumberBox
                                x:Name="OnePeriodNumberBox"
                                Header="1교시 시간 (분)"
                                PlaceholderText="45"
                                SpinButtonPlacementMode="Inline"
                                Minimum="30"
                                Maximum="90"
                                ValueChanged="OnOnePeriodChanged"/>

                            <NumberBox
                                x:Name="BreakTimeNumberBox"
                                Header="쉬는 시간 (분)"
                                PlaceholderText="10"
                                SpinButtonPlacementMode="Inline"
                                Minimum="5"
                                Maximum="30"
                                ValueChanged="OnBreakTimeChanged"/>

                            <NumberBox
                                x:Name="LunchTimeNumberBox"
                                Header="점심 시간 (분)"
                                PlaceholderText="50"
                                SpinButtonPlacementMode="Inline"
                                Minimum="30"
                                Maximum="90"
                                ValueChanged="OnLunchTimeChanged"/>
                        </StackPanel>
                    </Expander.Content>
                </Expander>

                <!-- 하단 여백 -->
                <Border Height="40"/>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>

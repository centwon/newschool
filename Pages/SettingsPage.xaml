<Page
    x:Class="NewSchool.Pages.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:local="using:NewSchool.Pages"
    mc:Ignorable="d">

    <Grid>
        <ScrollViewer VerticalScrollMode="Enabled">
            <StackPanel Spacing="4" Padding="40,40,40,40" MaxWidth="1000">

                <!-- 페이지 헤더 -->
                <TextBlock 
                    Text="설정" 
                    Style="{StaticResource TitleTextBlockStyle}" 
                    Margin="0,0,0,20"/>

                <!-- 1. 학교 정보 설정 -->
                <Expander Header="학교 정보" IsExpanded="True" HorizontalAlignment="Stretch" Margin="0,0,0,8">
                    <Expander.Content>
                        <StackPanel Spacing="12" Padding="16">

                            <!-- 학교 검색 버튼 -->
                            <Button 
                                Click="OnSearchSchoolClick"
                                HorizontalAlignment="Left"
                                Style="{StaticResource AccentButtonStyle}">
                                <Button.Content>
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <FontIcon Glyph="&#xE721;" FontSize="14"/>
                                        <TextBlock Text="학교 검색"/>
                                    </StackPanel>
                                </Button.Content>
                            </Button>

                            <InfoBar
                                x:Name="SchoolSearchInfoBar"
                                Title="학교 정보를 검색하세요"
                                Message="NEIS 나이스 시스템에서 학교 정보를 검색하여 자동으로 입력할 수 있습니다."
                                Severity="Informational"
                                IsOpen="True"
                                IsClosable="True"
                                Margin="0,0,0,8"/>

                            <TextBox 
                                x:Name="SchoolNameTextBox"
                                Header="학교명" 
                                PlaceholderText="학교명을 입력하세요"
                                LostFocus="OnSchoolNameChanged"
                                IsReadOnly="True"/>

                            <Grid ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <TextBox 
                                    x:Name="ProvinceCodeTextBox"
                                    Grid.Column="0"
                                    Header="시도 코드" 
                                    PlaceholderText="예: B10"
                                    LostFocus="OnProvinceCodeChanged"
                                    IsReadOnly="True"/>

                                <TextBox 
                                    x:Name="SchoolCodeTextBox"
                                    Grid.Column="1"
                                    Header="학교 코드" 
                                    PlaceholderText="학교 코드"
                                    LostFocus="OnSchoolCodeChanged"
                                    IsReadOnly="True"/>
                            </Grid>

                            <TextBox 
                                x:Name="ProvinceNameTextBox"
                                Header="시도명" 
                                PlaceholderText="예: 서울특별시"
                                LostFocus="OnProvinceNameChanged"
                                IsReadOnly="True"/>

                            <TextBox 
                                x:Name="SchoolAddressTextBox"
                                Header="학교 주소" 
                                PlaceholderText="학교 주소를 입력하세요"
                                LostFocus="OnSchoolAddressChanged"
                                IsReadOnly="True"/>

                            <!--<TextBox 
                                x:Name="NeisApiKeyTextBox"
                                Header="NEIS API 키" 
                                PlaceholderText="NEIS API 키를 입력하세요"
                                LostFocus="OnNeisApiKeyChanged"/>-->
                        </StackPanel>
                    </Expander.Content>
                </Expander>

                <!-- 2. 학년도/학기 설정 -->
                <Expander Header="학년도 및 학기" IsExpanded="True" HorizontalAlignment="Stretch" Margin="0,0,0,8">
                    <Expander.Content>
                        <StackPanel Spacing="12" Padding="16">

                            <NumberBox 
                                x:Name="WorkYearNumberBox"
                                Header="학년도" 
                                PlaceholderText="예: 2025"
                                SpinButtonPlacementMode="Inline"
                                Minimum="2000"
                                Maximum="2100"
                                ValueChanged="OnWorkYearChanged"/>

                            <ComboBox 
                                x:Name="WorkSemesterComboBox"
                                Header="학기" 
                                PlaceholderText="학기 선택"
                                SelectionChanged="OnWorkSemesterChanged"
                                HorizontalAlignment="Stretch">
                                <ComboBoxItem Content="1학기" Tag="1"/>
                                <ComboBoxItem Content="2학기" Tag="2"/>
                            </ComboBox>
                        </StackPanel>
                    </Expander.Content>
                </Expander>

                <!-- 3. 담임반 설정 -->
                <Expander Header="담임반 정보" IsExpanded="True" HorizontalAlignment="Stretch" Margin="0,0,0,8">
                    <Expander.Content>
                        <StackPanel Spacing="12" Padding="16">

                            <Grid ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <NumberBox 
                                    x:Name="HomeGradeNumberBox"
                                    Grid.Column="0"
                                    Header="담임 학년" 
                                    PlaceholderText="학년"
                                    SpinButtonPlacementMode="Inline"
                                    Minimum="0"
                                    Maximum="6"
                                    ValueChanged="OnHomeGradeChanged"/>

                                <NumberBox 
                                    x:Name="HomeRoomNumberBox"
                                    Grid.Column="1"
                                    Header="담임 반" 
                                    PlaceholderText="반"
                                    SpinButtonPlacementMode="Inline"
                                    Minimum="0"
                                    Maximum="30"
                                    ValueChanged="OnHomeRoomChanged"/>
                            </Grid>

                            <TextBox 
                                x:Name="UserNameTextBox"
                                Header="사용자 이름" 
                                PlaceholderText="교사 이름"
                                LostFocus="OnUserNameChanged"/>
                        </StackPanel>
                    </Expander.Content>
                </Expander>

                <!-- 4. 시간표 설정 -->
                <Expander Header="교시 시간 설정" IsExpanded="False" HorizontalAlignment="Stretch" Margin="0,0,0,8">
                    <Expander.Content>
                        <StackPanel Spacing="12" Padding="16">

                            <TimePicker 
                                x:Name="DayStartingTimePicker"
                                Header="등교 시간" 
                                ClockIdentifier="24HourClock"
                                TimeChanged="OnDayStartingChanged"/>

                            <TimePicker 
                                x:Name="AssemblyTimePicker"
                                Header="조회 시간 (분)" 
                                ClockIdentifier="24HourClock"
                                TimeChanged="OnAssemblyTimeChanged"/>

                            <NumberBox 
                                x:Name="OnePeriodNumberBox"
                                Header="1교시 시간 (분)" 
                                PlaceholderText="45"
                                SpinButtonPlacementMode="Inline"
                                Minimum="30"
                                Maximum="90"
                                ValueChanged="OnOnePeriodChanged"/>

                            <NumberBox 
                                x:Name="BreakTimeNumberBox"
                                Header="쉬는 시간 (분)" 
                                PlaceholderText="10"
                                SpinButtonPlacementMode="Inline"
                                Minimum="5"
                                Maximum="30"
                                ValueChanged="OnBreakTimeChanged"/>

                            <NumberBox 
                                x:Name="LunchTimeNumberBox"
                                Header="점심 시간 (분)" 
                                PlaceholderText="50"
                                SpinButtonPlacementMode="Inline"
                                Minimum="30"
                                Maximum="90"
                                ValueChanged="OnLunchTimeChanged"/>
                        </StackPanel>
                    </Expander.Content>
                </Expander>

                <!-- 5. 일정 관리 설정 -->
                <Expander Header="일정 관리" IsExpanded="False" HorizontalAlignment="Stretch" Margin="0,0,0,8">
                    <Expander.Content>
                        <StackPanel Spacing="12" Padding="16">

                            <ToggleSwitch 
                                x:Name="ShowEventsToggle"
                                Header="이벤트 표시" 
                                OnContent="표시" 
                                OffContent="숨김"
                                Toggled="OnShowEventsToggled"/>

                            <ToggleSwitch 
                                x:Name="ShowTasksToggle"
                                Header="할 일 표시" 
                                OnContent="표시" 
                                OffContent="숨김"
                                Toggled="OnShowTasksToggled"/>

                            <NumberBox 
                                x:Name="EventFontSizeNumberBox"
                                Header="이벤트 폰트 크기" 
                                PlaceholderText="9.0"
                                SpinButtonPlacementMode="Inline"
                                Minimum="8"
                                Maximum="20"
                                SmallChange="0.5"
                                LargeChange="1"
                                ValueChanged="OnEventFontSizeChanged"/>

                            <NumberBox 
                                x:Name="TaskFontSizeNumberBox"
                                Header="할 일 폰트 크기" 
                                PlaceholderText="10.0"
                                SpinButtonPlacementMode="Inline"
                                Minimum="8"
                                Maximum="20"
                                SmallChange="0.5"
                                LargeChange="1"
                                ValueChanged="OnTaskFontSizeChanged"/>

                            <ToggleSwitch
                                x:Name="UseGoogleToggle"
                                Header="Google 캘린더 연동"
                                OnContent="사용"
                                OffContent="미사용"
                                Toggled="OnUseGoogleToggled"/>

                            <!-- Google 계정 연동 -->
                            <TextBlock Text="Google 계정 연동" FontWeight="SemiBold" Margin="0,12,0,4"/>

                            <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,4,0,0">
                                <Button
                                    x:Name="GoogleAuthButton"
                                    Content="Google 계정 연동"
                                    IsEnabled="{x:Bind UseGoogleToggle.IsOn, Mode=OneWay}"
                                    Click="OnGoogleAuthClicked"/>
                                <Button
                                    x:Name="GoogleSignOutButton"
                                    Content="연동 해제"
                                    IsEnabled="{x:Bind UseGoogleToggle.IsOn, Mode=OneWay}"
                                    Click="OnGoogleSignOutClicked"/>
                            </StackPanel>

                            <TextBlock
                                x:Name="GoogleAuthStatusText"
                                Text="연동되지 않음"
                                Foreground="{ThemeResource SystemFillColorCautionBrush}"
                                Margin="0,4,0,0"/>

                            <!-- 캘린더 선택 -->
                            <TextBlock Text="동기화할 캘린더" FontWeight="SemiBold" Margin="0,12,0,4"/>
                            <TextBlock
                                x:Name="GoogleCalendarListHint"
                                Text="계정을 연동하면 캘린더 목록이 표시됩니다."
                                Opacity="0.6"
                                Margin="0,0,0,4"/>
                            <ListView
                                x:Name="GoogleCalendarListView"
                                SelectionMode="None"
                                MaxHeight="200"
                                Visibility="Collapsed">
                                <ListView.ItemTemplate>
                                    <DataTemplate x:DataType="local:GoogleCalendarCheckItem">
                                        <CheckBox
                                            Content="{x:Bind Title}"
                                            IsChecked="{x:Bind IsChecked, Mode=TwoWay}"
                                            Tag="{x:Bind GoogleId}"/>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                            <Button
                                x:Name="GoogleCalendarSaveButton"
                                Content="캘린더 선택 저장"
                                Visibility="Collapsed"
                                Click="OnGoogleCalendarSaveClicked"
                                Margin="0,4,0,0"/>

                            <!-- 동기화 설정 -->
                            <TextBlock Text="동기화 설정" FontWeight="SemiBold" Margin="0,12,0,4"/>

                            <ToggleSwitch
                                x:Name="GoogleAutoSyncToggle"
                                Header="자동 동기화"
                                OnContent="사용"
                                OffContent="미사용"
                                IsEnabled="{x:Bind UseGoogleToggle.IsOn, Mode=OneWay}"
                                Toggled="OnGoogleAutoSyncToggled"/>

                            <NumberBox
                                x:Name="GoogleSyncIntervalNumberBox"
                                Header="동기화 간격 (분)"
                                PlaceholderText="15"
                                SpinButtonPlacementMode="Inline"
                                Minimum="5"
                                Maximum="120"
                                SmallChange="5"
                                LargeChange="15"
                                IsEnabled="{x:Bind UseGoogleToggle.IsOn, Mode=OneWay}"
                                ValueChanged="OnGoogleSyncIntervalChanged"/>

                            <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,4,0,0">
                                <Button
                                    x:Name="GoogleSyncNowButton"
                                    Content="지금 동기화"
                                    IsEnabled="{x:Bind UseGoogleToggle.IsOn, Mode=OneWay}"
                                    Click="OnGoogleSyncNowClicked"/>
                                <ProgressRing
                                    x:Name="GoogleSyncProgressRing"
                                    IsActive="False"
                                    Width="20" Height="20"
                                    Visibility="Collapsed"/>
                            </StackPanel>

                            <TextBlock
                                x:Name="GoogleSyncStatusText"
                                Text=""
                                Margin="0,4,0,0"
                                TextWrapping="Wrap"
                                Opacity="0.7"/>

                            <!-- 학사일정 일괄 등록 -->
                            <TextBlock Text="학사일정 일괄 등록" FontWeight="SemiBold" Margin="0,12,0,4"/>
                            <TextBlock
                                Text="NEIS에서 받아온 학사일정을 Google Calendar에 한번에 등록합니다."
                                Opacity="0.6"
                                TextWrapping="Wrap"/>

                            <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,4,0,0">
                                <Button
                                    x:Name="UploadSchoolScheduleButton"
                                    Content="학사일정 등록"
                                    IsEnabled="{x:Bind UseGoogleToggle.IsOn, Mode=OneWay}"
                                    Click="OnUploadSchoolScheduleClicked"/>
                                <ProgressRing
                                    x:Name="UploadScheduleProgressRing"
                                    IsActive="False"
                                    Width="20" Height="20"
                                    Visibility="Collapsed"/>
                            </StackPanel>

                            <TextBlock
                                x:Name="UploadScheduleStatusText"
                                Text=""
                                Margin="0,4,0,0"
                                TextWrapping="Wrap"
                                Opacity="0.7"/>
                        </StackPanel>
                    </Expander.Content>
                </Expander>

                <!-- 6. 일반 설정 -->
                <Expander Header="일반 설정" IsExpanded="False" HorizontalAlignment="Stretch" Margin="0,0,0,8">
                    <Expander.Content>
                        <StackPanel Spacing="12" Padding="16">

                            <ToggleSwitch 
                                x:Name="TopMostToggle"
                                Header="항상 위에 표시" 
                                OnContent="활성화" 
                                OffContent="비활성화"
                                Toggled="OnTopMostToggled"/>

                            <ComboBox 
                                x:Name="ThemeComboBox"
                                Header="테마" 
                                PlaceholderText="테마 선택"
                                SelectionChanged="OnThemeChanged"
                                HorizontalAlignment="Stretch">
                                <ComboBoxItem Content="라이트" Tag="Light"/>
                                <ComboBoxItem Content="다크" Tag="Dark"/>
                                <ComboBoxItem Content="시스템 설정 따르기" Tag="Default"/>
                            </ComboBox>

                            <ComboBox 
                                x:Name="LanguageComboBox"
                                Header="언어" 
                                PlaceholderText="언어 선택"
                                SelectionChanged="OnLanguageChanged"
                                HorizontalAlignment="Stretch">
                                <ComboBoxItem Content="한국어" Tag="ko-KR"/>
                                <ComboBoxItem Content="English" Tag="en-US"/>
                            </ComboBox>
                        </StackPanel>
                    </Expander.Content>
                </Expander>

                <!-- 7. 성능 및 캐시 설정 -->
                <Expander Header="성능 및 캐시" IsExpanded="False" HorizontalAlignment="Stretch" Margin="0,0,0,8">
                    <Expander.Content>
                        <StackPanel Spacing="12" Padding="16">

                            <ToggleSwitch 
                                x:Name="EnableCacheToggle"
                                Header="캐시 사용" 
                                OnContent="활성화" 
                                OffContent="비활성화"
                                Toggled="OnEnableCacheToggled"/>

                            <NumberBox
                                x:Name="DefaultPageSizeNumberBox"
                                Header="페이지당 항목 수" 
                                PlaceholderText="20"
                                SpinButtonPlacementMode="Inline"
                                Minimum="10"
                                Maximum="100"
                                ValueChanged="OnDefaultPageSizeChanged"/>
                        </StackPanel>
                    </Expander.Content>
                </Expander>

                <!-- 8. 백업 설정 -->
                <Expander Header="백업 및 복원" IsExpanded="False" HorizontalAlignment="Stretch" Margin="0,0,0,8">
                    <Expander.Content>
                        <StackPanel Spacing="12" Padding="16">

                            <ToggleSwitch 
                                x:Name="AutoBackupToggle"
                                Header="자동 백업" 
                                OnContent="활성화" 
                                OffContent="비활성화"
                                Toggled="OnAutoBackupToggled"/>

                            <NumberBox 
                                x:Name="AutoBackupIntervalDaysNumberBox"
                                Header="자동 백업 간격 (일)" 
                                PlaceholderText="7"
                                SpinButtonPlacementMode="Inline"
                                Minimum="1"
                                Maximum="30"
                                IsEnabled="{x:Bind AutoBackupToggle.IsOn, Mode=OneWay}"
                                ValueChanged="OnAutoBackupIntervalDaysChanged"/>

                            <NumberBox 
                                x:Name="BackupRetentionCountNumberBox"
                                Header="백업 보관 개수" 
                                PlaceholderText="20"
                                SpinButtonPlacementMode="Inline"
                                Minimum="1"
                                Maximum="100"
                                ValueChanged="OnBackupRetentionCountChanged"/>

                            <Grid ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <Button 
                                    Grid.Column="0"
                                    Content="지금 백업" 
                                    Click="OnBackupClick"
                                    HorizontalAlignment="Stretch"/>

                                <Button 
                                    Grid.Column="1"
                                    Content="복원..." 
                                    Click="OnRestoreClick"
                                    HorizontalAlignment="Stretch"/>
                            </Grid>
                        </StackPanel>
                    </Expander.Content>
                </Expander>

                <!-- 9. 고급 설정 -->
                <Expander Header="고급" IsExpanded="False" HorizontalAlignment="Stretch" Margin="0,0,0,8">
                    <Expander.Content>
                        <StackPanel Spacing="12" Padding="16">

                            <ComboBox 
                                x:Name="LogLevelComboBox"
                                Header="로그 레벨" 
                                PlaceholderText="로그 레벨 선택"
                                SelectionChanged="OnLogLevelChanged"
                                HorizontalAlignment="Stretch">
                                <ComboBoxItem Content="Debug" Tag="Debug"/>
                                <ComboBoxItem Content="Info" Tag="Info"/>
                                <ComboBoxItem Content="Warning" Tag="Warning"/>
                                <ComboBoxItem Content="Error" Tag="Error"/>
                            </ComboBox>

                            <Grid ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <Button 
                                    Grid.Column="0"
                                    Content="설정 초기화" 
                                    Click="OnResetSettingsClick"
                                    HorizontalAlignment="Stretch"/>

                                <Button 
                                    Grid.Column="1"
                                    Content="설정 정보 출력" 
                                    Click="OnPrintSettingsClick"
                                    HorizontalAlignment="Stretch"/>
                            </Grid>
                        </StackPanel>
                    </Expander.Content>
                </Expander>

                <!-- 하단 여백 -->
                <Border Height="40"/>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>

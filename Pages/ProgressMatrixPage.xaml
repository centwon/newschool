<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="NewSchool.Pages.ProgressMatrixPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:NewSchool.Pages"
    xmlns:models="using:NewSchool.Models"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Grid Padding="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 헤더 -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="16" Margin="0,0,0,16">
            <TextBlock Text="진도 관리" Style="{StaticResource TitleTextBlockStyle}"/>

            <!-- 수업 선택 -->
            <ComboBox x:Name="CmbCourse"
                      Width="300"
                      PlaceholderText="수업 선택"
                      SelectionChanged="OnCourseSelectionChanged">
                <ComboBox.ItemTemplate>
                    <DataTemplate x:DataType="models:Course">
                        <TextBlock Text="{x:Bind DisplayName}"/>
                    </DataTemplate>
                </ComboBox.ItemTemplate>
            </ComboBox>

            <!-- 새로고침 -->
            <Button x:Name="BtnRefresh"
                    Click="OnRefreshClick"
                    ToolTipService.ToolTip="새로고침">
                <SymbolIcon Symbol="Refresh"/>
            </Button>

            <Border Width="1" Background="{ThemeResource DividerStrokeColorDefaultBrush}" Margin="8,4"/>

            <!-- 격차 분석 -->
            <Button x:Name="BtnAnalyze"
                    Click="OnAnalyzeClick"
                    IsEnabled="False">
                <StackPanel Orientation="Horizontal" Spacing="4">
                    <FontIcon Glyph="&#xE9D9;" FontSize="14"/>
                    <TextBlock Text="격차 분석"/>
                </StackPanel>
            </Button>

            <!-- 일정 동기화 -->
            <Button x:Name="BtnSync"
                    Click="OnSyncClick"
                    IsEnabled="False">
                <StackPanel Orientation="Horizontal" Spacing="4">
                    <FontIcon Glyph="&#xE895;" FontSize="14"/>
                    <TextBlock Text="일정 동기화"/>
                </StackPanel>
            </Button>

            <!-- 엑셀 내보내기 -->
            <Button x:Name="BtnExport"
                    Click="OnExportClick"
                    IsEnabled="False">
                <StackPanel Orientation="Horizontal" Spacing="4">
                    <FontIcon Glyph="&#xEDE1;" FontSize="14"/>
                    <TextBlock Text="엑셀"/>
                </StackPanel>
            </Button>
        </StackPanel>

        <!-- 매트릭스 영역 -->
        <Border Grid.Row="1"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="4">
            <ScrollViewer HorizontalScrollBarVisibility="Auto"
                          VerticalScrollBarVisibility="Auto">
                <Grid x:Name="MatrixGrid" Margin="0">
                    <!-- 동적으로 생성됨 -->
                </Grid>
            </ScrollViewer>
        </Border>

        <!-- 하단 요약 패널 -->
        <Grid Grid.Row="2" Margin="0,16,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- 격차 정보 -->
            <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="24">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <TextBlock Text="전체 단원:" Opacity="0.7"/>
                    <TextBlock x:Name="TxtTotalSections" Text="0" FontWeight="SemiBold"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal" Spacing="8">
                    <TextBlock Text="선두 학급:" Opacity="0.7"/>
                    <TextBlock x:Name="TxtLeadingRoom" Text="-" FontWeight="SemiBold" Foreground="#4CAF50"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal" Spacing="8">
                    <TextBlock Text="최대 격차:" Opacity="0.7"/>
                    <TextBlock x:Name="TxtMaxGap" Text="0" FontWeight="SemiBold"/>
                </StackPanel>
            </StackPanel>

            <!-- 범례 -->
            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="16">
                <StackPanel Orientation="Horizontal" Spacing="4">
                    <Border Background="#4CAF50" Width="16" Height="16" CornerRadius="2"/>
                    <TextBlock Text="완료" FontSize="12"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Spacing="4">
                    <Border Background="#2196F3" Width="16" Height="16" CornerRadius="2"/>
                    <TextBlock Text="보강" FontSize="12"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Spacing="4">
                    <Border Background="#9C27B0" Width="16" Height="16" CornerRadius="2"/>
                    <TextBlock Text="병합" FontSize="12"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Spacing="4">
                    <Border Background="#FF9800" Width="16" Height="16" CornerRadius="2"/>
                    <TextBlock Text="건너뜀" FontSize="12"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Spacing="4">
                    <Border Background="#F44336" Width="16" Height="16" CornerRadius="2"/>
                    <TextBlock Text="결강" FontSize="12"/>
                </StackPanel>
            </StackPanel>
        </Grid>

        <!-- 로딩 오버레이 -->
        <Grid x:Name="LoadingOverlay"
              Grid.RowSpan="5"
              Background="{ThemeResource AcrylicBackgroundFillColorBaseBrush}"
              Visibility="Collapsed">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="16">
                <ProgressRing IsActive="True" Width="48" Height="48"/>
                <TextBlock x:Name="TxtLoadingMessage" Text="로딩 중..." HorizontalAlignment="Center"/>
            </StackPanel>
        </Grid>
    </Grid>
</Page>

<Page
    x:Class="NewSchool.Pages.TodayPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:local="using:NewSchool.Pages"
    xmlns:models="using:NewSchool.Models"
    xmlns:vm="using:NewSchool.ViewModels"
    xmlns:controls="using:NewSchool.Controls"
    xmlns:scheduler="using:NewSchool.Scheduler"
    xmlns:board="using:NewSchool.Board.Controls"
    mc:Ignorable="d"
    Background="{ThemeResource LayerFillColorDefaultBrush}"
    Loaded="Page_Loaded" >

    <Grid Padding="16,8,16,16" RowSpacing="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ═══ 상단: 오늘 날짜 · 오늘 학사일정 · 현재 교시 ═══ -->
        <Border Grid.Row="0" Style="{StaticResource DashboardCard}" Padding="14,10">
            <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                <TextBlock x:Name="TxtTodayDate"
                           FontSize="18" FontWeight="SemiBold" VerticalAlignment="Center"/>
                <TextBlock x:Name="TxtTodayDow"
                           FontSize="18" FontWeight="SemiBold" VerticalAlignment="Center"
                           Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"/>
                <TextBlock x:Name="TxtTodayEvent"
                           FontSize="13" VerticalAlignment="Center"
                           MaxWidth="360" TextTrimming="CharacterEllipsis"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                           Visibility="Collapsed"/>
                <Border Background="{ThemeResource SystemFillColorAttentionBackgroundBrush}"
                        CornerRadius="10" Padding="10,2" VerticalAlignment="Center">
                    <TextBlock x:Name="TxtCurrentPeriod"
                               FontSize="12" FontWeight="SemiBold"
                               Foreground="{ThemeResource SystemFillColorAttentionBrush}"/>
                </Border>
            </StackPanel>
        </Border>

        <!-- ═══ 메인 콘텐츠 ═══ -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="260" />
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="*" MinWidth="200"/>
            </Grid.ColumnDefinitions>

            <!-- 좌측 패널: 시간표, 학사일정, 급식 -->
            <Grid RowSpacing="12" Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- 시간표 카드: 내 수업 | 우리 반 (오늘 슬롯) -->
                <Border Grid.Row="0" Style="{StaticResource DashboardCard}">
                    <Grid x:Name="TimetableTable">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition x:Name="ClassColumn" Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- 헤더: 내 수업 -->
                        <Border Grid.Row="0" Grid.Column="0"
                                Style="{StaticResource DashboardCardHeader}"
                                CornerRadius="7,0,0,0" Padding="10,7">
                            <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                                <FontIcon Glyph="&#xE8D3;" Style="{StaticResource DashboardCardHeaderIcon}" FontSize="14"/>
                                <TextBlock Text="내 수업" Style="{StaticResource DashboardCardHeaderTitle}" FontSize="13"/>
                            </StackPanel>
                        </Border>

                        <!-- 헤더: 우리 반 -->
                        <Border x:Name="ClassHeaderCell" Grid.Row="0" Grid.Column="1"
                                Style="{StaticResource DashboardCardHeader}"
                                CornerRadius="0,7,0,0" Padding="10,7" BorderThickness="1,0,0,1">
                            <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                                <FontIcon Glyph="&#xE716;" Style="{StaticResource DashboardCardHeaderIcon}" FontSize="14"/>
                                <TextBlock Text="우리 반" Style="{StaticResource DashboardCardHeaderTitle}" FontSize="13"/>
                            </StackPanel>
                        </Border>

                        <!-- 본문: 내 수업 -->
                        <Grid Grid.Row="1" Grid.Column="0" MinHeight="56">
                            <TextBlock x:Name="TxtNoTeacherSlots" Text="수업 없음"
                                       HorizontalAlignment="Center" Margin="0,12" FontSize="11"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            <ItemsControl x:Name="TeacherSlotsList" Padding="4,4,4,8" Visibility="Collapsed">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="vm:TimetableItemViewModel">
                                        <Grid Margin="4,1" MinHeight="20" ColumnSpacing="6">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="22"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <Border Grid.Column="0" Background="{ThemeResource SystemFillColorAttentionBackgroundBrush}"
                                                    CornerRadius="4" Padding="0,2" VerticalAlignment="Center">
                                                <TextBlock Text="{x:Bind Period}" FontSize="11" FontWeight="SemiBold"
                                                           HorizontalAlignment="Center"
                                                           Foreground="{ThemeResource SystemFillColorAttentionBrush}"/>
                                            </Border>
                                            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                                                <TextBlock Text="{x:Bind SubjectName}" FontSize="12"
                                                           TextTrimming="CharacterEllipsis"/>
                                                <TextBlock Text="{x:Bind Room}" FontSize="12"
                                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                            </StackPanel>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Grid>

                        <!-- 본문: 우리 반 -->
                        <Grid x:Name="ClassBodyCell" Grid.Row="1" Grid.Column="1" MinHeight="56">
                            <TextBlock x:Name="TxtNoClassSlots" Text="시간표 없음"
                                       HorizontalAlignment="Center" Margin="0,12" FontSize="11"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            <ItemsControl x:Name="ClassSlotsList" Padding="4,4,4,8" Visibility="Collapsed">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="models:ClassTimetable">
                                        <Grid Margin="4,1" MinHeight="20" ColumnSpacing="6">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="22"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <Border Grid.Column="0" Background="{ThemeResource SystemFillColorAttentionBackgroundBrush}"
                                                    CornerRadius="4" Padding="0,2" VerticalAlignment="Center">
                                                <TextBlock Text="{x:Bind Period}" FontSize="11" FontWeight="SemiBold"
                                                           HorizontalAlignment="Center"
                                                           Foreground="{ThemeResource SystemFillColorAttentionBrush}"/>
                                            </Border>
                                            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                                                <TextBlock Text="{x:Bind SubjectName}" FontSize="12"
                                                           TextTrimming="CharacterEllipsis"/>
                                                <TextBlock Text="{x:Bind TeacherName}" FontSize="12"
                                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                            </StackPanel>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Grid>
                    </Grid>
                </Border>

                <!-- 학사일정 카드 -->
                <controls:SchoolScheduleListControl x:Name="ScheduleList" Grid.Row="1"/>

                <!-- 급식 카드 -->
                <controls:SchoolMealBox x:Name="MealBox" Grid.Row="2"/>
            </Grid>

            <!-- 우측 패널: 할 일 목록 + 메모보드 -->
            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="270"/>
                    <RowDefinition Height="16"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- 할 일 + 일정 통합 카드 -->
                <scheduler:KAgendaControl Grid.Row="0"
                            x:Name="AgendaList"
                            Background="Transparent"/>

                <!-- 메모보드 컨텐츠 -->
                <board:MemoBoard Grid.Row="2"
                        x:Name="MemoBoard"
                        ShowFilter="True"/>
            </Grid>
        </Grid>
    </Grid>
</Page>

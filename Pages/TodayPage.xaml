<Page
    x:Class="NewSchool.Pages.TodayPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:local="using:NewSchool.Pages"
    xmlns:models="using:NewSchool.Models"
    xmlns:controls="using:NewSchool.Controls"
    xmlns:scheduler="using:NewSchool.Scheduler"
    xmlns:board="using:NewSchool.Board.Controls"
    mc:Ignorable="d"
    Background="{ThemeResource LayerFillColorDefaultBrush}"
    Loaded="Page_Loaded" >

    <Grid Padding="16,8,16,16">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260" />
            <ColumnDefinition Width="16"/>
            <ColumnDefinition Width="*" MinWidth="200"/>
        </Grid.ColumnDefinitions>

        <!-- 좌측 패널: 시간표, 학사일정, 급식 -->
        <Grid RowSpacing="12" Grid.Column="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <!-- 수업 시간표 카드 -->
            <Border  Grid.Row="0"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="CornflowerBlue"
                    BorderThickness="1"
                    CornerRadius="8">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="34"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- 헤더 -->
                    <Grid Grid.Row="0" Padding="12,8" 
                              Background="Lavender"
                              CornerRadius="8,8,0,0">
                        <TextBlock 
                                Text="📚 수업 시간표" 
                                FontWeight="Bold"
                                VerticalAlignment="Center" 
                                FontSize="14"/>
                    </Grid>

                    <!-- 시간표 컨텐츠 -->
                    <Border Grid.Row="1" Padding="6">
                        <Viewbox Stretch="Uniform" MaxHeight="280">
                            <controls:TimetableControl 
                                    x:Name="LecTimeTable" 
                                    Width="260" Height="260"
                                   />
                        </Viewbox>
                    </Border>
                </Grid>
            </Border>

            <!-- 학사일정 카드 -->
            <controls:SchoolScheduleListControl x:Name="ScheduleList" Grid.Row="1"/>

            <!-- 급식 카드 -->
            <controls:SchoolMealBox x:Name="MealBox" Grid.Row="2"/>
        </Grid>


        <!-- 우측 패널: 할 일 목록 + 메모보드 -->
        <Grid Grid.Column="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="270"/>
                <RowDefinition Height="16"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- 할 일 + 일정 통합 카드 -->
            <scheduler:KAgendaControl Grid.Row="0"
                        x:Name="AgendaList"
                        Background="Transparent"/>



            <!-- 메모보드 컨텐츠 -->
            <board:MemoBoard Grid.Row="2"
                    x:Name="MemoBoard"
                    ShowFilter="True"/>
        </Grid>
    </Grid>
</Page>

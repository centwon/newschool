<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="NewSchool.Pages.PageSeats"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:controls="using:NewSchool.Controls"
    mc:Ignorable="d"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Grid Margin="0" SizeChanged="GridBody_SizeChanged">
        <Grid.RowDefinitions>
            <RowDefinition Height="48"/>
            <RowDefinition x:Name="RowBody" Height="*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition x:Name="ColBody" Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- 상단 헤더 (학년/학급 선택) -->
        <StackPanel Grid.Row="0" Grid.Column="0" 
                    Orientation="Horizontal" 
                    Spacing="8" 
                    Padding="2">
            <ComboBox x:Name="CBoxGrade" 
                      PlaceholderText="학년"
                      MinWidth="100"
                      SelectionChanged="CBoxGrade_SelectionChanged"/>
            <ComboBox x:Name="CBoxRooms" 
                      PlaceholderText="학급"
                      MinWidth="100"
                      SelectionChanged="CBoxRooms_SelectionChanged"/>
        </StackPanel>

        <!-- 좌측 학생 목록 -->
        <Border Grid.Row="1" Grid.Column="0" 
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="0,0,1,0"
                Padding="8"
                MinWidth="200">
            <controls:ListStudent x:Name="StudentList"
                                  ViewMode="NumName"
                                  ShowCheckBox="False"/>
        </Border>

        <!-- 상단 툴바 -->
        <Grid Grid.Row="0" Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- 선택된 학생 정보 표시 -->
            <InfoBar x:Name="SelectedStudentInfoBar"
                     Grid.Row="0"
                     Grid.ColumnSpan="3"
                     Severity="Informational"
                     IsOpen="False"
                     IsClosable="True"
                     Margin="8,8,8,4">
                <InfoBar.Title>학생 선택됨</InfoBar.Title>
                <InfoBar.Message>좌석을 클릭하여 배치하세요</InfoBar.Message>
            </InfoBar>

            <!-- 배열 설정 -->
            <Border Grid.Row="1"
                    Grid.Column="0"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="4"
                    Padding="12,4"
                    Margin="2">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <TextBlock Text="배열 :" 
                              VerticalAlignment="Center"/>
                    <ComboBox x:Name="CBoxJul" 
                              PlaceholderText="줄"
                              MinWidth="80"
                              SelectionChanged="CBoxJul_SelectionChanged"/>
                    <ComboBox x:Name="CBoxJJak" 
                              PlaceholderText="짝"
                              MinWidth="80"
                              SelectionChanged="CBoxJJak_SelectionChanged"/>
                </StackPanel>
            </Border>

            <!-- 우측 버튼들 -->
            <StackPanel Grid.Row="1"
                       Grid.Column="2" 
                       Orientation="Horizontal" 
                       Spacing="8"
                       Padding="8"
                       HorizontalAlignment="Right">
                <CheckBox x:Name="ChkViewPhoto" 
                         Content="사진 표시"
                         Click="ChkViewPhoto_Click"/>
                <Button x:Name="BtnInit" 
                       Content="초기화"
                       Click="BtnInit_Click"/>
                <Button x:Name="BtnArrange" 
                       Content="자동배정"
                       Style="{StaticResource AccentButtonStyle}"
                       Click="BtnArrange_Click"/>
                <Button x:Name="BtnPrint" 
                       Click="BtnPrint_Click"
                       ToolTipService.ToolTip="인쇄">
                    <FontIcon Glyph="&#xE749;" FontSize="16"/>
                </Button>
            </StackPanel>
        </Grid>

        <!-- 좌석 배치 영역 -->
        <Grid Grid.Row="1" Grid.Column="1" 
              Background="{ThemeResource LayerFillColorDefaultBrush}"
              Padding="16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="48"/>
            </Grid.RowDefinitions>

            <!-- 설명 입력 -->
            <TextBox x:Name="TboxMessage" 
                     Grid.Row="0"
                     PlaceholderText="설명 입력..."
                     Margin="0,0,0,8"/>

            <!-- 좌석 배치 Canvas -->
            <Canvas x:Name="Room" 
                    Grid.Row="1"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    AllowDrop="True"
                    DragOver="Room_DragOver"
                    Drop="Room_Drop"/>

            <!-- 교탁 -->
            <Border Grid.Row="2"
                    Background="{ThemeResource AccentFillColorDefaultBrush}"
                    CornerRadius="4"
                    Padding="16,8"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Top"
                    Margin="0,8,0,0">
                <TextBlock x:Name="TBTable" 
                          Text="교탁"
                          FontSize="16"
                          FontWeight="Bold"
                          Foreground="{ThemeResource TextOnAccentFillColorPrimaryBrush}"/>
            </Border>
        </Grid>
    </Grid>
</Page>

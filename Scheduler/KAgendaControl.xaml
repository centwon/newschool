<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="NewSchool.Scheduler.KAgendaControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:local="using:NewSchool.Scheduler"
    mc:Ignorable="d">

    <UserControl.Resources>
        <local:BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <local:StringNotEmptyToVisibilityConverter x:Key="StrToVis"/>

        <!-- 날짜 헤더 템플릿 -->
        <DataTemplate x:Key="HeaderTemplate" x:DataType="local:AgendaHeader">
            <Border Padding="8,4,8,2"
                    Background="#F0F4FF"
                    BorderBrush="#C5D0F0"
                    BorderThickness="0,0,0,1"
                    Margin="0,4,0,0">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <TextBlock Text="{x:Bind DateHeader}"
                               FontWeight="SemiBold"
                               FontSize="12"
                               Foreground="#3F51B5"/>
                    <TextBlock Text="{x:Bind CountLabel}"
                               FontSize="11"
                               Foreground="#7986CB"
                               VerticalAlignment="Center"/>
                </StackPanel>
            </Border>
        </DataTemplate>

        <!-- 개별 항목 템플릿 -->
        <DataTemplate x:Key="ItemTemplate" x:DataType="local:AgendaItem">
            <Grid Padding="8,4" MinHeight="32">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="18"/>
                    <ColumnDefinition Width="90"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- 유형 아이콘 -->
                <TextBlock Grid.Column="0"
                           Text="{x:Bind TypeIcon, Mode=OneWay}"
                           FontSize="10"
                           VerticalAlignment="Center"
                           Foreground="{x:Bind local:KAgendaControl.HexToBrush(AccentColor), Mode=OneWay}"/>

                <!-- 시간 라벨 -->
                <TextBlock Grid.Column="1"
                           Text="{x:Bind TimeLabel}"
                           FontSize="10"
                           Foreground="#777"
                           VerticalAlignment="Center"
                           Margin="2,0,4,0"/>

                <!-- 제목 -->
                <TextBlock Grid.Column="2"
                           Text="{x:Bind Title}"
                           FontSize="12"
                           TextDecorations="{x:Bind Decorations, Mode=OneWay}"
                           TextTrimming="CharacterEllipsis"
                           TextWrapping="NoWrap"
                           VerticalAlignment="Center"
                           Opacity="{x:Bind TitleOpacity, Mode=OneWay}"/>

                <!-- 분류 배지 -->
                <Border Grid.Column="3"
                        CornerRadius="3"
                        Padding="5,1"
                        Margin="4,0,2,0"
                        Height="22"
                        Background="{x:Bind local:KAgendaControl.HexToBrush(BadgeBackground)}"
                        Visibility="{x:Bind CategoryName, Converter={StaticResource StrToVis}}">
                    <TextBlock Text="{x:Bind CategoryName}"
                               FontSize="9"
                               VerticalAlignment="Center"
                               Foreground="White"/>
                </Border>

                <!-- 완료 토글 버튼 (할일만) -->
                <ToggleButton Grid.Column="4"
                              Tag="{x:Bind}"
                              IsChecked="{x:Bind IsTaskDone, Mode=OneWay}"
                              Click="TaskToggle_Click"
                              Visibility="{x:Bind IsTask, Converter={StaticResource BoolToVis}}"
                              MinWidth="44" Height="22"
                              FontSize="10"
                              Padding="5,1"
                              Margin="4,0,0,0"
                              VerticalAlignment="Center"
                              Content="{x:Bind DoneLabel, Mode=OneWay}"/>
            </Grid>
        </DataTemplate>

        <!-- DataTemplateSelector -->
        <local:AgendaTemplateSelector x:Key="AgendaSelector"
                                      HeaderTemplate="{StaticResource HeaderTemplate}"
                                      ItemTemplate="{StaticResource ItemTemplate}"/>
    </UserControl.Resources>

    <Border BorderBrush="CornflowerBlue" BorderThickness="1" CornerRadius="5" Background="White">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="36"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- ── 헤더 ── -->
            <Border Grid.Row="0"
                    Background="Lavender"
                    BorderBrush="CornflowerBlue"
                    BorderThickness="0,0,0,1"
                    CornerRadius="5,5,0,0">
                <Grid Padding="8,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="4"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0" Text="📋"
                               FontSize="14" VerticalAlignment="Center"
                               Margin="0,0,6,0"/>

                    <ComboBox x:Name="CBoxFilter" Grid.Column="1"
                              Height="26" FontSize="11" MinWidth="70"
                              Padding="6,2" VerticalAlignment="Center"
                              SelectionChanged="CBoxFilter_SelectionChanged"/>

                    <ToggleButton x:Name="TbTask" Grid.Column="3"
                                  Content="✓ 할 일"
                                  IsChecked="True"
                                  Height="24" FontSize="11"
                                  Padding="6,2"
                                  VerticalAlignment="Center"
                                  Checked="Filter_Changed"
                                  Unchecked="Filter_Changed"/>

                    <ToggleButton x:Name="TbEvent" Grid.Column="5"
                                  Content="📅 일정"
                                  IsChecked="True"
                                  Height="24" FontSize="11"
                                  Padding="6,2"
                                  VerticalAlignment="Center"
                                  Checked="Filter_Changed"
                                  Unchecked="Filter_Changed"/>

                    <Button x:Name="BtnAdd" Grid.Column="7"
                            Click="BtnAdd_Click"
                            Width="26" Height="26"
                            Background="Transparent"
                            BorderThickness="0"
                            Padding="0"
                            VerticalAlignment="Center"
                            ToolTipService.ToolTip="새 항목 추가">
                        <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}"
                                  Glyph="&#xECC8;" FontSize="15"/>
                    </Button>
                </Grid>
            </Border>

            <!-- ── 목록 본문 ── -->
            <ListView x:Name="AgendaListView"
                      Grid.Row="1"
                      ItemTemplateSelector="{StaticResource AgendaSelector}"
                      SelectionMode="Single"
                      IsItemClickEnabled="True"
                      ItemClick="AgendaListView_ItemClick"
                      Background="Transparent">

                <ListView.ItemContainerStyle>
                    <Style TargetType="ListViewItem">
                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                        <Setter Property="Padding" Value="0"/>
                        <Setter Property="MinHeight" Value="0"/>
                    </Style>
                </ListView.ItemContainerStyle>
            </ListView>
        </Grid>
    </Border>
</UserControl>

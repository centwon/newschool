<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="NewSchool.Scheduler.KAgendaControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:local="using:NewSchool.Scheduler"
    mc:Ignorable="d">

    <UserControl.Resources>
        <local:BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <local:StringNotEmptyToVisibilityConverter x:Key="StrToVis"/>

        <!-- 개별 항목 템플릿: [분류 배지][날짜][시간] [제목][완료/진행] -->
        <DataTemplate x:Key="ItemTemplate" x:DataType="local:AgendaItem">
            <Grid Padding="8,4" MinHeight="32">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="76"/>
                    <ColumnDefinition Width="80"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- 분류 배지 (할일/일정 구분은 맨 끝 완료·진행 토글 유무로 충분) -->
                <Border Grid.Column="0"
                        CornerRadius="3"
                        Padding="5,1"
                        Height="20"
                        MinWidth="34"
                        Margin="0,0,6,0"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Center"
                        Background="{x:Bind local:KAgendaControl.HexToBrush(BadgeBackground), Mode=OneWay}"
                        Visibility="{x:Bind CategoryName, Converter={StaticResource StrToVis}}">
                    <TextBlock Text="{x:Bind CategoryName}"
                               FontSize="11"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               Foreground="White"/>
                </Border>

                <!-- 날짜 -->
                <TextBlock Grid.Column="1"
                           Text="{x:Bind DateLabel}"
                           FontSize="13"
                           Foreground="#777"
                           TextTrimming="CharacterEllipsis"
                           VerticalAlignment="Center"
                           Margin="2,0,4,0"/>

                <!-- 시간 -->
                <TextBlock Grid.Column="2"
                           Text="{x:Bind TimeLabel}"
                           FontSize="13"
                           Foreground="#777"
                           VerticalAlignment="Center"
                           Margin="0,0,4,0"/>

                <!-- 제목 -->
                <TextBlock Grid.Column="3"
                           Text="{x:Bind Title}"
                           FontSize="13"
                           TextDecorations="{x:Bind Decorations, Mode=OneWay}"
                           TextTrimming="CharacterEllipsis"
                           TextWrapping="NoWrap"
                           VerticalAlignment="Center"
                           Opacity="{x:Bind TitleOpacity, Mode=OneWay}"/>

                <!-- 완료/진행 (할일만) -->
                <ToggleButton Grid.Column="4"
                              Tag="{x:Bind}"
                              IsChecked="{x:Bind IsTaskDone, Mode=OneWay}"
                              Click="TaskToggle_Click"
                              Visibility="{x:Bind IsTask, Converter={StaticResource BoolToVis}}"
                              MinWidth="44" Height="22"
                              FontSize="10"
                              Padding="5,1"
                              Margin="4,0,0,0"
                              VerticalAlignment="Center"
                              Content="{x:Bind DoneLabel, Mode=OneWay}"/>
            </Grid>
        </DataTemplate>
    </UserControl.Resources>

    <Border Style="{StaticResource DashboardCard}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- ── 헤더 ── -->
            <Border Grid.Row="0" Style="{StaticResource DashboardCardHeader}" Padding="8,4">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="4"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <FontIcon Grid.Column="0" Glyph="&#xE8FD;"
                              Style="{StaticResource DashboardCardHeaderIcon}"
                              Margin="0,0,6,0"/>

                    <ComboBox x:Name="CBoxFilter" Grid.Column="1"
                              Height="26" FontSize="11" MinWidth="70"
                              Padding="6,2" VerticalAlignment="Center"
                              SelectionChanged="CBoxFilter_SelectionChanged"/>

                    <ToggleButton x:Name="TbTask" Grid.Column="3"
                                  Content="✓ 할 일"
                                  IsChecked="True"
                                  Height="24" FontSize="11"
                                  Padding="6,2"
                                  VerticalAlignment="Center"
                                  Checked="Filter_Changed"
                                  Unchecked="Filter_Changed"/>

                    <ToggleButton x:Name="TbEvent" Grid.Column="5"
                                  Content="📅 일정"
                                  IsChecked="True"
                                  Height="24" FontSize="11"
                                  Padding="6,2"
                                  VerticalAlignment="Center"
                                  Checked="Filter_Changed"
                                  Unchecked="Filter_Changed"/>

                    <Button x:Name="BtnAdd" Grid.Column="7"
                            Click="BtnAdd_Click"
                            Width="26" Height="26"
                            Background="Transparent"
                            BorderThickness="0"
                            Padding="0"
                            VerticalAlignment="Center"
                            ToolTipService.ToolTip="새 항목 추가">
                        <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}"
                                  Glyph="&#xECC8;" FontSize="15"/>
                    </Button>
                </Grid>
            </Border>

            <!-- ── 목록 본문 ── -->
            <ListView x:Name="AgendaListView"
                      Grid.Row="1"
                      ItemTemplate="{StaticResource ItemTemplate}"
                      SelectionMode="Single"
                      IsItemClickEnabled="True"
                      ItemClick="AgendaListView_ItemClick"
                      Background="Transparent"
                      ScrollViewer.VerticalScrollBarVisibility="Auto">

                <ListView.ItemContainerStyle>
                    <Style TargetType="ListViewItem">
                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                        <Setter Property="Padding" Value="0"/>
                        <Setter Property="MinHeight" Value="0"/>
                    </Style>
                </ListView.ItemContainerStyle>
            </ListView>
        </Grid>
    </Border>
</UserControl>

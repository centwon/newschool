<UserControl
    x:Class="NewSchool.Scheduler.DayCell"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:local="using:NewSchool.Scheduler"
    xmlns:newschool="using:NewSchool"
    mc:Ignorable="d">

    <UserControl.Resources>
        <!-- 색상 리소스 -->
        <SolidColorBrush x:Key="BorderColor" Color="#E0E0E0"/>
        <SolidColorBrush x:Key="HolidayColor" Color="#FF4444"/>
        <SolidColorBrush x:Key="SaturdayColor" Color="#4444FF"/>
        <SolidColorBrush x:Key="SundayColor" Color="#FF4444"/>
        <SolidColorBrush x:Key="VacationColor" Color="#FFA500"/>
        <SolidColorBrush x:Key="TaskHoverColor" Color="#E6F4FF"/>
        <SolidColorBrush x:Key="TodayHighlightColor" Color="#FFF8DC"/>
        <!-- 컨버터 -->
        <local:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
        <local:DayOfWeekToColorConverter x:Key="DayOfWeekToColorConverter"/>
        <local:StringNotEmptyToVisibilityConverter x:Key="StringNotEmptyToVisibilityConverter"/>

    </UserControl.Resources>

    <!-- 오른쪽과 아래쪽 테두리만 표시 (0,0,0.5,0.5) -->
    <Border x:Name="BrdBase" 
            BorderBrush="{StaticResource BorderColor}" 
            BorderThickness="0,0,0.5,0.5"
            CornerRadius="0"
            Background="White">

        <Grid x:Name="GridBase">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- 헤더 영역 -->
            <Grid Grid.Row="0" Padding="6,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- 날짜 -->
                <TextBlock x:Name="LbDate" 
                           Grid.Column="0"
                           FontWeight="Bold" 
                           FontSize="12"
                           VerticalAlignment="Center"
                           Margin="0,0,8,0"/>

                <!-- 날짜 이름 (공휴일 등) -->
                <TextBlock x:Name="TbDateName" 
                           Grid.Column="1"
                           FontSize="9"
                           TextTrimming="CharacterEllipsis"
                           VerticalAlignment="Center"
                           Opacity="0.8"/>

                <!-- 작업 개수 배지 -->
                <Border x:Name="TaskCountBadge" 
                        Grid.Column="2"
                        Background="{StaticResource TaskHoverColor}"
                        CornerRadius="10"
                        Padding="6,2"
                        Visibility="Collapsed">
                    <TextBlock x:Name="TaskCountText" 
                               FontSize="10"
                               FontWeight="SemiBold"/>
                </Border>
            </Grid>

            <!-- 이벤트+작업 목록 영역 -->
            <ScrollViewer x:Name="SV" 
                          Grid.Row="1"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          Padding="2">
                <StackPanel>

                <!-- 이벤트 목록 (KEvent) -->
                <ItemsRepeater x:Name="EventsRepeater">
                    <ItemsRepeater.ItemTemplate>
                        <DataTemplate x:DataType="local:KEvent">
                            <Border x:Name="EventItem"
                                    CornerRadius="3"
                                    Margin="2,1,2,1"
                                    Padding="4,2"
                                    Background="#4285F4"
                                    Tag="{x:Bind}"
                                    PointerPressed="EventItem_PointerPressed"
                                    PointerEntered="EventItem_PointerEntered"
                                    PointerExited="EventItem_PointerExited">
                                <StackPanel Orientation="Horizontal" Spacing="4">
                                    <TextBlock Text="{x:Bind TimeLabel, Mode=OneWay}"
                                               FontSize="9" Foreground="White"
                                               VerticalAlignment="Center"
                                               Visibility="{x:Bind TimeLabel, Converter={StaticResource StringNotEmptyToVisibilityConverter}, Mode=OneWay}"/>
                                    <TextBlock Text="{x:Bind Title, Mode=OneWay}"
                                               FontSize="10" Foreground="White"
                                               FontWeight="SemiBold"
                                               TextTrimming="CharacterEllipsis"
                                               TextWrapping="NoWrap"
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsRepeater.ItemTemplate>
                </ItemsRepeater>

                <!-- 작업 목록 (KEvent, ItemType="task") -->
                <ItemsRepeater x:Name="TasksRepeater">
                    <ItemsRepeater.ItemTemplate>
                        <DataTemplate x:DataType="local:KEvent">
                            <Grid Tag="{x:Bind}"
                                  PointerEntered="TaskItem_PointerEntered" 
                                  PointerExited="TaskItem_PointerExited"
                                  PointerPressed="TaskItem_PointerPressed"
                                  Background="Transparent"
                                  Margin="8,0,2,0"
                                  Padding="0"
                                  IsHitTestVisible="True">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>  <!-- 상태 버튼 -->
                                    <ColumnDefinition Width="*"/>     <!-- 제목 -->
                                </Grid.ColumnDefinitions>

                                <!-- 상태 토글 버튼 (글머리 역할) -->
                                <Button Grid.Column="0"
                                        Tag="{x:Bind}"
                                        Click="TaskToggleButton_Click"
                                        MinWidth="0" MinHeight="0"
                                        Padding="2,0"
                                        BorderThickness="0"
                                        Background="Transparent"
                                        VerticalAlignment="Center"
                                        Margin="0,0,2,0">
                                    <TextBlock Text="{x:Bind local:DayCell.ToStatusLabel(IsDone), Mode=OneWay}"
                                               FontSize="8"
                                               Foreground="{x:Bind local:DayCell.ToStatusColor(IsDone), Mode=OneWay}"/>
                                </Button>

                                <!-- 제목 -->
                                <TextBlock Grid.Column="1" 
                                           Text="{x:Bind Title, Mode=OneWay}" 
                                           FontSize="11" 
                                           TextDecorations="{x:Bind TextDecorations, Mode=OneWay}"
                                           TextTrimming="CharacterEllipsis" 
                                           TextWrapping="NoWrap"
                                           VerticalAlignment="Center"/>
                            </Grid>
                        </DataTemplate>
                    </ItemsRepeater.ItemTemplate>
                </ItemsRepeater>
                </StackPanel>
            </ScrollViewer>

            <!-- 오늘 날짜 강조 효과 -->
            <Rectangle x:Name="TodayHighlight"
                       Grid.RowSpan="2"
                       Fill="{StaticResource TodayHighlightColor}"
                       Opacity="0.3"
                       IsHitTestVisible="False"
                       Visibility="Collapsed"/>
        </Grid>
    </Border>
</UserControl>

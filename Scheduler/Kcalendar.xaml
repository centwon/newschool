<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="NewSchool.Scheduler.Kcalendar"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:NewSchool.Scheduler"
    xmlns:Control="using:NewSchool.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Border BorderBrush="CornflowerBlue" BorderThickness="0.5" CornerRadius="5,5,5,5" Background="White">
        <Grid Margin="2,2,2,2">
            <Grid.RowDefinitions>
                <RowDefinition x:Name="RowHeader" Height="32"/>
                <RowDefinition x:Name="RowBody" />
            </Grid.RowDefinitions>
            <!--윈도우 타이틀-->
            <!-- 달력 header-->
            <Border Grid.Row="0" >
                <Grid VerticalAlignment="Center">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Button x:Name="BtnPrevious" Grid.Column="0" FontSize="14" Margin="2,2,2,2" Click="BtnPrevious_Click" Padding="6,2,6,2" Background="{x:Null}" BorderBrush="{x:Null}" HorizontalAlignment="Right">
                        <TextBlock FontFamily="{StaticResource SymbolThemeFontFamily}" Text="&#xE76B;" FontSize="18"/>
                    </Button>
                    <Control:MonthPicker x:Name="PickerMonth" Grid.Column="1" SelectedMonthChanged="PickerMonth_SelectedMonthChanged" />

                    <Button x:Name="BtnNext" Grid.Column="2" FontSize="14" Margin="2,2,2,2" Click="BtnNext_Click" Padding="6,2,6,2" Background="{x:Null}" BorderBrush="{x:Null}" HorizontalAlignment="Left">
                        <TextBlock FontFamily="{StaticResource SymbolThemeFontFamily}" Text="&#xE76C;" FontSize="18"/>
                    </Button>

                    <Button x:Name="BtnSetup" Grid.Column="4" Margin="4,2,4,2" HorizontalAlignment="Center" VerticalAlignment="Center" Padding="4,2,4,2" Click="BtnSetup_Click" Background="{x:Null}" BorderBrush="{x:Null}">
                        <Button.Content>
                            <TextBlock FontFamily="{StaticResource SymbolThemeFontFamily}" Text="&#xE713;" FontSize="18"/>

                        </Button.Content>
                    </Button>
                </Grid>
            </Border>
            <!-- 달력 body-->
            <!-- 달력 body - 기존 GridBody 부분 교체 -->
            <Border Grid.Row="1" BorderBrush="#E0E0E0" BorderThickness="0.5" Margin="2,2,2,2">
                <Grid x:Name="GridBody">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition/>
                        <ColumnDefinition/>
                        <ColumnDefinition/>
                        <ColumnDefinition/>
                        <ColumnDefinition/>
                        <ColumnDefinition/>
                        <ColumnDefinition/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition MaxHeight="60" Height="Auto"/>
                        <RowDefinition/>
                        <RowDefinition/>
                        <RowDefinition/>
                        <RowDefinition/>
                        <RowDefinition/>
                        <RowDefinition/>
                    </Grid.RowDefinitions>

                    <!-- 요일 헤더 - 오른쪽과 아래쪽 테두리만 -->
                    <Border Grid.Column="0" Grid.Row="0" BorderBrush="#E0E0E0" BorderThickness="0,0,0.5,0.5" Padding="8">
                        <TextBlock Text="일" Foreground="Red" FontSize="12" HorizontalTextAlignment="Center" />
                    </Border>
                    <Border Grid.Column="1" Grid.Row="0" BorderBrush="#E0E0E0" BorderThickness="0,0,0.5,0.5" Padding="8">
                        <TextBlock Text="월" Foreground="Black" FontSize="12" HorizontalTextAlignment="Center"/>
                    </Border>
                    <Border Grid.Column="2" Grid.Row="0" BorderBrush="#E0E0E0" BorderThickness="0,0,0.5,0.5" Padding="8">
                        <TextBlock Text="화" Foreground="Black" FontSize="12" HorizontalTextAlignment="Center"/>
                    </Border>
                    <Border Grid.Column="3" Grid.Row="0" BorderBrush="#E0E0E0" BorderThickness="0,0,0.5,0.5" Padding="8">
                        <TextBlock Text="수" Foreground="Black" FontSize="12" HorizontalTextAlignment="Center"/>
                    </Border>
                    <Border Grid.Column="4" Grid.Row="0" BorderBrush="#E0E0E0" BorderThickness="0,0,0.5,0.5" Padding="8">
                        <TextBlock Text="목" Foreground="Black" FontSize="12" HorizontalTextAlignment="Center"/>
                    </Border>
                    <Border Grid.Column="5" Grid.Row="0" BorderBrush="#E0E0E0" BorderThickness="0,0,0.5,0.5" Padding="8">
                        <TextBlock Text="금" Foreground="Black" FontSize="12" HorizontalTextAlignment="Center"/>
                    </Border>
                    <Border Grid.Column="6" Grid.Row="0" BorderBrush="#E0E0E0" BorderThickness="0,0,0,0.5" Padding="8">
                        <TextBlock Text="토" Foreground="Blue" FontSize="12" HorizontalTextAlignment="Center"/>
                    </Border>
                </Grid>
            </Border>
        </Grid>
    </Border>

</Page>

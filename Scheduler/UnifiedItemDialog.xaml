<?xml version="1.0" encoding="utf-8"?>
<ContentDialog
    x:Class="NewSchool.Scheduler.UnifiedItemDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:local="using:NewSchool.Scheduler"
    xmlns:control="using:NewSchool.Controls"
    mc:Ignorable="d"
    Title="새 항목"
    PrimaryButtonText="저장"
    SecondaryButtonText="삭제"
    CloseButtonText="닫기"
    PrimaryButtonClick="Dialog_PrimaryButtonClick"
    SecondaryButtonClick="Dialog_SecondaryButtonClick">

    <ContentDialog.Resources>
    </ContentDialog.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <StackPanel MinWidth="600" Spacing="8">

            <!-- 유형 선택: 할 일 / 일정 (RadioButton 탭 스타일) -->
            <Border Background="#F3F3F3" CornerRadius="8" Padding="4">
                <StackPanel Orientation="Horizontal" Spacing="4">
                    <RadioButton x:Name="RbTypeTask"
                                 Content="✓  할 일"
                                 GroupName="ItemType"
                                 IsChecked="True"
                                 Checked="RbType_Checked"
                                 Padding="16,6" FontSize="13"/>
                    <RadioButton x:Name="RbTypeEvent"
                                 Content="📅  일정"
                                 GroupName="ItemType"
                                 Checked="RbType_Checked"
                                 Padding="16,6" FontSize="13"/>
                </StackPanel>
            </Border>

            <!-- ======================== 할 일 패널 ======================== -->
            <Grid x:Name="PanelTask">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="300"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="80"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBlock Text="분류" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                <ComboBox x:Name="CBoxTaskList" Grid.Column="1" Margin="10,4,2,4"
                          MinWidth="140" VerticalAlignment="Center"
                          IsEditable="True"
                          SelectionChanged="CBoxTaskList_SelectionChanged"
                          TextSubmitted="CBoxTaskList_TextSubmitted"/>

                <TextBlock Text="제목" Grid.Row="1" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                <TextBox x:Name="TxtTaskTitle" Grid.Row="1" Grid.Column="1"
                         Margin="10,4,2,4" VerticalContentAlignment="Center"
                         LostFocus="TextBox_LostFocus"/>

                <TextBlock Text="마감" Grid.Row="2" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                <StackPanel Orientation="Horizontal" Grid.Row="2" Grid.Column="1"
                            Margin="10,4,2,4" Spacing="10">
                    <CalendarDatePicker x:Name="TaskDueDatePicker"
                                        DateChanged="TaskDueDatePicker_DateChanged"/>
                    <control:CompactTimePicker x:Name="TaskDueTimePicker"
                                TimeChanged="TaskDueTimePicker_TimeChanged"/>
                    <CheckBox x:Name="ChkTaskAllday" Content="종일"
                              VerticalAlignment="Center" Click="ChkTaskAllday_Click"/>
                </StackPanel>

                <!-- 반복 옵션 (신규 작업만 표시) -->
                <Grid x:Name="GridRepeat" Grid.Row="3" Grid.ColumnSpan="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="80"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <TextBlock Text="반복" Grid.RowSpan="2"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    <StackPanel Grid.Column="1" Grid.ColumnSpan="2" Grid.Row="0"
                                Margin="10,4,2,0" Spacing="2">
                        <StackPanel Orientation="Horizontal" Spacing="4">
                            <RadioButton x:Name="RbNone"    Content="없음"  GroupName="Repeat"
                                         IsChecked="True" Checked="RepeatOption_Checked"
                                         MinWidth="0" Padding="6,4"/>
                            <RadioButton x:Name="RbDaily"   Content="매일"  GroupName="Repeat"
                                         Checked="RepeatOption_Checked"
                                         MinWidth="0" Padding="6,4"/>
                            <RadioButton x:Name="RbWeekly"  Content="매주 월요일"  GroupName="Repeat"
                                         Checked="RepeatOption_Checked"
                                         MinWidth="0" Padding="6,4"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Spacing="4">
                            <RadioButton x:Name="RbMonthly" Content="매월 1일"  GroupName="Repeat"
                                         Checked="RepeatOption_Checked"
                                         MinWidth="0" Padding="6,4"/>
                            <RadioButton x:Name="RbYearly"  Content="매년 1월 1일"  GroupName="Repeat"
                                         Checked="RepeatOption_Checked"
                                         MinWidth="0" Padding="6,4"/>
                        </StackPanel>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Grid.Column="1" Grid.ColumnSpan="2"
                                Grid.Row="1" Spacing="8" Margin="10,2,2,4">
                        <TextBlock x:Name="LbRepeatEnd" Text="종료 날짜"
                                   VerticalAlignment="Center" Visibility="Collapsed"
                                   FontWeight="Bold" Foreground="Red"/>
                        <CalendarDatePicker x:Name="PickerEnd"
                                            Visibility="Collapsed" PlaceholderText="반복 종료"/>
                    </StackPanel>
                </Grid>

                <TextBlock Text="완료" Grid.Row="4"
                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                <CheckBox x:Name="ChkTaskDone" Content="완료됨"
                          Grid.Row="4" Grid.Column="1" Margin="10,2,0,2" VerticalAlignment="Center"/>

                <TextBlock Text="설명" Grid.Row="5"
                           HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,8,0,0"/>
                <control:JoditEditor x:Name="TxtTaskNotes" Grid.Row="5" Grid.Column="1"
                                     Margin="4" Mode="Simple" LostFocus="TextBox_LostFocus"/>

                <!-- 구글 캘린더 동기화 -->
                <CheckBox x:Name="ChkTaskGoogleSync" Grid.Row="6" Grid.ColumnSpan="2"
                          Content="📤 구글 캘린더에 등록"
                          Margin="10,4,0,0" Visibility="Collapsed"/>
            </Grid>

            <!-- ======================== 일정 패널 ======================== -->
            <Grid x:Name="PanelEvent" Visibility="Collapsed">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="300"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="80"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBlock Text="캘린더" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                <ComboBox x:Name="CBoxCalendar" Grid.Column="1" Margin="10,4,2,4"
                          MinWidth="140" VerticalAlignment="Center"
                          IsEditable="True"
                          SelectionChanged="CBoxCalendar_SelectionChanged"
                          TextSubmitted="CBoxCalendar_TextSubmitted"/>

                <TextBlock Text="제목" Grid.Row="1"
                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                <TextBox x:Name="TxtEventTitle" Grid.Row="1" Grid.Column="1"
                         Margin="10,4,2,4" VerticalContentAlignment="Center"
                         LostFocus="TextBox_LostFocus"/>

                <TextBlock Text="시작" Grid.Row="2"
                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                <StackPanel Orientation="Horizontal" Grid.Row="2" Grid.Column="1"
                            Margin="10,4,2,4" Spacing="10">
                    <CalendarDatePicker x:Name="EventStartDatePicker"
                                        DateChanged="EventStartDatePicker_DateChanged"/>
                    <control:CompactTimePicker x:Name="EventStartTimePicker"
                                TimeChanged="EventStartTimePicker_TimeChanged"/>
                    <CheckBox x:Name="ChkEventAllday" Content="종일"
                              VerticalAlignment="Center" Click="ChkEventAllday_Click"/>
                </StackPanel>

                <TextBlock Text="종료" Grid.Row="3"
                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                <StackPanel Orientation="Horizontal" Grid.Row="3" Grid.Column="1"
                            Margin="10,4,2,4" Spacing="10">
                    <CalendarDatePicker x:Name="EventEndDatePicker"
                                        DateChanged="EventEndDatePicker_DateChanged"/>
                    <control:CompactTimePicker x:Name="EventEndTimePicker"
                                TimeChanged="EventEndTimePicker_TimeChanged"/>
                </StackPanel>

                <TextBlock Text="장소" Grid.Row="4"
                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                <TextBox x:Name="TxtEventLocation" Grid.Row="4" Grid.Column="1"
                         Margin="10,4,2,4"/>

                <TextBlock Text="색상" Grid.Row="5"
                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                <StackPanel Orientation="Horizontal" Grid.Row="5" Grid.Column="1"
                            Margin="10,4,2,4" Spacing="6">
                    <ComboBox x:Name="CBoxColor" MinWidth="150"
                              SelectionChanged="CBoxColor_SelectionChanged">
                        <ComboBoxItem Tag=""   Content="캘린더 기본색"/>
                        <ComboBoxItem Tag="1"  Content="🔴 토마토"/>
                        <ComboBoxItem Tag="2"  Content="🩷 플라밍고"/>
                        <ComboBoxItem Tag="3"  Content="🟠 탠저린"/>
                        <ComboBoxItem Tag="4"  Content="🍌 바나나"/>
                        <ComboBoxItem Tag="5"  Content="🌿 세이지"/>
                        <ComboBoxItem Tag="6"  Content="🌱 바질"/>
                        <ComboBoxItem Tag="7"  Content="🦚 피콕"/>
                        <ComboBoxItem Tag="8"  Content="🔵 블루베리"/>
                        <ComboBoxItem Tag="9"  Content="💜 라벤더"/>
                        <ComboBoxItem Tag="10" Content="🍇 그레이프"/>
                        <ComboBoxItem Tag="11" Content="⚫ 그라파이트"/>
                    </ComboBox>
                    <Border x:Name="ColorPreview" Width="24" Height="24"
                            CornerRadius="12" Background="#4285F4" VerticalAlignment="Center"/>
                </StackPanel>

                <TextBlock Text="설명" Grid.Row="6"
                           HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,8,0,0"/>
                <control:JoditEditor x:Name="TxtEventNotes" Grid.Row="6" Grid.Column="1"
                                     Margin="4" Mode="Simple" LostFocus="TextBox_LostFocus"/>

                <!-- 구글 캘린더 동기화 -->
                <CheckBox x:Name="ChkEventGoogleSync" Grid.Row="7" Grid.ColumnSpan="2"
                          Content="📤 구글 캘린더에 등록"
                          Margin="10,4,0,0" Visibility="Collapsed"/>
            </Grid>

        </StackPanel>
    </ScrollViewer>
</ContentDialog>

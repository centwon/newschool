<?xml version="1.0" encoding="utf-8"?>
<ContentDialog
    x:Class="NewSchool.Dialogs.ClassTimetableEditDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:NewSchool.Models"
    mc:Ignorable="d"
    Title="학급 시간표 편집"
    PrimaryButtonText="저장"
    CloseButtonText="취소"
    DefaultButton="Primary"
    PrimaryButtonClick="OnPrimaryButtonClick"
    Width="900"
    MaxHeight="700">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 에러 메시지 -->
        <InfoBar 
            x:Name="ErrorInfoBar"
            Grid.Row="0"
            Severity="Error"
            IsOpen="False"
            IsClosable="True"
            Margin="0,0,0,8"/>

        <!-- 학급 정보 -->
        <TextBlock 
            Grid.Row="1"
            x:Name="TxtClassInfo"
            FontSize="16" 
            FontWeight="SemiBold"
            Margin="0,0,0,16"/>

        <!-- 입력 영역 -->
        <Border 
            Grid.Row="2"
            Background="{ThemeResource LayerFillColorDefaultBrush}"
            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
            BorderThickness="1"
            CornerRadius="8"
            Padding="16"
            Margin="0,0,0,16">
            <Grid ColumnSpacing="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="1.5*"/>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- 요일 -->
                <ComboBox 
                    Grid.Column="0"
                    x:Name="CBoxDayOfWeek"
                    Header="요일"
                    HorizontalAlignment="Stretch">
                    <ComboBoxItem Content="월" Tag="1"/>
                    <ComboBoxItem Content="화" Tag="2"/>
                    <ComboBoxItem Content="수" Tag="3"/>
                    <ComboBoxItem Content="목" Tag="4"/>
                    <ComboBoxItem Content="금" Tag="5"/>
                </ComboBox>

                <!-- 교시 -->
                <ComboBox 
                    Grid.Column="1"
                    x:Name="CBoxPeriod"
                    Header="교시"
                    HorizontalAlignment="Stretch">
                    <ComboBoxItem Content="1" Tag="1"/>
                    <ComboBoxItem Content="2" Tag="2"/>
                    <ComboBoxItem Content="3" Tag="3"/>
                    <ComboBoxItem Content="4" Tag="4"/>
                    <ComboBoxItem Content="5" Tag="5"/>
                    <ComboBoxItem Content="6" Tag="6"/>
                    <ComboBoxItem Content="7" Tag="7"/>
                </ComboBox>

                <!-- 과목명 -->
                <TextBox 
                    Grid.Column="2"
                    x:Name="TxtSubject"
                    Header="과목명"
                    PlaceholderText="국어"
                    MaxLength="20"/>

                <!-- 교사명 -->
                <TextBox 
                    Grid.Column="3"
                    x:Name="TxtTeacher"
                    Header="교사명"
                    PlaceholderText="홍길동"
                    MaxLength="20"/>

                <!-- 추가 버튼 -->
                <Button 
                    Grid.Column="4"
                    Content="추가"
                    Style="{StaticResource AccentButtonStyle}"
                    Click="OnAddClick"
                    VerticalAlignment="Bottom"
                    MinWidth="80"/>
            </Grid>
        </Border>

        <!-- 시간표 목록 -->
        <ListView 
            Grid.Row="3"
            x:Name="TimetableListView"
            SelectionMode="None">
            <ListView.ItemTemplate>
                <DataTemplate x:DataType="models:ClassTimetable">
                    <Grid 
                        Padding="12,8"
                        ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="80"/>
                            <ColumnDefinition Width="80"/>
                            <ColumnDefinition Width="150"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock 
                            Grid.Column="0"
                            Text="{x:Bind DayName, Mode=OneWay}"
                            VerticalAlignment="Center"/>

                        <TextBlock 
                            Grid.Column="1"
                            VerticalAlignment="Center">
                            <Run Text="{x:Bind Period, Mode=OneWay}"/>
                            <Run Text="교시"/>
                        </TextBlock>

                        <TextBlock 
                            Grid.Column="2"
                            Text="{x:Bind SubjectName, Mode=OneWay}"
                            FontWeight="SemiBold"
                            VerticalAlignment="Center"/>

                        <TextBlock 
                            Grid.Column="3"
                            Text="{x:Bind TeacherName, Mode=OneWay}"
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            VerticalAlignment="Center"/>

                        <Button 
                            Grid.Column="4"
                            Click="OnRemoveClick"
                            Tag="{x:Bind Mode=OneTime}">
                            <FontIcon Glyph="&#xE74D;" FontSize="14"/>
                        </Button>
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </Grid>
</ContentDialog>

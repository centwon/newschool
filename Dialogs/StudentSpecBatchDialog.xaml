<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="NewSchool.Dialogs.StudentSpecBatchDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:controls="using:NewSchool.Controls"
    xmlns:models="using:NewSchool.Models"
    mc:Ignorable="d"
    Title="학생부 특기사항 일괄 입력">

    <Grid Padding="16" RowSpacing="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- 상단 필터 -->
            <RowDefinition Height="*"/>     <!-- 메인 (학생목록 + 편집) -->
            <RowDefinition Height="Auto"/>  <!-- 하단 버튼 -->
        </Grid.RowDefinitions>

        <!-- ==============================
             상단: 필터 영역
        ============================== -->
        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8">
                <!-- 영역 선택 -->
                <ComboBox x:Name="CBoxType"
                          PlaceholderText="영역 선택"
                          MinWidth="130"
                          SelectionChanged="CBoxType_SelectionChanged"/>

                <!-- 과목 선택 (교과활동/개인별세특일 때만 표시) -->
                <ComboBox x:Name="CBoxCourse"
                          PlaceholderText="과목 선택"
                          MinWidth="130"
                          Visibility="Collapsed"
                          ItemsSource="{x:Bind Courses}"
                          SelectionChanged="CBoxCourse_SelectionChanged">
                    <ComboBox.ItemTemplate>
                        <DataTemplate x:DataType="models:Course">
                            <TextBlock Text="{x:Bind Subject}"/>
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>
            </StackPanel>

            <!-- 학급 정보 -->
            <TextBlock x:Name="TxtClassInfo"
                       Grid.Column="1"
                       VerticalAlignment="Center"
                       Margin="16,0,0,0"
                       FontWeight="SemiBold"
                       Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"/>

            <!-- 진행 상황 -->
            <StackPanel Grid.Column="2" 
                        Orientation="Horizontal" Spacing="8"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center">
                <TextBlock x:Name="TxtProgress"
                           FontSize="12"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
            </StackPanel>

            <!-- 맞춤법 검사 -->
            <Button Grid.Column="3"
                    Content="맞춤법 검사"
                    Click="BtnSpellCheck_Click"
                    Margin="8,0,0,0"/>
        </Grid>

        <!-- ==============================
             메인: 학생 목록 + 편집 영역
        ============================== -->
        <Grid Grid.Row="1" ColumnSpacing="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="200"/>   <!-- 학생 목록 -->
                <ColumnDefinition Width="*"/>     <!-- 편집 영역 -->
            </Grid.ColumnDefinitions>

            <!-- 좌측: 학생 목록 -->
            <controls:ListStudent x:Name="StudentList" Grid.Column="0"/>

            <!-- 우측: 편집 + 참조 영역 -->
            <Grid Grid.Column="1" RowSpacing="8">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>      <!-- 편집 영역 -->
                    <RowDefinition Height="Auto"/>   <!-- 참조 토글 -->
                    <RowDefinition x:Name="RowRef" Height="0"/>  <!-- 누가기록 참조 -->
                </Grid.RowDefinitions>

                <!-- 편집 영역 -->
                <Border Grid.Row="0"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1" CornerRadius="8"
                        Padding="16">

                    <Grid RowSpacing="8">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- 학생 정보 & 바이트 -->
                        <Grid Grid.Row="0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8">
                                <TextBlock x:Name="TxtStudentName"
                                           Text="학생을 선택하세요"
                                           FontSize="16" FontWeight="SemiBold"
                                           VerticalAlignment="Center"/>
                                <TextBlock x:Name="TxtStudentNum"
                                           FontSize="13"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                           VerticalAlignment="Center"/>
                                <FontIcon x:Name="IconModified"
                                          Glyph="&#xE915;"
                                          FontSize="12"
                                          Foreground="{ThemeResource SystemFillColorCautionBrush}"
                                          Visibility="Collapsed"
                                          ToolTipService.ToolTip="수정됨 (미저장)"/>
                            </StackPanel>

                            <TextBlock x:Name="TxtByteInfo"
                                       Grid.Column="1"
                                       Text="0 / 0 Byte (0자)"
                                       FontSize="12"
                                       VerticalAlignment="Center"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        </Grid>

                        <!-- 텍스트 에디터 -->
                        <TextBox x:Name="TxtContent"
                                 Grid.Row="1"
                                 AcceptsReturn="True"
                                 TextWrapping="Wrap"
                                 PlaceholderText="학생부 특기사항을 입력하세요..."
                                 IsEnabled="False"
                                 ScrollViewer.VerticalScrollBarVisibility="Auto"
                                 TextChanged="TxtContent_TextChanged"
                                 FontSize="13"/>

                        <!-- 하단 안내 -->
                        <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="16">
                            <TextBlock FontSize="11" Foreground="{ThemeResource TextFillColorTertiaryBrush}">
                                <Run Text="↑↓"/>
                                <Run Text=" 방향키로 학생 전환"/>
                            </TextBlock>
                            <TextBlock FontSize="11" Foreground="{ThemeResource TextFillColorTertiaryBrush}">
                                <Run Text="Ctrl+S"/>
                                <Run Text=" 저장"/>
                            </TextBlock>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- 참조 토글 버튼 + 초안 자동 생성 -->
                <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="8">
                    <ToggleButton x:Name="BtnToggleRef"
                                  Click="BtnToggleRef_Click"
                                  ToolTipService.ToolTip="누가기록 참조 영역 표시/숨김">
                        <StackPanel Orientation="Horizontal" Spacing="4">
                            <FontIcon Glyph="&#xE8A5;" FontSize="14"/>
                            <TextBlock Text="누가기록 참조" FontSize="12"/>
                        </StackPanel>
                    </ToggleButton>

                    <Button x:Name="BtnAutoGenerate"
                            Click="BtnAutoGenerate_Click"
                            ToolTipService.ToolTip="누가기록의 학생부 초안을 병합하여 자동 생성">
                        <StackPanel Orientation="Horizontal" Spacing="4">
                            <FontIcon Glyph="&#xE945;" FontSize="14"/>
                            <TextBlock Text="초안 자동 생성" FontSize="12"/>
                        </StackPanel>
                    </Button>
                </StackPanel>

                <!-- 누가기록 참조 패널 -->
                <Border Grid.Row="2"
                        Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1" CornerRadius="8"
                        Padding="12">

                    <Grid RowSpacing="4">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Text="누가기록 학생부 초안"
                                   FontSize="12" FontWeight="SemiBold"
                                   Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"/>

                        <ScrollViewer Grid.Row="1"
                                      VerticalScrollBarVisibility="Auto"
                                      MaxHeight="180">
                            <TextBlock x:Name="TxtLogReference"
                                       Text="학생을 선택하면 해당 학생의 누가기록 초안이 표시됩니다."
                                       FontSize="12"
                                       TextWrapping="Wrap"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                       IsTextSelectionEnabled="True"/>
                        </ScrollViewer>
                    </Grid>
                </Border>
            </Grid>
        </Grid>

        <!-- ==============================
             하단: 버튼
        ============================== -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBlock x:Name="TxtSaveStatus"
                       Grid.Column="0"
                       FontSize="12"
                       VerticalAlignment="Center"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>

            <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8">
                <Button x:Name="BtnSaveAll"
                        Content="전체 저장"
                        Style="{StaticResource AccentButtonStyle}"
                        Click="BtnSaveAll_Click"/>
                <Button x:Name="BtnClose"
                        Content="닫기"
                        Click="BtnClose_Click"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>

<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="NewSchool.Dialogs.StudentSpecBatchDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:controls="using:NewSchool.Controls"
    xmlns:models="using:NewSchool.Models"
    mc:Ignorable="d"
    Title="학생부 특기사항 일괄 입력">

    <Grid Padding="16" RowSpacing="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- 상단 필터 -->
            <RowDefinition Height="*"/>     <!-- 메인 (학생목록 + 편집) -->
            <RowDefinition Height="Auto"/>  <!-- 하단 버튼 -->
        </Grid.RowDefinitions>

        <!-- ==============================
             상단: 필터 영역
        ============================== -->
        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8">
                <!-- 영역 선택 -->
                <ComboBox x:Name="CBoxType"
                          PlaceholderText="영역 선택"
                          MinWidth="130"
                          SelectionChanged="CBoxType_SelectionChanged"/>

                <!-- 과목 선택 (교과활동/개인별세특일 때만 표시) -->
                <ComboBox x:Name="CBoxCourse"
                          PlaceholderText="과목 선택"
                          MinWidth="130"
                          Visibility="Collapsed"
                          ItemsSource="{x:Bind Courses}"
                          SelectionChanged="CBoxCourse_SelectionChanged">
                    <ComboBox.ItemTemplate>
                        <DataTemplate x:DataType="models:Course">
                            <TextBlock Text="{x:Bind Subject}"/>
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>
            </StackPanel>

            <!-- 학급 정보 -->
            <TextBlock x:Name="TxtClassInfo"
                       Grid.Column="1"
                       VerticalAlignment="Center"
                       Margin="16,0,0,0"
                       FontWeight="SemiBold"
                       Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"/>

            <!-- 진행 상황 -->
            <StackPanel Grid.Column="2" 
                        Orientation="Horizontal" Spacing="8"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center">
                <TextBlock x:Name="TxtProgress"
                           FontSize="12"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
            </StackPanel>

            <!-- 맞춤법 검사 -->
            <Button Grid.Column="3"
                    Content="맞춤법 검사"
                    Click="BtnSpellCheck_Click"
                    Margin="8,0,0,0"/>
        </Grid>

        <!-- ==============================
             메인: 학생 목록 + 편집 영역
        ============================== -->
        <Grid Grid.Row="1" ColumnSpacing="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="200"/>   <!-- 학생 목록 -->
                <ColumnDefinition Width="*"/>     <!-- 편집 영역 -->
            </Grid.ColumnDefinitions>

            <!-- 좌측: 학생 목록 -->
            <controls:ListStudent x:Name="StudentList" Grid.Column="0"/>

            <!-- 우측: 편집 영역 -->
            <Border Grid.Column="1"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1" CornerRadius="8"
                    Padding="16">

                <Grid RowSpacing="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>  <!-- 학생 정보 + 바이트 -->
                        <RowDefinition Height="*"/>     <!-- 텍스트 에디터 -->
                        <RowDefinition Height="Auto"/>  <!-- 안내 -->
                    </Grid.RowDefinitions>

                    <!-- 학생 정보 & 바이트 -->
                    <Grid Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8">
                            <TextBlock x:Name="TxtStudentName"
                                       Text="학생을 선택하세요"
                                       FontSize="16" FontWeight="SemiBold"
                                       VerticalAlignment="Center"/>
                            <TextBlock x:Name="TxtStudentNum"
                                       FontSize="13"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                       VerticalAlignment="Center"/>
                            <FontIcon x:Name="IconModified"
                                      Glyph="&#xE915;"
                                      FontSize="12"
                                      Foreground="{ThemeResource SystemFillColorCautionBrush}"
                                      Visibility="Collapsed"
                                      ToolTipService.ToolTip="수정됨 (미저장)"/>
                        </StackPanel>

                        <TextBlock x:Name="TxtByteInfo"
                                   Grid.Column="1"
                                   Text="0 / 0 Byte (0자)"
                                   FontSize="12"
                                   VerticalAlignment="Center"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    </Grid>

                    <!-- 텍스트 에디터 -->
                    <TextBox x:Name="TxtContent"
                             Grid.Row="1"
                             AcceptsReturn="True"
                             TextWrapping="Wrap"
                             PlaceholderText="학생부 특기사항을 입력하세요..."
                             IsEnabled="False"
                             ScrollViewer.VerticalScrollBarVisibility="Auto"
                             TextChanged="TxtContent_TextChanged"
                             FontSize="13"/>

                    <!-- 하단 안내 -->
                    <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="16">
                        <TextBlock FontSize="11" Foreground="{ThemeResource TextFillColorTertiaryBrush}">
                            <Run Text="↑↓"/>
                            <Run Text=" 방향키로 학생 전환"/>
                        </TextBlock>
                        <TextBlock FontSize="11" Foreground="{ThemeResource TextFillColorTertiaryBrush}">
                            <Run Text="Ctrl+S"/>
                            <Run Text=" 저장"/>
                        </TextBlock>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

        <!-- ==============================
             하단: 버튼
        ============================== -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBlock x:Name="TxtSaveStatus"
                       Grid.Column="0"
                       FontSize="12"
                       VerticalAlignment="Center"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>

            <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8">
                <Button x:Name="BtnSaveAll"
                        Content="전체 저장"
                        Style="{StaticResource AccentButtonStyle}"
                        Click="BtnSaveAll_Click"/>
                <Button x:Name="BtnClose"
                        Content="닫기"
                        Click="BtnClose_Click"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>

<?xml version="1.0" encoding="utf-8"?>
<ContentDialog
    x:Class="NewSchool.Dialogs.CourseEnrollmentDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:controls="using:NewSchool.Controls"
    mc:Ignorable="d"
    Title="수강생 관리"
    PrimaryButtonText="저장"
    CloseButtonText="취소"
    DefaultButton="Primary"
    PrimaryButtonClick="OnPrimaryButtonClick"
    Loaded="OnLoaded">

    <ContentDialog.Resources>
        <x:Double x:Key="ContentDialogMaxWidth">1100</x:Double>
        <x:Double x:Key="ContentDialogMaxHeight">800</x:Double>
    </ContentDialog.Resources>

    <Grid MinWidth="1000" MinHeight="550">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- 에러 메시지 -->
            <RowDefinition Height="Auto"/>
            <!-- 과목 정보 -->
            <RowDefinition Height="Auto"/>
            <!-- 일괄 배치 -->
            <RowDefinition Height="*"/>
            <!-- 학생 목록 -->
        </Grid.RowDefinitions>

        <!-- 에러/안내 메시지 -->
        <InfoBar x:Name="InfoMessage"
                 Grid.Row="0"
                 IsOpen="False"
                 IsClosable="True"
                 Margin="0,0,0,8"/>

        <!-- 과목 정보 헤더 -->
        <Border Grid.Row="1"
                Background="{ThemeResource LayerFillColorDefaultBrush}"
                CornerRadius="6"
                Padding="12,8"
                Margin="0,0,0,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="16">
                    <StackPanel Orientation="Horizontal">
                        <FontIcon Glyph="&#xE7BE;" FontSize="16"
                                  Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"/>
                        <TextBlock x:Name="TxtSubject"
                                   Text="과목명"
                                   FontWeight="SemiBold"
                                   FontSize="15"
                                   Margin="8,0,0,0"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                    <Border Background="{ThemeResource AccentFillColorDefaultBrush}"
                            CornerRadius="4"
                            Padding="8,2">
                        <TextBlock x:Name="TxtType"
                                   Text="학급 공통"
                                   FontSize="12"
                                   Foreground="White"/>
                    </Border>
                    <TextBlock x:Name="TxtGradeInfo"
                               Text="1학년"
                               FontSize="13"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                               VerticalAlignment="Center"/>
                </StackPanel>

                <TextBlock Grid.Column="1"
                           x:Name="TxtEnrolledCount"
                           Text="등록: 0명"
                           FontSize="13"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                           VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <!-- 일괄 배치 바 (학급 공통 전용) -->
        <Border x:Name="BulkAssignPanel"
                Grid.Row="2"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="6"
                Padding="12,8"
                Margin="0,0,0,12"
                Visibility="Collapsed">
            <StackPanel Orientation="Horizontal" Spacing="10">
                <FontIcon Glyph="&#xE71D;" FontSize="14" VerticalAlignment="Center"
                          Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"/>
                <TextBlock Text="일괄 배치:"
                           FontWeight="SemiBold"
                           VerticalAlignment="Center"
                           FontSize="13"/>

                <TextBlock x:Name="TxtBulkDescription"
                           Text=""
                           VerticalAlignment="Center"
                           FontSize="13"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>

                <Button x:Name="BtnBulkAssign"
                        Click="BtnBulkAssign_Click"
                        Style="{ThemeResource AccentButtonStyle}"
                        Padding="12,5">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <FontIcon Glyph="&#xE71D;" FontSize="12"/>
                        <TextBlock Text="전체 학생 일괄 배치"/>
                    </StackPanel>
                </Button>
            </StackPanel>
        </Border>

        <!-- 학생 목록 영역 -->
        <Grid Grid.Row="3">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <!-- 좌측: 학급 학생 -->
                <ColumnDefinition Width="Auto"/>
                <!-- 중앙: 버튼 -->
                <ColumnDefinition Width="*"/>
                <!-- 우측: 수강생 -->
            </Grid.ColumnDefinitions>

            <!-- ========== 좌측: 학급 학생 ========== -->
            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <!-- 헤더 -->
                    <RowDefinition Height="Auto"/>
                    <!-- 필터 -->
                    <RowDefinition Height="*"/>
                    <!-- 목록 -->
                </Grid.RowDefinitions>

                <!-- 헤더 -->
                <Border Grid.Row="0"
                        Background="{ThemeResource LayerFillColorDefaultBrush}"
                        Padding="12,8"
                        CornerRadius="8,8,0,0"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1,1,1,0">
                    <StackPanel Orientation="Horizontal">
                        <FontIcon Glyph="&#xE716;" FontSize="14"/>
                        <TextBlock Text="학급 학생"
                                   FontWeight="SemiBold"
                                   FontSize="13"
                                   Margin="8,0,0,0"/>
                        <TextBlock x:Name="TxtAvailableCount"
                                   FontSize="12"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                   Margin="8,0,0,0"/>
                    </StackPanel>
                </Border>

                <!-- 필터: 학년/반 (실제 학생 데이터 기반) -->
                <Border Grid.Row="1"
                        Padding="8"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1,0,1,0">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <ComboBox x:Name="CBoxGradeFilter"
                                  MinWidth="80"
                                  SelectionChanged="CBoxGradeFilter_SelectionChanged"/>
                        <ComboBox x:Name="CBoxClassFilter"
                                  MinWidth="80"
                                  SelectionChanged="CBoxClassFilter_SelectionChanged"/>
                    </StackPanel>
                </Border>

                <!-- 학생 목록 -->
                <controls:ListStudent x:Name="ListAvailable"
                                      Grid.Row="2"
                                      ViewMode="NumName"
                                      ShowCheckBox="True"
                                      MinWidth="280"/>
            </Grid>

            <!-- ========== 중앙: 이동 버튼 ========== -->
            <StackPanel Grid.Column="1"
                        VerticalAlignment="Center"
                        Margin="8,0">
                <Button x:Name="BtnAdd"
                        Click="BtnAdd_Click"
                        ToolTipService.ToolTip="선택한 학생 등록"
                        Padding="12,8"
                        Margin="0,4">
                    <FontIcon Glyph="&#xE72A;" FontSize="16"/>
                </Button>
                <Button x:Name="BtnRemove"
                        Click="BtnRemove_Click"
                        ToolTipService.ToolTip="선택한 학생 등록 해제"
                        Padding="12,8"
                        Margin="0,4">
                    <FontIcon Glyph="&#xE72B;" FontSize="16"/>
                </Button>
            </StackPanel>

            <!-- ========== 우측: 수강생 ========== -->
            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <!-- 헤더 -->
                    <RowDefinition Height="Auto"/>
                    <!-- 필터 -->
                    <RowDefinition Height="*"/>
                    <!-- 목록 -->
                </Grid.RowDefinitions>

                <!-- 헤더 -->
                <Border Grid.Row="0"
                        Background="{ThemeResource LayerFillColorDefaultBrush}"
                        Padding="12,8"
                        CornerRadius="8,8,0,0"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1,1,1,0">
                    <StackPanel Orientation="Horizontal">
                        <FontIcon Glyph="&#xE77B;" FontSize="14"
                                  Foreground="{ThemeResource SystemFillColorSuccessBrush}"/>
                        <TextBlock Text="수강생"
                                   FontWeight="SemiBold"
                                   FontSize="13"
                                   Margin="8,0,0,0"/>
                        <TextBlock x:Name="TxtRegisteredCount"
                                   FontSize="12"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                   Margin="8,0,0,0"/>
                    </StackPanel>
                </Border>

                <!-- 필터 -->
                <Grid Grid.Row="1"
                      Padding="8"
                      ColumnSpacing="8"
                      Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                      BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                      BorderThickness="1,0,1,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <ComboBox x:Name="CBoxRoomFilter"
                              Grid.Column="0"
                              Header="강의실"
                              HorizontalAlignment="Stretch"
                              SelectionChanged="CBoxRoomFilter_SelectionChanged"/>

                    <TextBox x:Name="TxtSearch"
                             Grid.Column="1"
                             Header="검색"
                             PlaceholderText="이름..."
                             TextChanged="TxtSearch_TextChanged"/>
                </Grid>

                <!-- 수강생 목록 -->
                <controls:ListStudent x:Name="ListEnrolled"
                                      Grid.Row="2"
                                      ViewMode="ClassNumName"
                                      ShowCheckBox="True"
                                      MinWidth="280"/>
            </Grid>
        </Grid>
    </Grid>
</ContentDialog>

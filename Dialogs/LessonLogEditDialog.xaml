<?xml version="1.0" encoding="utf-8"?>
<ContentDialog
    x:Class="NewSchool.Dialogs.LessonLogEditDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="수업 기록"
    PrimaryButtonText="저장"
    CloseButtonText="취소"
    DefaultButton="Primary"
    PrimaryButtonClick="OnPrimaryButtonClick">

    <Grid Width="480">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- 에러 -->
            <RowDefinition Height="Auto"/>
            <!-- 날짜/교시 -->
            <RowDefinition Height="Auto"/>
            <!-- 과목/학급/강의실 -->
            <RowDefinition Height="Auto"/>
            <!-- 단원 -->
            <RowDefinition Height="Auto"/>
            <!-- 주제 -->
            <RowDefinition Height="Auto"/>
            <!-- 내용 -->
            <RowDefinition Height="Auto"/>
            <!-- 교사 메모 -->
            <RowDefinition Height="Auto"/>
            <!-- 삭제 버튼 -->
        </Grid.RowDefinitions>

        <!-- 에러 메시지 -->
        <InfoBar x:Name="ErrorInfoBar"
                 Grid.Row="0"
                 Severity="Error"
                 IsOpen="False"
                 IsClosable="True"
                 Margin="0,0,0,12"/>

        <!-- 날짜/교시 -->
        <Grid Grid.Row="1" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="100"/>
            </Grid.ColumnDefinitions>

            <CalendarDatePicker x:Name="DatePicker"
                                Grid.Column="0"
                                Header="날짜 *"
                                HorizontalAlignment="Stretch"
                                Margin="0,0,8,0"
                                DateChanged="DatePicker_DateChanged"/>

            <ComboBox x:Name="CBoxPeriod"
                      Grid.Column="1"
                      Header="교시 *"
                      HorizontalAlignment="Stretch">
                <ComboBoxItem Content="1교시" Tag="1"/>
                <ComboBoxItem Content="2교시" Tag="2"/>
                <ComboBoxItem Content="3교시" Tag="3"/>
                <ComboBoxItem Content="4교시" Tag="4"/>
                <ComboBoxItem Content="5교시" Tag="5"/>
                <ComboBoxItem Content="6교시" Tag="6"/>
                <ComboBoxItem Content="7교시" Tag="7"/>
            </ComboBox>
        </Grid>

        <!-- 과목/학급/강의실 -->
        <Grid Grid.Row="2" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="80"/>
                <ColumnDefinition Width="100"/>
            </Grid.ColumnDefinitions>

            <TextBox x:Name="TxtSubject"
                     Grid.Column="0"
                     Header="과목"
                     IsReadOnly="True"
                     Margin="0,0,8,0"/>

            <TextBox x:Name="TxtClass"
                     Grid.Column="1"
                     Header="학급"
                     IsReadOnly="True"
                     Margin="0,0,8,0"/>

            <TextBox x:Name="TxtRoom"
                     Grid.Column="2"
                     Header="강의실"
                     PlaceholderText="예: 과학실"/>
        </Grid>

        <!-- 단원 선택 -->
        <Grid Grid.Row="3" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <ComboBox x:Name="CBoxSection"
                      Grid.Column="0"
                      Header="단원 (선택)"
                      HorizontalAlignment="Stretch"
                      PlaceholderText="단원을 선택하세요"
                      SelectionChanged="CBoxSection_SelectionChanged"/>

            <Button x:Name="BtnClearSection"
                    Grid.Column="1"
                    Content="&#xE711;"
                    FontFamily="Segoe Fluent Icons"
                    VerticalAlignment="Bottom"
                    Margin="4,0,0,0"
                    ToolTipService.ToolTip="단원 선택 해제"
                    Click="BtnClearSection_Click"/>
        </Grid>

        <!-- 주제 -->
        <TextBox x:Name="TxtTopic"
                 Grid.Row="4"
                 Header="주제 *"
                 PlaceholderText="수업 주제를 입력하세요"
                 MaxLength="200"
                 Margin="0,0,0,12"/>

        <!-- 내용 -->
        <TextBox x:Name="TxtContent"
                 Grid.Row="5"
                 Header="내용"
                 PlaceholderText="수업 내용을 입력하세요"
                 AcceptsReturn="True"
                 TextWrapping="Wrap"
                 Height="100"
                 MaxLength="2000"
                 Margin="0,0,0,12"/>

        <!-- 교사 메모 -->
        <TextBox x:Name="TxtNote"
                 Grid.Row="6"
                 Header="메모"
                 PlaceholderText="수업 반성, 개인 노트 등"
                 AcceptsReturn="True"
                 TextWrapping="Wrap"
                 Height="60"
                 MaxLength="500"
                 Margin="0,0,0,12"/>

        <!-- 삭제 버튼 (수정 모드만) -->
        <Button x:Name="BtnDelete"
                Grid.Row="7"
                Content="이 기록 삭제"
                Click="BtnDelete_Click"
                Visibility="Collapsed"
                Foreground="{ThemeResource SystemFillColorCriticalBrush}"/>
    </Grid>
</ContentDialog>

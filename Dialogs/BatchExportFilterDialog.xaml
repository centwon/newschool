<ContentDialog
    x:Class="NewSchool.Dialogs.BatchExportFilterDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="일괄 출력 옵션"
    PrimaryButtonText="출력"
    CloseButtonText="취소"
    DefaultButton="Primary">

    <StackPanel Spacing="12" MinWidth="380">
        <TextBlock Text="출력할 기록의 필터 조건을 설정하세요."
                   FontSize="13"
                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>

        <!-- 출력 형식 -->
        <StackPanel Orientation="Horizontal" Spacing="12">
            <TextBlock Text="형식" VerticalAlignment="Center" Width="60" FontWeight="SemiBold"/>
            <RadioButton x:Name="RbPdf" Content="PDF" IsChecked="True" GroupName="Format"/>
            <RadioButton x:Name="RbExcel" Content="엑셀" GroupName="Format"/>
        </StackPanel>

        <NavigationViewItemSeparator/>

        <!-- 영역 (카테고리) 필터 -->
        <StackPanel Orientation="Horizontal" Spacing="12">
            <TextBlock Text="영역" VerticalAlignment="Center" Width="60" FontWeight="SemiBold"/>
            <ComboBox x:Name="CBoxCategory" MinWidth="180"/>
        </StackPanel>

        <!-- 학기 필터 -->
        <StackPanel Orientation="Horizontal" Spacing="12">
            <TextBlock Text="학기" VerticalAlignment="Center" Width="60" FontWeight="SemiBold"/>
            <ComboBox x:Name="CBoxSemester" MinWidth="180" SelectedIndex="0">
                <ComboBoxItem Content="전체" Tag="0"/>
                <ComboBoxItem Content="1학기" Tag="1"/>
                <ComboBoxItem Content="2학기" Tag="2"/>
            </ComboBox>
        </StackPanel>

        <!-- 키워드 필터 -->
        <StackPanel Orientation="Horizontal" Spacing="12">
            <TextBlock Text="키워드" VerticalAlignment="Center" Width="60" FontWeight="SemiBold"/>
            <TextBox x:Name="TbKeyword"
                     PlaceholderText="주제, 활동명, 내용에서 검색"
                     MinWidth="250"/>
        </StackPanel>

        <NavigationViewItemSeparator/>

        <!-- 정보 -->
        <TextBlock Text="선택한 조건에 맞는 기록만 하나의 문서에 출력합니다."
                   FontSize="12"
                   Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                   TextWrapping="Wrap"/>
    </StackPanel>
</ContentDialog>

<ContentDialog
    x:Class="NewSchool.Dialogs.SpecExportFilterDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="학생부 일괄 출력"
    PrimaryButtonText="출력"
    CloseButtonText="취소"
    DefaultButton="Primary">

    <StackPanel Spacing="12" MinWidth="380">
        <TextBlock Text="출력할 학생부 특기사항의 조건을 설정하세요."
                   FontSize="13"
                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>

        <!-- 출력 형식 -->
        <StackPanel Orientation="Horizontal" Spacing="12">
            <TextBlock Text="형식" VerticalAlignment="Center" Width="60" FontWeight="SemiBold"/>
            <RadioButton x:Name="RbPdf" Content="PDF" IsChecked="True" GroupName="Format"/>
            <RadioButton x:Name="RbExcel" Content="엑셀" GroupName="Format"/>
        </StackPanel>

        <NavigationViewItemSeparator/>

        <!-- 영역 필터 -->
        <StackPanel Orientation="Horizontal" Spacing="12">
            <TextBlock Text="영역" VerticalAlignment="Center" Width="60" FontWeight="SemiBold"/>
            <ComboBox x:Name="CBoxType" MinWidth="180" SelectedIndex="0">
                <ComboBoxItem Content="전체" Tag="전체"/>
                <ComboBoxItem Content="자율활동" Tag="자율활동"/>
                <ComboBoxItem Content="진로활동" Tag="진로활동"/>
                <ComboBoxItem Content="동아리활동" Tag="동아리활동"/>
                <ComboBoxItem Content="봉사활동" Tag="봉사활동"/>
                <ComboBoxItem Content="교과활동" Tag="교과활동"/>
                <ComboBoxItem Content="개인별세특" Tag="개인별세특"/>
                <ComboBoxItem Content="종합의견" Tag="종합의견"/>
            </ComboBox>
        </StackPanel>

        <!-- 마감 상태 필터 -->
        <StackPanel Orientation="Horizontal" Spacing="12">
            <TextBlock Text="상태" VerticalAlignment="Center" Width="60" FontWeight="SemiBold"/>
            <ComboBox x:Name="CBoxStatus" MinWidth="180" SelectedIndex="0">
                <ComboBoxItem Content="전체" Tag="all"/>
                <ComboBoxItem Content="작성중만" Tag="draft"/>
                <ComboBoxItem Content="마감만" Tag="finalized"/>
            </ComboBox>
        </StackPanel>

        <!-- 빈 항목 제외 -->
        <CheckBox x:Name="ChkExcludeEmpty"
                  Content="내용이 비어있는 항목 제외"
                  IsChecked="True"/>

        <NavigationViewItemSeparator/>

        <TextBlock Text="선택한 조건에 맞는 학생부 특기사항을 하나의 문서로 출력합니다."
                   FontSize="12"
                   Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                   TextWrapping="Wrap"/>
    </StackPanel>
</ContentDialog>

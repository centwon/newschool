<ContentDialog
    x:Class="NewSchool.Dialogs.CalendarSettingsDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:NewSchool.Pages"
    Title="일정 설정"
    PrimaryButtonText="닫기"
    DefaultButton="Primary"
    MinWidth="560">

    <ContentDialog.Resources>
        <x:Double x:Key="ContentDialogMaxHeight">720</x:Double>
    </ContentDialog.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled"
                  MaxHeight="600">
    <StackPanel Spacing="6" Padding="0,8,0,0">

        <!-- 1. 일정 표시 -->
        <Expander Header="일정 표시" IsExpanded="True" HorizontalAlignment="Stretch">
            <Expander.Content>
                <Grid ColumnSpacing="16" RowSpacing="12" Padding="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition/>
                        <RowDefinition/>
                    </Grid.RowDefinitions>

                    <ToggleSwitch
                        x:Name="ShowEventsToggle"
                        Grid.Row="0" Grid.Column="0"
                        Header="이벤트"
                        OnContent="표시" OffContent="숨김"/>
                    <ToggleSwitch
                        x:Name="ShowTasksToggle"
                        Grid.Row="0" Grid.Column="1"
                        Header="할 일"
                        OnContent="표시" OffContent="숨김"/>

                    <NumberBox
                        x:Name="EventFontSizeNumberBox"
                        Grid.Row="1" Grid.Column="0"
                        Header="이벤트 폰트"
                        PlaceholderText="9.0"
                        SpinButtonPlacementMode="Inline"
                        Minimum="8" Maximum="20"
                        SmallChange="0.5" LargeChange="1"/>
                    <NumberBox
                        x:Name="TaskFontSizeNumberBox"
                        Grid.Row="1" Grid.Column="1"
                        Header="할 일 폰트"
                        PlaceholderText="10.0"
                        SpinButtonPlacementMode="Inline"
                        Minimum="8" Maximum="20"
                        SmallChange="0.5" LargeChange="1"/>
                </Grid>
            </Expander.Content>
        </Expander>

        <!-- 2. Google 캘린더 연동 -->
        <Expander Header="Google 캘린더 연동" IsExpanded="False" HorizontalAlignment="Stretch">
            <Expander.Content>
                <StackPanel Spacing="12" Padding="12">

                    <ToggleSwitch
                        x:Name="UseGoogleToggle"
                        Header="Google 캘린더 연동"
                        OnContent="사용" OffContent="미사용"/>

                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Button
                            x:Name="GoogleAuthButton"
                            Content="계정 연동"
                            IsEnabled="{x:Bind UseGoogleToggle.IsOn, Mode=OneWay}"
                            Click="OnGoogleAuthClicked"/>
                        <Button
                            x:Name="GoogleSignOutButton"
                            Content="연동 해제"
                            IsEnabled="{x:Bind UseGoogleToggle.IsOn, Mode=OneWay}"
                            Click="OnGoogleSignOutClicked"/>
                    </StackPanel>

                    <TextBlock
                        x:Name="GoogleAuthStatusText"
                        Text="연동되지 않음"
                        Foreground="{ThemeResource SystemFillColorCautionBrush}"
                        FontSize="12"/>

                    <!-- 캘린더 선택 -->
                    <TextBlock Text="동기화할 캘린더" FontWeight="SemiBold" Margin="0,4,0,0"/>
                    <TextBlock
                        x:Name="GoogleCalendarListHint"
                        Text="계정을 연동하면 목록이 표시됩니다."
                        Opacity="0.6" FontSize="12"/>
                    <ListView
                        x:Name="GoogleCalendarListView"
                        SelectionMode="None"
                        MaxHeight="150"
                        Visibility="Collapsed">
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="local:GoogleCalendarCheckItem">
                                <CheckBox
                                    Content="{x:Bind Title}"
                                    IsChecked="{x:Bind IsChecked, Mode=TwoWay}"
                                    Tag="{x:Bind GoogleId}"/>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                    <Button
                        x:Name="GoogleCalendarSaveButton"
                        Content="캘린더 선택 저장"
                        Visibility="Collapsed"
                        Click="OnGoogleCalendarSaveClicked"/>
                </StackPanel>
            </Expander.Content>
        </Expander>

        <!-- 3. 동기화 -->
        <Expander Header="동기화" IsExpanded="False" HorizontalAlignment="Stretch">
            <Expander.Content>
                <StackPanel Spacing="12" Padding="12">

                    <Grid ColumnSpacing="16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <ToggleSwitch
                            x:Name="GoogleAutoSyncToggle"
                            Grid.Column="0"
                            Header="자동 동기화"
                            OnContent="사용" OffContent="미사용"
                            IsEnabled="{x:Bind UseGoogleToggle.IsOn, Mode=OneWay}"/>
                        <NumberBox
                            x:Name="GoogleSyncIntervalNumberBox"
                            Grid.Column="1"
                            Header="간격 (분)"
                            PlaceholderText="15"
                            SpinButtonPlacementMode="Inline"
                            Minimum="5" Maximum="120"
                            SmallChange="5" LargeChange="15"
                            Width="140"
                            IsEnabled="{x:Bind UseGoogleToggle.IsOn, Mode=OneWay}"/>
                    </Grid>

                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Button
                            x:Name="GoogleSyncNowButton"
                            Content="지금 동기화"
                            IsEnabled="{x:Bind UseGoogleToggle.IsOn, Mode=OneWay}"
                            Click="OnGoogleSyncNowClicked"/>
                        <ProgressRing
                            x:Name="GoogleSyncProgressRing"
                            IsActive="False"
                            Width="20" Height="20"
                            Visibility="Collapsed"/>
                    </StackPanel>

                    <TextBlock
                        x:Name="GoogleSyncStatusText"
                        Text=""
                        TextWrapping="Wrap"
                        Opacity="0.7" FontSize="12"/>
                </StackPanel>
            </Expander.Content>
        </Expander>

        <!-- 4. 학사일정 일괄 등록 -->
        <Expander Header="학사일정 일괄 등록" IsExpanded="False" HorizontalAlignment="Stretch">
            <Expander.Content>
                <StackPanel Spacing="12" Padding="12">

                    <TextBlock
                        Text="NEIS에서 받아온 학사일정을 Google Calendar에 한번에 등록합니다."
                        Opacity="0.6" TextWrapping="Wrap" FontSize="12"/>

                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Button
                            x:Name="UploadSchoolScheduleButton"
                            Content="학사일정 등록"
                            IsEnabled="{x:Bind UseGoogleToggle.IsOn, Mode=OneWay}"
                            Click="OnUploadSchoolScheduleClicked"/>
                        <ProgressRing
                            x:Name="UploadScheduleProgressRing"
                            IsActive="False"
                            Width="20" Height="20"
                            Visibility="Collapsed"/>
                    </StackPanel>

                    <TextBlock
                        x:Name="UploadScheduleStatusText"
                        Text=""
                        TextWrapping="Wrap"
                        Opacity="0.7" FontSize="12"/>
                </StackPanel>
            </Expander.Content>
        </Expander>

    </StackPanel>
    </ScrollViewer>
</ContentDialog>

<ContentDialog
    x:Class="NewSchool.Dialogs.SchoolSearchDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:NewSchool.Models"
    mc:Ignorable="d"
    Title="학교 찾기"
    PrimaryButtonText="선택"
    CloseButtonText="취소"
    DefaultButton="Primary"
    IsPrimaryButtonEnabled="False"
    PrimaryButtonClick="OnPrimaryButtonClick">

    <Grid Width="700" Height="500">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 검색 영역 -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="12" Padding="0,0,0,16">
            <TextBox 
                x:Name="SchoolNameTextBox"
                PlaceholderText="학교 이름을 입력하세요"
                Width="300"
                VerticalAlignment="Center"
                KeyDown="OnSchoolNameKeyDown"/>

            <Button 
                x:Name="SearchButton"
                Content="검색"
                Click="OnSearchClick"
                Style="{StaticResource AccentButtonStyle}"/>

            <ProgressRing 
                x:Name="LoadingRing"
                Width="24"
                Height="24"
                IsActive="False"
                Visibility="Collapsed"/>
        </StackPanel>

        <!-- 검색 결과 -->
        <ListView 
            x:Name="SchoolListView"
            Grid.Row="1"
            SelectionMode="Single"
            SelectionChanged="OnSchoolSelectionChanged"
            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
            BorderThickness="1"
            CornerRadius="4">
            <ListView.ItemTemplate>
                <DataTemplate x:DataType="models:School">
                    <Grid Padding="12,8" ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="100"/>
                            <ColumnDefinition Width="100"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock 
                            Grid.Column="0" 
                            Grid.Row="0"
                            Text="{x:Bind ATPT_OFCDC_SC_NAME}" 
                            FontSize="12"
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>

                        <TextBlock 
                            Grid.Column="1" 
                            Grid.Row="0"
                            Text="{x:Bind ATPT_OFCDC_SC_CODE}" 
                            FontSize="12"
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>

                        <TextBlock 
                            Grid.Column="2" 
                            Grid.Row="0"
                            Text="{x:Bind SchoolCode}" 
                            FontSize="12"
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>

                        <TextBlock 
                            Grid.Column="0" 
                            Grid.Row="1"
                            Grid.ColumnSpan="4"
                            Text="{x:Bind SchoolName}" 
                            FontWeight="SemiBold"
                            FontSize="14"
                            Margin="0,4,0,0"/>

                        <TextBlock 
                            Grid.Column="0" 
                            Grid.Row="1"
                            Grid.ColumnSpan="4"
                            Text="{x:Bind Address}" 
                            FontSize="12"
                            Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                            Margin="0,24,0,0"/>
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <!-- 정보 텍스트 -->
        <TextBlock 
            x:Name="InfoTextBlock"
            Grid.Row="2"
            Text="학교 이름을 입력하고 검색 버튼을 클릭하세요."
            FontSize="12"
            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
            Margin="0,12,0,0"/>
    </Grid>
</ContentDialog>

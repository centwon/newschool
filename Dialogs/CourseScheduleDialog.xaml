<?xml version="1.0" encoding="utf-8"?>
<ContentDialog
    x:Class="NewSchool.Dialogs.CourseScheduleDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="시간표 배치"
    PrimaryButtonText="저장"
    CloseButtonText="취소"
    DefaultButton="Primary"
    PrimaryButtonClick="OnPrimaryButtonClick"
    Width="800">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 에러 메시지 -->
        <InfoBar 
            x:Name="ErrorInfoBar"
            Grid.Row="0"
            Severity="Error"
            IsOpen="False"
            IsClosable="True"
            Margin="0,0,0,8"/>

        <!-- 수업 정보 -->
        <Border 
            Grid.Row="1"
            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
            BorderThickness="1"
            CornerRadius="8"
            Padding="16"
            Margin="0,0,0,16">
            <StackPanel Spacing="4">
                <TextBlock 
                    x:Name="TxtCourseName"
                    FontSize="16" 
                    FontWeight="SemiBold"/>
                <TextBlock 
                    x:Name="TxtCourseInfo"
                    FontSize="13"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
            </StackPanel>
        </Border>

        <!-- 시간표 추가 영역 -->
        <Border 
            Grid.Row="2"
            Background="{ThemeResource LayerFillColorDefaultBrush}"
            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
            BorderThickness="1"
            CornerRadius="8"
            Padding="16"
            Margin="0,0,0,16">
            <Grid ColumnSpacing="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- 요일 -->
                <ComboBox 
                    Grid.Column="0"
                    x:Name="CBoxDayOfWeek"
                    Header="요일"
                    PlaceholderText="선택"
                    HorizontalAlignment="Stretch">
                    <ComboBoxItem Content="월요일" Tag="1"/>
                    <ComboBoxItem Content="화요일" Tag="2"/>
                    <ComboBoxItem Content="수요일" Tag="3"/>
                    <ComboBoxItem Content="목요일" Tag="4"/>
                    <ComboBoxItem Content="금요일" Tag="5"/>
                </ComboBox>

                <!-- 교시 -->
                <ComboBox 
                    Grid.Column="1"
                    x:Name="CBoxPeriod"
                    Header="교시"
                    PlaceholderText="선택"
                    HorizontalAlignment="Stretch">
                    <ComboBoxItem Content="1교시" Tag="1"/>
                    <ComboBoxItem Content="2교시" Tag="2"/>
                    <ComboBoxItem Content="3교시" Tag="3"/>
                    <ComboBoxItem Content="4교시" Tag="4"/>
                    <ComboBoxItem Content="5교시" Tag="5"/>
                    <ComboBoxItem Content="6교시" Tag="6"/>
                    <ComboBoxItem Content="7교시" Tag="7"/>
                </ComboBox>

                <!-- 강의실 -->
                <ComboBox 
                    Grid.Column="2"
                    x:Name="CBoxRoom"
                    Header="강의실"
                    PlaceholderText="선택"
                    HorizontalAlignment="Stretch"
                    IsEditable="True"/>

                <!-- 추가 버튼 -->
                <Button 
                    Grid.Column="3"
                    Content="추가"
                    Style="{StaticResource AccentButtonStyle}"
                    Click="OnAddScheduleClick"
                    VerticalAlignment="Bottom"
                    MinWidth="80"/>
            </Grid>
        </Border>

        <!-- 시간표 목록 -->
        <Grid Grid.Row="3">
            <!-- 빈 상태 -->
            <StackPanel 
                x:Name="EmptyState"
                Visibility="Visible"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Spacing="12">
                <FontIcon 
                    Glyph="&#xE8F4;" 
                    FontSize="48"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                <TextBlock 
                    Text="시간표가 배치되지 않았습니다" 
                    FontSize="14"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                <TextBlock 
                    Text="요일, 교시, 강의실을 선택하고 [추가] 버튼을 누르세요" 
                    FontSize="12"
                    Foreground="{ThemeResource TextFillColorTertiaryBrush}"/>
            </StackPanel>

            <!-- 리스트 -->
            <ListView 
                x:Name="ScheduleListView"
                Visibility="Collapsed"
                SelectionMode="None">
                <ListView.ItemTemplate>
                    <DataTemplate x:DataType="models:Lesson"
                                 xmlns:models="using:NewSchool.Models">
                        <Grid 
                            Padding="12,8"
                            ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" Spacing="4">
                                <TextBlock 
                                    FontSize="15" 
                                    FontWeight="SemiBold">
                                    <Run Text="{x:Bind DayName}"/>
                                    <Run Text="요일"/>
                                    <Run Text="{x:Bind Period}"/>
                                    <Run Text="교시"/>
                                </TextBlock>
                                <TextBlock 
                                    Text="{x:Bind Room}"
                                    FontSize="13"
                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            </StackPanel>

                            <Button 
                                Grid.Column="1"
                                Click="OnRemoveScheduleClick"
                                Tag="{x:Bind}">
                                <FontIcon Glyph="&#xE74D;" FontSize="14"/>
                            </Button>
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </Grid>
    </Grid>
</ContentDialog>

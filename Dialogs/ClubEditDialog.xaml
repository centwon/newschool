<?xml version="1.0" encoding="utf-8"?>
<ContentDialog
    x:Class="NewSchool.Dialogs.ClubEditDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="동아리 추가"
    PrimaryButtonText="저장"
    CloseButtonText="취소"
    DefaultButton="Primary"
    PrimaryButtonClick="OnPrimaryButtonClick"
    Width="500">

    <StackPanel Spacing="16">
        <!-- 에러 메시지 -->
        <InfoBar 
            x:Name="ErrorInfoBar"
            Severity="Error"
            IsOpen="False"
            IsClosable="True"/>

        <!-- 동아리명 -->
        <TextBox 
            x:Name="TxtClubName"
            Header="동아리명"
            PlaceholderText="동아리 이름을 입력하세요"
            MaxLength="50"/>

        <!-- 활동실 -->
        <TextBox 
            x:Name="TxtActivityRoom"
            Header="활동실"
            PlaceholderText="활동 장소 (예: 3층 동아리실)"
            MaxLength="50"/>

        <!-- 비고 -->
        <TextBox 
            x:Name="TxtRemark"
            Header="비고"
            PlaceholderText="추가 설명"
            AcceptsReturn="True"
            TextWrapping="Wrap"
            Height="80"
            MaxLength="200"/>
    </StackPanel>
</ContentDialog>

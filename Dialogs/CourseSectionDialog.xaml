<?xml version="1.0" encoding="utf-8"?>
<ContentDialog
    x:Class="NewSchool.Dialogs.CourseSectionDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:NewSchool.Dialogs"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    x:Name="Dialog"
    Title="소단원 편집"
    PrimaryButtonText="저장"
    CloseButtonText="취소"
    DefaultButton="Primary"
    PrimaryButtonClick="OnPrimaryButtonClick">

    <ContentDialog.Resources>
        <x:Double x:Key="ContentDialogMaxWidth">700</x:Double>
        <x:Double x:Key="ContentDialogMaxHeight">800</x:Double>
    </ContentDialog.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="700">
        <StackPanel Spacing="16" Width="600" Padding="4">
            <!-- 과목 정보 -->
            <StackPanel Orientation="Horizontal" Spacing="12">
                <TextBlock x:Name="TxtCourseName"
                           FontSize="16"
                           FontWeight="SemiBold"
                           VerticalAlignment="Center"/>
                <TextBlock x:Name="TxtCourseInfo"
                           FontSize="13"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                           VerticalAlignment="Center"/>
            </StackPanel>

            <Border Height="1" Background="{ThemeResource DividerStrokeColorDefaultBrush}"/>

            <!-- 대단원 -->
            <StackPanel Spacing="6">
                <TextBlock Text="대단원" FontSize="13" FontWeight="SemiBold"/>
                <Grid ColumnSpacing="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <NumberBox x:Name="NumUnitNo" 
                               Grid.Column="0"
                               Header="번호"
                               Width="100" 
                               Minimum="0" 
                               Maximum="20" 
                               Value="1" 
                               SpinButtonPlacementMode="Compact"/>
                    <TextBox x:Name="TxtUnitName" 
                             Grid.Column="1"
                             Header="대단원명"
                             PlaceholderText="예) 수와 연산"/>
                </Grid>
            </StackPanel>

            <!-- 중단원 -->
            <StackPanel Spacing="6">
                <TextBlock Text="중단원" FontSize="13" FontWeight="SemiBold"/>
                <Grid ColumnSpacing="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <NumberBox x:Name="NumChapterNo" 
                               Grid.Column="0"
                               Header="번호"
                               Width="100" 
                               Minimum="0" 
                               Maximum="20" 
                               Value="1" 
                               SpinButtonPlacementMode="Compact"/>
                    <TextBox x:Name="TxtChapterName" 
                             Grid.Column="1"
                             Header="중단원명"
                             PlaceholderText="예) 자연수의 혼합 계산"/>
                </Grid>
            </StackPanel>

            <!-- 소단원 -->
            <StackPanel Spacing="6">
                <TextBlock Text="소단원 *" FontSize="13" FontWeight="SemiBold" Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"/>
                <Grid ColumnSpacing="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <NumberBox x:Name="NumSectionNo" 
                               Grid.Column="0"
                               Header="번호"
                               Width="100" 
                               Minimum="1" 
                               Maximum="50" 
                               Value="1" 
                               SpinButtonPlacementMode="Compact"/>
                    <TextBox x:Name="TxtSectionName" 
                             Grid.Column="1"
                             Header="소단원명 (필수)"
                             PlaceholderText="예) 덧셈과 뺄셈의 혼합 계산"/>
                </Grid>
            </StackPanel>

            <Border Height="1" Background="{ThemeResource DividerStrokeColorDefaultBrush}"/>

            <!-- 유형 및 기본 정보 -->
            <Grid ColumnSpacing="12" RowSpacing="16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- 유형 -->
                <ComboBox x:Name="CmbSectionType" 
                          Grid.Column="0" Grid.Row="0"
                          Header="유형"
                          HorizontalAlignment="Stretch" 
                          SelectedIndex="0">
                    <ComboBoxItem Content="일반수업" Tag="Normal"/>
                    <ComboBoxItem Content="지필고사" Tag="Exam"/>
                    <ComboBoxItem Content="수행평가" Tag="Assessment"/>
                    <ComboBoxItem Content="행사/기타" Tag="Event"/>
                </ComboBox>

                <!-- 예상 차시 -->
                <NumberBox x:Name="NumEstimatedHours" 
                           Grid.Column="1" Grid.Row="0"
                           Header="예상 차시"
                           Minimum="1" 
                           Maximum="20" 
                           Value="1" 
                           SpinButtonPlacementMode="Compact"/>

                <!-- 시작 페이지 -->
                <NumberBox x:Name="NumStartPage" 
                           Grid.Column="0" Grid.Row="1"
                           Header="시작 페이지"
                           Minimum="0" 
                           Maximum="500" 
                           Value="0" 
                           SpinButtonPlacementMode="Compact"/>

                <!-- 끝 페이지 -->
                <NumberBox x:Name="NumEndPage" 
                           Grid.Column="1" Grid.Row="1"
                           Header="끝 페이지"
                           Minimum="0" 
                           Maximum="500" 
                           Value="0" 
                           SpinButtonPlacementMode="Compact"/>
            </Grid>

            <!-- 고정 날짜 (평가용) -->
            <StackPanel x:Name="PinnedDatePanel" Spacing="6" Visibility="Collapsed">
                <TextBlock Text="고정 날짜 (평가 일정)" FontSize="13" FontWeight="SemiBold"/>
                <CalendarDatePicker x:Name="DpPinnedDate" 
                                    PlaceholderText="날짜 선택"
                                    DateFormat="{}{year.full}-{month.integer(2)}-{day.integer(2)}"
                                    HorizontalAlignment="Stretch"/>
            </StackPanel>

            <Border Height="1" Background="{ThemeResource DividerStrokeColorDefaultBrush}"/>

            <!-- 학습 목표 -->
            <StackPanel Spacing="6">
                <TextBlock Text="학습 목표" FontSize="13" FontWeight="SemiBold"/>
                <TextBox x:Name="TxtLearningObjective"
                         PlaceholderText="예) 자연수의 혼합 계산 순서를 알고 계산할 수 있다"
                         TextWrapping="Wrap"
                         AcceptsReturn="True"
                         Height="60"
                         MaxLength="500"/>
            </StackPanel>

            <!-- 수업 계획 메모 -->
            <StackPanel Spacing="6">
                <TextBlock Text="수업 계획 메모" FontSize="13" FontWeight="SemiBold"/>
                <TextBox x:Name="TxtLessonPlan"
                         PlaceholderText="예) 개념 도입 → 모둠 활동 → 평가"
                         TextWrapping="Wrap"
                         AcceptsReturn="True"
                         Height="70"/>
            </StackPanel>

            <!-- 자료 파일 -->
            <StackPanel Spacing="6">
                <TextBlock Text="자료 파일 (PPT, PDF 등)" FontSize="13" FontWeight="SemiBold"/>
                <Grid ColumnSpacing="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="TxtMaterialPath" 
                             Grid.Column="0"
                             PlaceholderText="파일 경로"
                             IsReadOnly="True"/>
                    <Button Grid.Column="1" 
                            Content="찾아보기..." 
                            Click="OnBrowseMaterialClick"
                            Padding="16,8"/>
                </Grid>
            </StackPanel>

            <!-- 자료 웹 링크 -->
            <StackPanel Spacing="6">
                <TextBlock Text="자료 웹 링크" FontSize="13" FontWeight="SemiBold"/>
                <TextBox x:Name="TxtMaterialUrl" 
                         PlaceholderText="https://..."/>
            </StackPanel>

            <!-- 수업 후기/메모 -->
            <StackPanel Spacing="6">
                <TextBlock Text="수업 후기/메모 (차년도 참고용)" FontSize="13" FontWeight="SemiBold"/>
                <TextBox x:Name="TxtMemo" 
                         PlaceholderText="수업 후 작성"
                         TextWrapping="Wrap"
                         AcceptsReturn="True"
                         Height="80"/>
            </StackPanel>

            <!-- 오류 메시지 -->
            <InfoBar x:Name="ErrorInfoBar"
                     IsOpen="False"
                     Severity="Error"
                     IsClosable="True"/>
        </StackPanel>
    </ScrollViewer>
</ContentDialog>

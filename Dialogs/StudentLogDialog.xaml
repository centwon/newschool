<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="NewSchool.Dialogs.StudentLogDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:controls="using:NewSchool.Controls"
    xmlns:models="using:NewSchool.Models"
    mc:Ignorable="d"
    Title="학생 기록">

    <Grid Padding="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- 헤더 영역 -->
            <RowDefinition Height="*"/>     <!-- 메인 컨텐츠 -->
        </Grid.RowDefinitions>

        <!-- ========== 헤더 영역 ========== -->
        <Grid Grid.Row="0" Margin="0,0,0,12">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- 필터 컨트롤 -->
            <StackPanel Grid.Row="0" 
                        Orientation="Horizontal" 
                        Spacing="12"
                        Margin="0,0,0,8">

                <!-- 카테고리 -->
                <ComboBox x:Name="CBoxCategory"
                          Header="영역"
                          MinWidth="120"
                          SelectionChanged="OnCategoryChanged"/>

                <!-- 과목 (교과활동/개인별세특) -->
                <ComboBox x:Name="CBoxCourse"
                          Header="과목"
                          MinWidth="150"
                          Visibility="Collapsed"
                          SelectionChanged="OnCourseChanged">
                    <ComboBox.ItemTemplate>
                        <DataTemplate x:DataType="models:Course">
                            <TextBlock Text="{x:Bind Subject}"/>
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>

                <!-- 동아리 -->
                <ComboBox x:Name="CBoxClub"
                          Header="동아리"
                          MinWidth="150"
                          Visibility="Collapsed"
                          SelectionChanged="OnClubChanged">
                    <ComboBox.ItemTemplate>
                        <DataTemplate x:DataType="models:Club">
                            <TextBlock Text="{x:Bind ClubName}"/>
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>

                <!-- 학년 -->
                <ComboBox x:Name="CBoxGrade"
                          Header="학년"
                          MinWidth="80"
                          Visibility="Collapsed"
                          SelectionChanged="OnGradeChanged"/>

                <!-- 반 -->
                <ComboBox x:Name="CBoxClass"
                          Header="반"
                          MinWidth="80"
                          Visibility="Collapsed"
                          SelectionChanged="OnClassChanged"/>
            </StackPanel>

            <!-- 정보 표시 -->
            <TextBlock x:Name="TxtStudentInfo"
                       Grid.Row="1"
                       Text=""
                       FontWeight="SemiBold"
                       FontSize="14"
                       Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"
                       Margin="0,4,0,0"/>
        </Grid>

        <!-- ========== 메인 컨텐츠 ========== -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition x:Name="ColStudentList" Width="280"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- 좌측: 학생 목록 -->
            <controls:ListStudent x:Name="ListStudents"
                                  Grid.Column="0"
                                  HorizontalAlignment="Stretch"
                                  VerticalAlignment="Stretch"/>

            <!-- 우측: StudentLogBox -->
            <controls:StudentLogBox x:Name="LogBox"
                                    Grid.Column="2"/>
        </Grid>
    </Grid>
</Window>

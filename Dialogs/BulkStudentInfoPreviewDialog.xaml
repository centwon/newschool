<ContentDialog
    x:Class="NewSchool.Dialogs.BulkStudentInfoPreviewDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="학생 정보 일괄 입력 미리보기"
    PrimaryButtonText="적용"
    CloseButtonText="취소"
    DefaultButton="Primary">

    <StackPanel Spacing="12" MinWidth="500" MaxHeight="500">
        <!-- 요약 정보 -->
        <Border Background="#F0F8FF" CornerRadius="6" Padding="12,8">
            <TextBlock x:Name="TxtSummary"
                       FontSize="13"
                       TextWrapping="Wrap"/>
        </Border>

        <!-- 학생별 변경 내용 목록 -->
        <ListView x:Name="PreviewListView"
                  MaxHeight="380"
                  SelectionMode="None">
            <ListView.ItemTemplate>
                <DataTemplate>
                    <Grid Padding="4,4" ColumnSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- 상태 아이콘 -->
                        <FontIcon x:Name="StatusIcon"
                                  Grid.Column="0"
                                  FontSize="14"
                                  VerticalAlignment="Center"/>

                        <!-- 변경 내용 -->
                        <TextBlock Grid.Column="1"
                                   TextWrapping="Wrap"
                                   FontSize="12"
                                   VerticalAlignment="Center"/>
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </StackPanel>
</ContentDialog>

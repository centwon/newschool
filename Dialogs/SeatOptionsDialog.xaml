<?xml version="1.0" encoding="utf-8"?>
<ContentDialog
    x:Class="NewSchool.Dialogs.SeatOptionsDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="좌석 배치 옵션"
    PrimaryButtonText="확인"
    CloseButtonText="취소"
    DefaultButton="Primary">

    <Pivot MinWidth="520" MinHeight="420">

        <!-- 탭 1: 이력 기반 -->
        <PivotItem Header="이력">
            <StackPanel Spacing="12" Padding="0,8,0,0">
                <TextBlock Text="저장된 배치 이력을 활용해 반복을 피합니다."
                           FontSize="12"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>

                <StackPanel Spacing="4">
                    <CheckBox x:Name="ChkRecentPair" Content="지난 짝 배제"/>
                    <StackPanel Orientation="Horizontal" Spacing="8" Margin="28,0,0,0">
                        <TextBlock Text="최근" VerticalAlignment="Center"/>
                        <NumberBox x:Name="NbxRecentPair"
                                   Value="1" Minimum="1" Maximum="10"
                                   SpinButtonPlacementMode="Compact"
                                   Width="100"/>
                        <TextBlock Text="회차의 짝 관계 회피" VerticalAlignment="Center"/>
                    </StackPanel>
                </StackPanel>

                <StackPanel Spacing="4">
                    <CheckBox x:Name="ChkRecentPos" Content="지난 자리 배제"/>
                    <StackPanel Orientation="Horizontal" Spacing="8" Margin="28,0,0,0">
                        <TextBlock Text="최근" VerticalAlignment="Center"/>
                        <NumberBox x:Name="NbxRecentPos"
                                   Value="1" Minimum="1" Maximum="10"
                                   SpinButtonPlacementMode="Compact"
                                   Width="100"/>
                        <TextBlock Text="회차의 같은 좌표 회피" VerticalAlignment="Center"/>
                    </StackPanel>
                </StackPanel>

                <InfoBar x:Name="HistoryInfo"
                         IsOpen="True" IsClosable="False"
                         Severity="Informational"
                         Title="누적된 이력"
                         Message="아직 저장된 배치가 없습니다."/>
            </StackPanel>
        </PivotItem>

        <!-- 탭 2: 학생 속성 -->
        <PivotItem Header="속성">
            <StackPanel Spacing="14" Padding="0,8,0,0">
                <CheckBox x:Name="ChkMixedGender"
                          Content="남녀 교차 짝 (짝 모드일 때 우선 적용)"/>

                <StackPanel Spacing="6">
                    <TextBlock Text="앞자리 우선 학생" FontWeight="SemiBold"/>
                    <TextBlock Text="시력·집중력 이슈 학생을 앞쪽 줄 범위에 고정합니다."
                               FontSize="11"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <TextBlock Text="허용 범위:" VerticalAlignment="Center"/>
                        <TextBlock Text="Row 0 ~" VerticalAlignment="Center"/>
                        <NumberBox x:Name="NbxFrontMaxRow"
                                   Value="1" Minimum="0" Maximum="9"
                                   SpinButtonPlacementMode="Compact"
                                   Width="100"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <ComboBox x:Name="CbxFrontStudent"
                                  PlaceholderText="학생 선택"
                                  MinWidth="200"/>
                        <Button x:Name="BtnAddFront" Content="추가"
                                Click="BtnAddFront_Click"/>
                    </StackPanel>
                    <ListView x:Name="FrontListView"
                              MaxHeight="140"
                              SelectionMode="None"/>
                </StackPanel>
            </StackPanel>
        </PivotItem>

        <!-- 탭 3: 짝 제약 (기존 분리/고정) -->
        <PivotItem Header="짝 제약">
            <StackPanel Spacing="10" Padding="0,8,0,0">
                <Grid ColumnSpacing="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <ComboBox x:Name="CbxPairA" Grid.Column="0"
                              PlaceholderText="학생 A"
                              HorizontalAlignment="Stretch"/>
                    <ComboBox x:Name="CbxPairB" Grid.Column="1"
                              PlaceholderText="학생 B"
                              HorizontalAlignment="Stretch"/>
                </Grid>

                <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center">
                    <Button Click="BtnAddExclusion_Click">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <FontIcon Glyph="&#xE711;" FontSize="14"/>
                            <TextBlock Text="분리 추가" FontSize="12"/>
                        </StackPanel>
                    </Button>
                    <Button Click="BtnAddFixed_Click">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <FontIcon Glyph="&#xE718;" FontSize="14"/>
                            <TextBlock Text="고정 추가" FontSize="12"/>
                        </StackPanel>
                    </Button>
                </StackPanel>

                <ListView x:Name="PairListView"
                          MaxHeight="220"
                          SelectionMode="None"/>

                <TextBlock x:Name="PairEmpty"
                           Text="설정된 짝 조건이 없습니다."
                           FontSize="12"
                           Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                           HorizontalAlignment="Center"/>
            </StackPanel>
        </PivotItem>

        <!-- 탭 4: 배치 방식 -->
        <PivotItem Header="방식">
            <StackPanel Spacing="12" Padding="0,8,0,0">
                <StackPanel Spacing="4">
                    <TextBlock Text="배치 시도 횟수" FontWeight="SemiBold"/>
                    <TextBlock Text="제약이 많을수록 더 많은 시도가 필요합니다."
                               FontSize="11"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    <ComboBox x:Name="CbxAttempts" MinWidth="140">
                        <ComboBoxItem Content="100" Tag="100"/>
                        <ComboBoxItem Content="500" Tag="500" IsSelected="True"/>
                        <ComboBoxItem Content="1000" Tag="1000"/>
                        <ComboBoxItem Content="3000" Tag="3000"/>
                    </ComboBox>
                </StackPanel>
            </StackPanel>
        </PivotItem>
    </Pivot>
</ContentDialog>
